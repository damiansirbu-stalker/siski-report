siski = siski or {}
siski.tasks = siski.tasks or {}

local tasks = siski.tasks

local tonumber  = _G.tonumber
local time_global = _G.time_global
local alife      = _G.alife
local game_graph = _G.game_graph

local RUNTIME = {
    smarts_by_level = {},
    smarts_rebuild_tg = 0,
    smarts_build = {
        active = false,
        last_key = nil,
        temp = nil,
        gvid_level_cache = nil,
        started_tg = 0,
    },
    beh_ini = nil,
    task_err_once = {},
    smart_enemy_cache = {},
    smart_trade_slot_cache = {},
    smart_tech_slot_cache = {},
    smart_kamp_slot_cache = {},
    target_arrived_state_cache = {},
    surge_cache_active = false,
    surge_cache_next_tg = 0,
    cache_prune_next_tg = 0,
    perf_warn_next_tg = {},
    smart_enemy_fallback_cache = {},
    adaptive_trade_target_cache = {},
    cap_index_by_level = {},
    cap_index_rebuild_tg = 0,
    artefact_pool = false,
    faction_quota = {
        next_tg = 0,
        by_level_faction = {},
    },
    intel = {
        by_level_faction = {},
        next_cleanup_tg = 0,
    },
    stats = {
        watchdog_rebuild_count = 0,
        forced_faction_assignments = 0,
        forced_faction_releases = 0,
        faction_runner_cycles = 0,
        faction_runner_reacquire = 0,
        force_resync_count = 0,
    },
    cold_start = {
        active = false,
        phase = nil,
        started_tg = 0,
        start_sim_cycles = 0,
        pending_ids = {},
        pending_head = 1,
        pending_set = {},
        pending_count = 0,
        retry_next_tg_by_sid = {},
        assigned_count = 0,
        skipped_count = 0,
        dropped_count = 0,
        stats_log_next_tg = 0,
    },
    cold_start_cfg = {
        profiles = {
            [1] = { warmup_ms = 2, assign_ms = 2, assign_budget = 8 },
            [2] = { warmup_ms = 4, assign_ms = 4, assign_budget = 16 },
            [3] = { warmup_ms = 6, assign_ms = 6, assign_budget = 24 },
            [4] = { warmup_ms = 4, assign_ms = 4, assign_budget = 16 },
        },
        log_interval_ms = 10000,
        warmup_step_budget = 16,
        retry_ms = 1000,
        compact_min_head = 64,
    },
}

local WATCHDOG_SCAN_INTERVAL_MS = 5000
local WATCHDOG_CHECK_INTERVAL = 3
local TARGET_REVALIDATE_INTERVAL_MS = 5000
local COMMUNITY_REFRESH_TTL_MS = 15000
local COMMUNITY_RETRY_TTL_MS = 1000
local LOGIC_MAX_AGE_MS = 90000
local DIRTY_ENEMY_TTL_MS = 5000
local DIRTY_TRADE_PICK_TTL_MS = 3000
local DIRTY_REVALIDATE_TTL_MS = 5000
local INTEL_TTL_MS = 300000
local FACTION_QUOTA_UPDATE_MS = 3000
local FACTION_RUNNER_REACQUIRE_MS = 10000
local ARTEFACT_CHECK_INTERVAL_MS = 5000
local ARTEFACT_SCAN_RADIUS = 50
local ARTEFACT_RELEASE_CONFIRM_MS = 3000
local ARTEFACT_OFFLINE_ROLL_PERCENT = 25
local ARRIVAL_ASSIST_SETTLE_MS = 10000
local ADAPTIVE_FORCE_WATCHDOG_MS = 10000
local ADAPTIVE_FORCE_REVALIDATE_MS = 30000
local ADAPTIVE_FORCE_TRADE_TICK_MS = 2000
local ADAPTIVE_FORCE_TRADE_PICK_MS = 5000
-- REMOVED: ADAPTIVE_FORCE_ENEMY_NEAR_SMART_MS - enemy scan optimized, no longer needs adaptive throttling
-- REMOVED: ADAPTIVE_FORCE_ENEMY_FALLBACK_SCAN_MS - enemy scan optimized, no longer needs adaptive throttling
local ADAPTIVE_FORCE_REBUILD_ENSURE_MS = 1500
local ADAPTIVE_FORCE_SMARTS_STEP_MS = 2000
local ADAPTIVE_FORCE_FACTION_PREEMPT_MS = 5000
local FACTION_PREEMPT_CHECK_INTERVAL = 3

local function tg()
    return (time_global and time_global()) or 0
end

local function cfg_num(key, default, min_v)
    local v = tonumber(default) or 0
    if siski.config and siski.config.get then
        local x = siski.config.get(key, default)
        if tonumber(x) then
            v = tonumber(x)
        end
    end
    if min_v ~= nil and v < min_v then
        v = min_v
    end
    return v
end

local function adaptive_mod()
    local ad = siski and siski.adaptive or nil
    if not (ad and ad.enabled and ad.enabled()) then
        return nil
    end
    return ad
end

local function adaptive_should_run(lane, now, base_interval_ms, force_max_delay_ms)
    local ad = adaptive_mod()
    if not (ad and ad.should_run) then
        return true
    end
    return ad.should_run(lane, now, base_interval_ms, force_max_delay_ms) == true
end

local function adaptive_note_defer(lane, now, reason)
    local ad = adaptive_mod()
    if ad and ad.note_defer then
        ad.note_defer(lane, now, reason)
    end
end

function tasks._cold_start_profile()
    local mode = 2
    if siski.config and siski.config.get then
        local v = tonumber(siski.config.get("perf_preset_mode", 0))
        if v and v >= 1 and v <= 4 then
            mode = v
        end
    end
    local cfg = RUNTIME.cold_start_cfg
    return cfg.profiles[mode] or cfg.profiles[2]
end

function tasks._cold_start_reset_runtime()
    local cs = RUNTIME.cold_start
    cs.active = false
    cs.phase = nil
    cs.started_tg = 0
    cs.start_sim_cycles = 0
    cs.pending_ids = {}
    cs.pending_head = 1
    cs.pending_set = {}
    cs.pending_count = 0
    cs.retry_next_tg_by_sid = {}
    cs.assigned_count = 0
    cs.skipped_count = 0
    cs.dropped_count = 0
    cs.stats_log_next_tg = 0
end

function tasks._cold_start_queue_len()
    return tonumber(RUNTIME.cold_start.pending_count) or 0
end

function tasks._cold_start_compact_queue()
    local cs = RUNTIME.cold_start
    local head = tonumber(cs.pending_head) or 1
    local ids = cs.pending_ids
    if type(ids) ~= "table" then
        cs.pending_ids = {}
        cs.pending_head = 1
        return
    end
    if head <= (tonumber(RUNTIME.cold_start_cfg.compact_min_head) or 64) then
        return
    end

    local compact = {}
    local n = 0
    for i = head, #ids do
        local sid = ids[i]
        if sid ~= nil then
            n = n + 1
            compact[n] = sid
        end
    end
    cs.pending_ids = compact
    cs.pending_head = 1
end

function tasks._cold_start_enqueue(sid)
    local id = tonumber(sid)
    if not id then return false end
    local cs = RUNTIME.cold_start
    if cs.pending_set[id] then
        return false
    end
    local ids = cs.pending_ids
    ids[#ids + 1] = id
    cs.pending_set[id] = true
    cs.pending_count = (tonumber(cs.pending_count) or 0) + 1
    return true
end

function tasks._cold_start_dequeue()
    local cs = RUNTIME.cold_start
    local ids = cs.pending_ids
    local head = tonumber(cs.pending_head) or 1
    while type(ids) == "table" and head <= #ids do
        local sid = ids[head]
        ids[head] = nil
        head = head + 1
        cs.pending_head = head
        if sid ~= nil then
            cs.pending_set[sid] = nil
            cs.pending_count = math.max(0, (tonumber(cs.pending_count) or 0) - 1)
            tasks._cold_start_compact_queue()
            return sid
        end
    end
    cs.pending_ids = {}
    cs.pending_head = 1
    cs.pending_count = 0
    return nil
end

function tasks._cold_start_log(now, fmt, ...)
    local cs = RUNTIME.cold_start
    now = tonumber(now) or tg()
    if now < (tonumber(cs.stats_log_next_tg) or 0) then
        return
    end
    cs.stats_log_next_tg = now + (tonumber(RUNTIME.cold_start_cfg.log_interval_ms) or 10000)
    if siski.log and siski.log.debug then
        siski.log.debug("TASKS", fmt, ...)
    end
end

local function iter_logic_squads(max_age_ms)
    local mem = siski.memory
    if mem and mem.iter_squads_for_logic then
        return mem.iter_squads_for_logic(max_age_ms or LOGIC_MAX_AGE_MS)
    end
    if mem and mem.get_state then
        local st = mem.get_state()
        local squads = st and st.squads or {}
        local function iter(tbl, last_key)
            return next(tbl, last_key)
        end
        return iter, squads, nil
    end
    local function iter_empty()
        return nil
    end
    return iter_empty, {}, nil
end

local function mark_entry_dirty(entry, key)
    if not (entry and entry.squad_id and siski.memory and siski.memory.mark_dirty) then return end
    siski.memory.mark_dirty(entry.squad_id, key)
end

local function consume_entry_dirty(entry, key)
    if not (entry and siski.memory and siski.memory.consume_dirty) then
        return false
    end
    return siski.memory.consume_dirty(entry, key) == true
end

local function get_faction_task_enabled()
    if not (siski.config and siski.config.get) then return true end
    return siski.config.get("faction_task_enabled", true) ~= false
end

local function get_faction_task_squads_per_level()
    local v = cfg_num("faction_task_squads_per_level", 1, 0)
    return math.floor(v + 0.5)
end

-- Forward declaration: used by enemy/trade helpers declared above the full intel block.
local record_intel

local function perf_warn_once(key, fmt, ...)
    if not (siski.log and siski.log.warn) then return end
    local now = tg()
    local interval = cfg_num("perf_warn_interval_ms", 10000, 1000)
    local next_tg = tonumber(RUNTIME.perf_warn_next_tg[key]) or 0
    if now < next_tg then return end
    RUNTIME.perf_warn_next_tg[key] = now + interval
    siski.log.warn("PERF", fmt, ...)
end

local function task_warn_once(key, fmt, ...)
    if not (siski.log and siski.log.warn) then return end
    local now = tg()
    local interval = cfg_num("perf_warn_interval_ms", 10000, 1000)
    local bucket = "TASKS_" .. tostring(key)
    local next_tg = tonumber(RUNTIME.perf_warn_next_tg[bucket]) or 0
    if now < next_tg then return end
    RUNTIME.perf_warn_next_tg[bucket] = now + interval
    siski.log.warn("TASKS", fmt, ...)
end

local function table_size(t)
    local n = 0
    if type(t) ~= "table" then
        return 0
    end
    for _ in pairs(t) do
        n = n + 1
    end
    return n
end

local function trim_cache_to_max(cache, max_entries, stamp_key)
    if type(cache) ~= "table" then return end
    local size = table_size(cache)
    if size <= max_entries then return end

    while size > max_entries do
        local oldest_k = nil
        local oldest_t = nil
        for k, v in pairs(cache) do
            local ts = nil
            if type(v) == "table" then
                ts = tonumber(v[stamp_key]) or tonumber(v.tg) or tonumber(v.next_tg) or 0
            else
                ts = 0
            end
            if oldest_t == nil or ts < oldest_t then
                oldest_t = ts
                oldest_k = k
            end
        end
        if oldest_k == nil then break end
        cache[oldest_k] = nil
        size = size - 1
    end
end

local function prune_runtime_caches(now)
    if now < (tonumber(RUNTIME.cache_prune_next_tg) or 0) then
        return
    end
    RUNTIME.cache_prune_next_tg = now + 1000

    local enemy_ttl = cfg_num("smart_enemy_cache_ttl_ms", 5000, 250)
    for k, v in pairs(RUNTIME.smart_enemy_cache) do
        local ts = type(v) == "table" and tonumber(v.tg) or nil
        if (not ts) or now > (ts + enemy_ttl * 4) then
            RUNTIME.smart_enemy_cache[k] = nil
        end
    end

    for k, v in pairs(RUNTIME.smart_trade_slot_cache) do
        local ts = type(v) == "table" and tonumber(v.tg) or nil
        if (not ts) or now > (ts + 180000) then
            RUNTIME.smart_trade_slot_cache[k] = nil
        end
    end
    for k, v in pairs(RUNTIME.smart_tech_slot_cache) do
        local ts = type(v) == "table" and tonumber(v.tg) or nil
        if (not ts) or now > (ts + 180000) then
            RUNTIME.smart_tech_slot_cache[k] = nil
        end
    end
    for k, v in pairs(RUNTIME.smart_kamp_slot_cache) do
        local ts = type(v) == "table" and tonumber(v.tg) or nil
        if (not ts) or now > (ts + 180000) then
            RUNTIME.smart_kamp_slot_cache[k] = nil
        end
    end
    for k, v in pairs(RUNTIME.target_arrived_state_cache) do
        local ts = type(v) == "table" and tonumber(v.next_tg) or nil
        if (not ts) or now > (ts + 15000) then
            RUNTIME.target_arrived_state_cache[k] = nil
        end
    end
    for k, v in pairs(RUNTIME.smart_enemy_fallback_cache) do
        local ts = type(v) == "table" and tonumber(v.tg) or nil
        if (not ts) or now > (ts + enemy_ttl * 4) then
            RUNTIME.smart_enemy_fallback_cache[k] = nil
        end
    end
    for k, v in pairs(RUNTIME.adaptive_trade_target_cache) do
        local ts = type(v) == "table" and tonumber(v.tg) or nil
        if (not ts) or now > (ts + 180000) then
            RUNTIME.adaptive_trade_target_cache[k] = nil
        end
    end

    trim_cache_to_max(RUNTIME.smart_enemy_cache, cfg_num("smart_enemy_cache_max_entries", 2048, 128), "tg")
    trim_cache_to_max(RUNTIME.smart_trade_slot_cache, cfg_num("smart_slot_cache_max_entries", 1024, 64), "tg")
    trim_cache_to_max(RUNTIME.smart_tech_slot_cache, cfg_num("smart_slot_cache_max_entries", 1024, 64), "tg")
    trim_cache_to_max(RUNTIME.smart_kamp_slot_cache, cfg_num("smart_slot_cache_max_entries", 1024, 64), "tg")
    trim_cache_to_max(RUNTIME.target_arrived_state_cache, cfg_num("target_arrived_cache_max_entries", 512, 64), "next_tg")
    trim_cache_to_max(RUNTIME.smart_enemy_fallback_cache, cfg_num("smart_enemy_cache_max_entries", 2048, 128), "tg")
    trim_cache_to_max(RUNTIME.adaptive_trade_target_cache, cfg_num("smart_slot_cache_max_entries", 1024, 64), "tg")
end

local function has_game_time()
    return game and game.get_game_time and game.CTime
end

local function ctime_to_table(ct)
    if not (ct and ct.get) then return nil end
    local ok, Y, M, D, h, m, s, ms = pcall(function()
        return ct:get(0, 0, 0, 0, 0, 0, 0)
    end)
    if not ok then return nil end
    return { Y = Y, M = M, D = D, h = h, m = m, s = s, ms = ms }
end

local function ctime_from_table(t)
    if not (has_game_time() and t and type(t) == "table") then return nil end
    local ok_new, ct = pcall(function() return game.CTime() end)
    if not (ok_new and ct and ct.set) then return nil end
    local ok_set = pcall(function()
        ct:set(t.Y, t.M, t.D, t.h, t.m, t.s, t.ms)
    end)
    if not ok_set then return nil end
    return ct
end

local function game_time_now()
    if not has_game_time() then return nil end
    local ok, ct = pcall(function() return game.get_game_time() end)
    return ok and ct or nil
end

local function is_night_now()
    local ct = game_time_now()
    if not (ct and ct.get) then
        return false
    end
    local t = ctime_to_table(ct)
    local h = t and tonumber(t.h) or nil
    if h == nil then
        return false
    end
    return h >= 22 or h < 6
end

local function game_time_diff_sec(start_ct)
    local now = game_time_now()
    if not (now and now.diffSec and start_ct) then return nil end
    local ok, sec = pcall(function() return now:diffSec(start_ct) end)
    sec = ok and tonumber(sec) or nil
    return sec
end

local function now_level_name_by_gvid(gvid)
    if not (gvid and alife and game_graph) then return nil end
    local ok, res = pcall(function()
        local gv = game_graph():vertex(gvid)
        if not gv then return nil end
        return alife():level_name(gv:level_id())
    end)
    return ok and res or nil
end

local function get_board()
    if SIMBOARD then return SIMBOARD end
    if sim_board and sim_board.get_sim_board then
        local ok, b = pcall(function() return sim_board.get_sim_board() end)
        if ok then return b end
    end
    return nil
end

local function safe_obj_by_id(id)
    id = tonumber(id)
    if not id then return nil end
    if level and level.object_by_id then
        local ok, obj = pcall(function() return level.object_by_id(id) end)
        if ok and obj then return obj end
    end
    if db and db.storage and db.storage[id] then
        local obj = db.storage[id].object
        if obj then return obj end
    end
    return nil
end

local function is_alive_obj(obj)
    if not obj then return false end
    if obj.alive then
        local ok, a = pcall(function() return obj:alive() end)
        if ok then return a == true end
    end
    return true
end

local function surge_active_uncached()
    local xc = _G.xr_conditions
    local xf = xc and xc.surge_started or nil
    if type(xf) == "function" then
        local ok, res = pcall(xf)
        if ok and res == true then return true, false end
        if ok and res == false then return false, false end
    end

    local fallback_used = false

    local f = _G.surge_started
    if type(f) == "function" then
        fallback_used = true
        local ok, res = pcall(f)
        if ok and res == true then return true, fallback_used end
        if ok and res == false then return false, fallback_used end
    end

    local psm = _G.psi_storm_manager
    if psm and type(psm.is_loaded) == "function" and type(psm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return psm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return psm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    local sm = _G.surge_manager
    if sm and type(sm.is_loaded) == "function" and type(sm.is_started) == "function" then
        fallback_used = true
        local okL, loaded = pcall(function() return sm.is_loaded() end)
        if okL and loaded == true then
            local okS, started = pcall(function() return sm.is_started() end)
            if okS and started == true then return true, fallback_used end
        end
    end

    if _G.level and type(_G.level.is_surge) == "function" then
        fallback_used = true
        local ok, res = pcall(function() return _G.level.is_surge() end)
        if ok and res == true then return true, fallback_used end
    end

    return false, fallback_used
end

local function is_surge_active(force_refresh)
    local now = tg()
    if force_refresh ~= true and now < (tonumber(RUNTIME.surge_cache_next_tg) or 0) then
        return RUNTIME.surge_cache_active == true
    end

    local active, fallback_used = surge_active_uncached()
    local cache_ms = cfg_num("surge_check_cache_ms", 250, 0)
    RUNTIME.surge_cache_active = active == true
    RUNTIME.surge_cache_next_tg = now + cache_ms

    if fallback_used then
        perf_warn_once("PERF_SURGE_CHECK_FALLBACK_TASKS", "PERF_SURGE_CHECK_FALLBACK source=tasks")
    end
    return active == true
end

local function start_smarts_build()
    if RUNTIME.smarts_build.active then return end
    RUNTIME.smarts_build.active = true
    RUNTIME.smarts_build.last_key = nil
    RUNTIME.smarts_build.temp = {}
    RUNTIME.smarts_build.gvid_level_cache = {}
    RUNTIME.smarts_build.started_tg = tg()
end

local function step_smarts_build(budget)
    local board = get_board()
    if not (board and board.smarts_by_names) then
        RUNTIME.smarts_by_level = {}
        RUNTIME.cap_index_by_level = {}
        RUNTIME.cap_index_rebuild_tg = 0
        RUNTIME.smarts_rebuild_tg = tg()
        RUNTIME.smarts_build.active = false
        RUNTIME.smarts_build.last_key = nil
        RUNTIME.smarts_build.temp = nil
        RUNTIME.smarts_build.gvid_level_cache = nil
        return
    end

    local build = RUNTIME.smarts_build
    if not build.active then return end

    local temp = build.temp or {}
    local gvid_cache = build.gvid_level_cache or {}
    local last = build.last_key

    for _ = 1, budget do
        local name, sm = next(board.smarts_by_names, last)
        last = name
        if name == nil then
            RUNTIME.smarts_by_level = temp
            RUNTIME.cap_index_rebuild_tg = 0
            RUNTIME.smarts_rebuild_tg = tg()
            build.active = false
            build.last_key = nil
            build.temp = nil
            build.gvid_level_cache = nil
            return
        end

        if sm and sm.m_game_vertex_id then
            local gvid = sm.m_game_vertex_id
            local lvl = gvid_cache[gvid]
            if lvl == nil then
                lvl = now_level_name_by_gvid(gvid)
                gvid_cache[gvid] = lvl or false
            end
            if lvl and lvl ~= false then
                local arr = temp[lvl]
                if not arr then
                    arr = {}
                    temp[lvl] = arr
                end
                arr[#arr + 1] = name
            end
        end
    end

    build.last_key = last
    build.temp = temp
    build.gvid_level_cache = gvid_cache
end

local function smart_blacklists_global_set()
    local cfg = siski.config
    if cfg and cfg.get_smart_blacklists_global_set then
        local res = cfg.get_smart_blacklists_global_set()
        if type(res) == "table" then
            return res
        end
    end
    return nil
end

local function smart_blacklists_rule(level_name)
    local cfg = siski.config
    if cfg and cfg.get_smart_blacklists_rule then
        local res = cfg.get_smart_blacklists_rule(level_name)
        if type(res) == "table" then
            return res
        end
    end
    return nil
end

local function normalize_community_key(name)
    if type(name) ~= "string" then return nil end
    local key = string.lower((string.gsub(name, "^%s*(.-)%s*$", "%1")))
    if key == "" then return nil end
    local cfg = siski.config
    if cfg and cfg.get_faction_alias then
        local alias = cfg.get_faction_alias(key)
        if type(alias) == "string" and alias ~= "" then
            alias = string.lower((string.gsub(alias, "^%s*(.-)%s*$", "%1")))
            if alias ~= "" then
                key = alias
            end
        end
    end
    return key
end

local function normalize_section_key(name)
    if type(name) ~= "string" then return nil end
    local key = string.lower((string.gsub(name, "^%s*(.-)%s*$", "%1")))
    if key == "" then return nil end
    return key
end

local function faction_level_blacklists_rule(community)
    local cfg = siski.config
    if not (cfg and cfg.get_faction_level_blacklist_rule) then
        return nil
    end
    local key = normalize_community_key(community)
    if not key then return nil end
    local res = cfg.get_faction_level_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function faction_smart_blacklists_rule(community)
    local cfg = siski.config
    if not (cfg and cfg.get_faction_smart_blacklist_rule) then
        return nil
    end
    local key = normalize_community_key(community)
    if not key then return nil end
    local res = cfg.get_faction_smart_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_level_blacklists_rule(section_name)
    local cfg = siski.config
    if not (cfg and cfg.get_section_level_blacklist_rule) then
        return nil
    end
    local key = normalize_section_key(section_name)
    if not key then return nil end
    local res = cfg.get_section_level_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function section_smart_blacklists_rule(section_name)
    local cfg = siski.config
    if not (cfg and cfg.get_section_smart_blacklist_rule) then
        return nil
    end
    local key = normalize_section_key(section_name)
    if not key then return nil end
    local res = cfg.get_section_smart_blacklist_rule(key)
    if type(res) == "table" then
        return res
    end
    return nil
end

local function is_level_blacklisted_for_faction(level_name, community, section_name)
    if type(level_name) ~= "string" or level_name == "" then
        return false
    end
    local rule = faction_level_blacklists_rule(community)
    if rule and rule.all == true then
        if siski.log and siski.log.debug then
            siski.log.debug("TASKS", "FACTION_LEVEL_BLACKLIST_HIT community=%s level=%s reason=all", tostring(community or "-"), tostring(level_name))
        end
        return true
    end
    local set = rule and rule.set or nil
    if set and set[level_name] then
        if siski.log and siski.log.debug then
            siski.log.debug("TASKS", "FACTION_LEVEL_BLACKLIST_HIT community=%s level=%s reason=list", tostring(community or "-"), tostring(level_name))
        end
        return true
    end

    local s_rule = section_level_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        if siski.log and siski.log.debug then
            siski.log.debug("TASKS", "SECTION_LEVEL_BLACKLIST_HIT section=%s level=%s reason=all", tostring(section_name or "-"), tostring(level_name))
        end
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    if s_set and s_set[level_name] then
        if siski.log and siski.log.debug then
            siski.log.debug("TASKS", "SECTION_LEVEL_BLACKLIST_HIT section=%s level=%s reason=list", tostring(section_name or "-"), tostring(level_name))
        end
        return true
    end
    return false
end

local function is_smart_blacklisted_for_faction(smart_name, community, level_name, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    if is_level_blacklisted_for_faction(level_name, community, section_name) then
        return true
    end
    local rule = faction_smart_blacklists_rule(community)
    if rule and rule.all == true then
        if siski.log and siski.log.debug then
            siski.log.debug("TASKS", "FACTION_SMART_BLACKLIST_HIT community=%s smart=%s reason=all", tostring(community or "-"), tostring(smart_name))
        end
        return true
    end
    local set = rule and rule.set or nil
    if set and set[smart_name] then
        if siski.log and siski.log.debug then
            siski.log.debug("TASKS", "FACTION_SMART_BLACKLIST_HIT community=%s smart=%s reason=list", tostring(community or "-"), tostring(smart_name))
        end
        return true
    end

    local s_rule = section_smart_blacklists_rule(section_name)
    if s_rule and s_rule.all == true then
        if siski.log and siski.log.debug then
            siski.log.debug("TASKS", "SECTION_SMART_BLACKLIST_HIT section=%s smart=%s reason=all", tostring(section_name or "-"), tostring(smart_name))
        end
        return true
    end
    local s_set = s_rule and s_rule.set or nil
    if s_set and s_set[smart_name] then
        if siski.log and siski.log.debug then
            siski.log.debug("TASKS", "SECTION_SMART_BLACKLIST_HIT section=%s smart=%s reason=list", tostring(section_name or "-"), tostring(smart_name))
        end
        return true
    end
    return false
end

local function smart_is_blacklisted_by_obj(sm, smart_name, community, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end

    local gset = smart_blacklists_global_set()
    if gset and gset[smart_name] then
        return true
    end

    local lvl = nil
    if sm and sm.m_game_vertex_id then
        lvl = now_level_name_by_gvid(sm.m_game_vertex_id)
        local rule = lvl and smart_blacklists_rule(lvl) or nil
        if rule and rule.all == true then
            return true
        end
        local set = rule and rule.set or nil
        if set and set[smart_name] then
            return true
        end
    end

    if is_smart_blacklisted_for_faction(smart_name, community, lvl, section_name) then
        return true
    end

    return false
end

local function smart_is_blacklisted_for_level(level_name, smart_name, community, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end

    local gset = smart_blacklists_global_set()
    if gset and gset[smart_name] then
        return true
    end

    local rule = level_name and smart_blacklists_rule(level_name) or nil
    if rule and rule.all == true then
        return true
    end

    local set = rule and rule.set or nil
    if set and set[smart_name] then
        return true
    end

    if is_smart_blacklisted_for_faction(smart_name, community, level_name, section_name) then
        return true
    end

    return false
end

local function get_smarts_for_level(level_name, community, section_name)
    local rule = level_name and smart_blacklists_rule(level_name) or nil
    if rule and rule.all == true then
        return {}
    end
    if is_level_blacklisted_for_faction(level_name, community, section_name) then
        return {}
    end

    local function filter(list)
        local n = list and #list or 0
        if n <= 0 then return list end
        local out = {}
        local out_n = 0
        for i = 1, n do
            local name = list[i]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                out_n = out_n + 1
                out[out_n] = name
            end
        end
        return out
    end

    local cfg_list = nil
    if siski.config and siski.config.get_level_smarts then
        local list = siski.config.get_level_smarts(level_name)
        if list and #list > 0 then
            cfg_list = list
        end
    end
    if cfg_list and siski.config and siski.config.get and siski.config.get("level_smarts_override", false) == true then
        return filter(cfg_list)
    end

    local now = tg()
    if (RUNTIME.smarts_rebuild_tg == 0 or now > (RUNTIME.smarts_rebuild_tg + 60000)) and not RUNTIME.smarts_build.active then
        start_smarts_build()
    end
    local runtime_list = RUNTIME.smarts_by_level[level_name] or {}
    if not cfg_list then
        return filter(runtime_list)
    end
    if not runtime_list or #runtime_list == 0 then
        return filter(cfg_list)
    end
    local merged = {}
    local seen = {}
    for i = 1, #cfg_list do
        local name = cfg_list[i]
        if name and not seen[name] then
            seen[name] = true
            merged[#merged + 1] = name
        end
    end
    for i = 1, #runtime_list do
        local name = runtime_list[i]
        if name and not seen[name] then
            seen[name] = true
            merged[#merged + 1] = name
        end
    end
    return filter(merged)
end

local function pick_random(arr)
    local n = arr and #arr or 0
    if n <= 0 then return nil end
    return arr[math.random(n)]
end

local function pick_random_valid(arr, community, level_name, section_name)
    local n = arr and #arr or 0
    if n <= 0 then return nil end

    local board = get_board()
    if not (board and board.smarts_by_names) then
        for _ = 1, math.min(8, n) do
            local name = arr[math.random(n)]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                return name
            end
        end
        for i = 1, n do
            local name = arr[i]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                return name
            end
        end
        return nil
    end

    local by_name = board.smarts_by_names
    for _ = 1, math.min(8, n) do
        local name = arr[math.random(n)]
        local sm = name and by_name[name] or nil
        if sm and (not smart_is_blacklisted_by_obj(sm, name, community, section_name)) then
            return name
        end
    end

    for i = 1, n do
        local name = arr[i]
        local sm = name and by_name[name] or nil
        if sm and (not smart_is_blacklisted_by_obj(sm, name, community, section_name)) then
            return name
        end
    end

    return nil
end

local function diag_key(stage, squad_id, task)
    local tid = task and task.id or "-"
    return tostring(stage or "-") .. "|" .. tostring(squad_id or "-") .. "|" .. tostring(tid)
end

local function log_task_error(stage, entry, task, err)
    local tostring = tostring
    if not (siski.log and siski.log.error) then return end
    local key = diag_key(stage, entry and entry.squad_id, task)
    if RUNTIME.task_err_once[key] then return end
    RUNTIME.task_err_once[key] = true

    local t = task and task.type or "-"
    local tgt = task and task.target or "-"
    local e = tostring(err or "")
    local tb = (debug and debug.traceback) and debug.traceback("", 2) or ""
    siski.log.error("TASKS", "Task error stage=%s sid=%s type=%s target=%s err=%s %s",
        tostring(stage or "-"),
        tostring(entry and entry.squad_id or "-"),
        tostring(t),
        tostring(tgt),
        tostring(e),
        tostring(tb)
    )
end

local function get_squad_community(entry, se_squad)
    local now = tg()
    if entry and entry.community and now < (tonumber(entry.community_next_tg) or 0) then
        return entry.community
    end
    if not (siski.safe and siski.safe.safe_squad_community) then
        return entry and entry.community or nil
    end
    local community = siski.safe.safe_squad_community(se_squad)
    if community and siski.config and siski.config.get_faction_alias then
        local alias = siski.config.get_faction_alias(community)
        if alias then community = alias end
    end
    if entry then
        if community then
            entry.community = community
            entry.community_verified_tg = now
            entry.community_next_tg = now + COMMUNITY_REFRESH_TTL_MS
        else
            entry.community_next_tg = now + COMMUNITY_RETRY_TTL_MS
        end
        return entry.community
    end
    return community
end

local function get_squad_section(entry, se_squad)
    local section = entry and entry.section or nil
    section = normalize_section_key(section)
    if section then
        if entry then
            entry.section = section
        end
        return section
    end

    if not (siski.safe and siski.safe.safe_section) then
        return nil
    end
    local live = normalize_section_key(siski.safe.safe_section(se_squad))
    if live and entry then
        entry.section = live
    end
    return live
end

local function resolve_entry_level(entry, se_squad)
    if not entry then
        if not se_squad then return nil end
        local gvid = tonumber(se_squad.m_game_vertex_id) or nil
        return gvid and now_level_name_by_gvid(gvid) or nil
    end

    local cached = entry.level
    if not se_squad then
        return cached
    end

    local gvid = tonumber(se_squad.m_game_vertex_id) or nil
    if not gvid then
        return cached
    end

    local cached_gvid = tonumber(entry.level_gvid) or nil
    if cached and cached_gvid and cached_gvid == gvid then
        return cached
    end

    local resolved = now_level_name_by_gvid(gvid)
    if resolved then
        entry.level_gvid = gvid
        entry.level_verified_tg = tg()
        entry.level = resolved
        return resolved
    end
    return cached
end

local function reset_task_hotpath_timers(task)
    if not task then return end
    task.params = task.params or {}
    task.params.watchdog_next_scan_tg = 0
    task.params.target_revalidate_next_tg = 0
end

local function make_task(task_type, target, params, priority)
    return {
        id = tostring(task_type) .. "_" .. tostring(tg()),
        type = task_type,
        target = target,
        params = params or {},
        created_at_tg = tg(),
        priority = priority or 0,
    }
end

local function get_smart_by_name(smart_name)
    if not smart_name then return nil end
    local board = get_board()
    if not (board and board.smarts_by_names) then return nil end
    return board.smarts_by_names[smart_name]
end

RUNTIME.resolve_smart_level_name = function(smart_name, fallback_level)
    if type(smart_name) ~= "string" or smart_name == "" then
        return fallback_level
    end
    local sm = get_smart_by_name(smart_name)
    if sm and sm.m_game_vertex_id then
        return now_level_name_by_gvid(sm.m_game_vertex_id) or fallback_level
    end
    return fallback_level
end

RUNTIME.resolve_entry_anchor_smart = function(entry)
    if type(entry) ~= "table" then
        return nil, nil
    end

    local target = entry.scripted_target
    if type(target) == "string" and target ~= "" then
        local lvl = RUNTIME.resolve_smart_level_name(target, entry.level)
        return target, lvl
    end

    local smart_id = tonumber(entry.smart_id) or nil
    if smart_id then
        local board = get_board()
        local by_name = board and board.smarts_by_names or nil
        if by_name then
            for smart_name, sm in pairs(by_name) do
                if sm and tonumber(sm.id) == smart_id then
                    local lvl = sm.m_game_vertex_id and now_level_name_by_gvid(sm.m_game_vertex_id) or entry.level
                    return smart_name, lvl
                end
            end
        end
    end

    local cur = entry.tasks and entry.tasks.current or nil
    target = cur and cur.target or nil
    if type(target) == "string" and target ~= "" then
        local lvl = RUNTIME.resolve_smart_level_name(target, entry.level)
        return target, lvl
    end

    return nil, nil
end

local function is_task_taken_on_level(task_type, level_name, community, exclude_squad_id)
    if not (task_type and level_name and community) then return false end
    local ex = tonumber(exclude_squad_id)
    for sid, e in iter_logic_squads(LOGIC_MAX_AGE_MS) do
        local id = tonumber(sid)
        if not (ex and id and id == ex) then
            local cur = e and e.tasks and e.tasks.current or nil
            if cur and cur.type == task_type and e.level == level_name and e.community == community then
                return true
            end
        end
    end
    return false
end

local function is_ally_faction(a, b)
    if not (a and b) then return false end
    if a == b then return true end
    if game_relations and game_relations.is_factions_enemies then
        local ok, enemies = pcall(function() return game_relations.is_factions_enemies(a, b) end)
        if ok then
            return enemies == false
        end
    end
    return false
end

local function try_game_graph_distance(sgvid, tgvid)
    sgvid = tonumber(sgvid)
    tgvid = tonumber(tgvid)
    if not (sgvid and tgvid and game_graph) then return nil end
    local ok, d = pcall(function()
        local gg = game_graph()
        if not gg then return nil end
        local res = gg:distance(sgvid, tgvid)
        return res
    end)
    d = ok and tonumber(d) or nil
    if d ~= nil then
        return d
    end
    return nil
end

local function get_beh_ini()
    if RUNTIME.beh_ini ~= nil then
        return RUNTIME.beh_ini or nil
    end
    RUNTIME.beh_ini = false
    if ini_file then
        local paths = {
            "configs\\beh_gulag_jobs.ltx",
            "configs/beh_gulag_jobs.ltx",
            "configs\\misc\\beh_gulag_jobs.ltx",
            "configs/misc/beh_gulag_jobs.ltx",
        }
        for i = 1, #paths do
            local ok, ini = pcall(ini_file, paths[i])
            if ok and ini and ini.section_exist then
                RUNTIME.beh_ini = ini
                break
            end
        end
    end
    if RUNTIME.beh_ini == false and not RUNTIME.beh_ini_warned then
        RUNTIME.beh_ini_warned = true
        if siski.log and siski.log.warn then
            siski.log.warn("TRADE", "beh_gulag_jobs.ltx not found; trader-slot detection disabled")
        end
    end
    return RUNTIME.beh_ini or nil
end

local function smart_has_trader_slot_ltx(smart_name)
    local ini = get_beh_ini()
    if not (ini and ini.section_exist and smart_name) then
        return false
    end
    local ok, res = pcall(function()
        local base = tostring(smart_name)
        return ini:section_exist(base .. "_beh_trade_job_1")
            or ini:section_exist(base .. "_beh_trade_job_2")
            or ini:section_exist(base .. "_beh_trade_job_3")
            or ini:section_exist(base .. "_beh_trade_1")
            or ini:section_exist(base .. "_beh_trade_2")
            or ini:section_exist(base .. "_beh_trade_3")
    end)
    return ok and res == true
end

local function smart_has_trader_slot_runtime(sm)
    if not (sm and sm.stalker_jobs) then
        return false
    end
    local jobs = sm.stalker_jobs
    if type(jobs) ~= "table" then return false end
    for i = 1, #jobs do
        local job = jobs[i]
        local sec = job and job.section or nil
        if type(sec) == "string" then
            if string.find(sec, "_beh_trade_job_", 1, true) ~= nil
                or string.find(sec, "_beh_trade_", 1, true) ~= nil then
                return true
            end
        end
    end
    return false
end

local function smart_has_tech_slot_runtime(sm)
    if not (sm and sm.stalker_jobs) then
        return false
    end
    local jobs = sm.stalker_jobs
    if type(jobs) ~= "table" then return false end
    for i = 1, #jobs do
        local job = jobs[i]
        local sec = job and job.section or nil
        if type(sec) == "string" then
            if string.find(sec, "_beh_tech_job_", 1, true) ~= nil then
                return true
            end
        end
    end
    return false
end

local function smart_has_tech_slot(smart_name, sm)
    if sm and smart_name then
        local cache = RUNTIME.smart_tech_slot_cache
        local c = cache and cache[smart_name]
        local now = tg()
        if c and c.tg and c.ttl_ms and (now < (c.tg + c.ttl_ms)) and c.has ~= nil then
            return c.has == true
        end
        local has = smart_has_tech_slot_runtime(sm) == true
        if not cache then
            RUNTIME.smart_tech_slot_cache = {}
        end
        RUNTIME.smart_tech_slot_cache[smart_name] = { tg = now, ttl_ms = (has and 60000 or 5000), has = has == true }
        return has == true
    end
    return false
end

local function smart_has_trader_slot(smart_name, sm)
    if smart_name and smart_has_trader_slot_ltx(smart_name) then
        return true
    end

    if sm and smart_name then
        local cache = RUNTIME.smart_trade_slot_cache
        local c = cache[smart_name]
        local now = tg()
        if c and c.tg and c.ttl_ms and (now < (c.tg + c.ttl_ms)) and c.has ~= nil then
            return c.has == true
        end
        local has = smart_has_trader_slot_runtime(sm) == true
        cache[smart_name] = { tg = now, ttl_ms = (has and 60000 or 5000), has = has == true }
        return has == true
    end

    return false
end

local function smart_has_real_trader(sm)
    if not (sm and sm.npc_info and IsStalker) then
        return false
    end
    local by_job = type(sm.npc_by_job_section) == "table" and sm.npc_by_job_section or nil
    for _, info in pairs(sm.npc_info) do
        local se = info and info.se_obj or nil
        if se and se.clsid and IsStalker(nil, se:clsid()) then
            local ok_name, npc_name = pcall(function() return se:name() end)
            local lower_name = ok_name and type(npc_name) == "string" and string.lower(npc_name) or nil
            local sec = info and info.job and info.job.section or nil
            local lower_sec = type(sec) == "string" and string.lower(sec) or nil
            local blocked = false
            if lower_name then
                blocked = blocked
                    or string.find(lower_name, "leader", 1, true) ~= nil
                    or string.find(lower_name, "medic", 1, true) ~= nil
                    or string.find(lower_name, "mechanic", 1, true) ~= nil
                    or string.find(lower_name, "guide", 1, true) ~= nil
                    or string.find(lower_name, "_tech", 1, true) ~= nil
            end
            if lower_sec then
                blocked = blocked
                    or string.find(lower_sec, "leader", 1, true) ~= nil
                    or string.find(lower_sec, "medic", 1, true) ~= nil
                    or string.find(lower_sec, "mechanic", 1, true) ~= nil
                    or string.find(lower_sec, "guide", 1, true) ~= nil
                    or string.find(lower_sec, "_tech", 1, true) ~= nil
            end
            if lower_name and (string.find(lower_name, "_trader", 1, true) ~= nil
                or string.find(lower_name, "_barman", 1, true) ~= nil) then
                return true
            end
            if lower_sec and (string.find(lower_sec, "trader", 1, true) ~= nil
                or string.find(lower_sec, "barman", 1, true) ~= nil) then
                return true
            end
            local sid = info and info.se_obj and (tonumber(info.se_obj.id) or (type(info.se_obj.id) == "function" and tonumber(info.se_obj:id()) or nil)) or nil
            if by_job and sid then
                for job_sec, owner_id in pairs(by_job) do
                    if sid and tonumber(owner_id) == sid and type(job_sec) == "string" then
                        local lower_job_sec = string.lower(job_sec)
                        if string.find(lower_job_sec, "trader", 1, true) ~= nil
                            or string.find(lower_job_sec, "barman", 1, true) ~= nil then
                            return true
                        end
                        if string.find(lower_job_sec, "leader", 1, true) ~= nil
                            or string.find(lower_job_sec, "medic", 1, true) ~= nil
                            or string.find(lower_job_sec, "mechanic", 1, true) ~= nil
                            or string.find(lower_job_sec, "guide", 1, true) ~= nil
                            or string.find(lower_job_sec, "_tech", 1, true) ~= nil then
                            blocked = true
                        end
                    end
                end
            end
            local ok_c, c = pcall(function() return se:community() end)
            if ok_c and c == "trader" and not blocked then
                return true
            end
        end
    end
    return false
end

-- OPTIMIZED: Uses smart-local checks first, then a bounded logic-squad scan.
-- Checks: sm:check_alarm(), sm.faction_war_in_progress, sm.npc_info, anchored hostile logic squads.
-- Returns: bool (true = hostile enemy present, false = safe)
local function smart_has_enemy_for_faction(sm, community, smart_name)
    if not (sm and community) then return false end

    local now = tg()
    local cache_ttl = cfg_num("smart_enemy_cache_ttl_ms", 1000, 100)
    local cache_key = tostring(smart_name or tonumber(sm.id) or tonumber(sm.m_game_vertex_id) or tostring(sm)) .. "|" .. tostring(community)
    local smart_level = now_level_name_by_gvid(tonumber(sm.m_game_vertex_id) or 0)
    if not smart_level and level and level.name then
        local ok_lvl, res_lvl = pcall(function() return level.name() end)
        if ok_lvl and type(res_lvl) == "string" then
            smart_level = res_lvl
        end
    end
    local cached = RUNTIME.smart_enemy_fallback_cache[cache_key]
    if type(cached) == "table" and cached.hostile ~= nil then
        local age = now - (tonumber(cached.tg) or 0)
        local ttl = cached.hostile == true and cache_ttl or math.min(cache_ttl, 1000)
        if age <= ttl then
            return cached.hostile == true
        end
    end

    -- Fast check: alarm state on smart
    if sm.check_alarm then
        local ok_alarm, alarm = pcall(function() return sm:check_alarm() end)
        if ok_alarm and alarm == true then
            RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
            record_intel(smart_level, community, tostring(sm.name or sm.id or "-"), 1, "enemy_alarm")
            return true
        end
    end

    -- Fast check: faction war in progress
    local ok_war, war = pcall(function() return sm.faction_war_in_progress end)
    if ok_war and war == true then
        RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
        record_intel(smart_level, community, tostring(sm.name or sm.id or "-"), 1, "enemy_war")
        return true
    end

    if not (game_relations and game_relations.is_factions_enemies and IsStalker) then
        RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = false }
        return false
    end

    if sm.npc_info then
        for _, info in pairs(sm.npc_info) do
            local se = info and info.se_obj or nil
            if se and se.clsid and IsStalker(nil, se:clsid()) then
                local ok_c, c = pcall(function() return se:community() end)
                if ok_c and c and game_relations.is_factions_enemies(community, c) then
                    RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
                    record_intel(smart_level, community, tostring(sm.name or sm.id or "-"), 1, "enemy_npc")
                    return true
                end
            end
        end
    end

    if type(smart_name) == "string" and smart_name ~= "" then
        for _, e in iter_logic_squads(LOGIC_MAX_AGE_MS) do
            local other_comm = normalize_community_key(e and e.community) or (e and e.community) or nil
            if other_comm and other_comm ~= "" then
                local ok_enemy, hostile = pcall(function()
                    return game_relations.is_factions_enemies(community, other_comm)
                end)
                if ok_enemy and hostile == true then
                    local enemy_smart_name, enemy_level = RUNTIME.resolve_entry_anchor_smart(e)
                    if enemy_smart_name == smart_name and (enemy_level == nil or smart_level == nil or enemy_level == smart_level) then
                        RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = true }
                        record_intel(smart_level, community, tostring(smart_name or sm.name or sm.id or "-"), 1, "enemy_logic")
                        return true
                    end
                end
            end
        end
    end

    -- No enemy found
    RUNTIME.smart_enemy_fallback_cache[cache_key] = { tg = now, hostile = false }
    record_intel(smart_level, community, tostring(smart_name or sm.name or sm.id or "-"), -0.25, "enemy_clear")
    return false
end

local function obj_community_name(obj)
    if not obj then return nil end
    if character_community then
        local ok, res = pcall(character_community, obj)
        if ok and res and res ~= "" then return res end
    end
    if obj.community then
        local ok, res = pcall(function() return obj:community() end)
        if ok and res and res ~= "" then return res end
    end
    if obj.character_community then
        local ok, res = pcall(function() return obj:character_community() end)
        if ok and res and res ~= "" then return res end
    end
    return nil
end

-- OPTIMIZED: Uses sm.npc_info instead of level.iterate_nearest
-- Checks only NPCs registered on the smart, not all objects in radius
-- Returns: bool (true = hostile enemy present, false = safe)
local function has_enemy_stalker_near_smart(smart_name, community, radius_m, cur_level_name)
    if not (smart_name and community) then
        return false
    end

    local sm = get_smart_by_name(smart_name)
    if not sm then
        return false
    end

    -- Delegate to unified enemy check
    return smart_has_enemy_for_faction(sm, community, smart_name) == true
end

local function loaded_level_name()
    if not (level and level.name) then return nil end
    local ok, res = pcall(function() return level.name() end)
    return ok and res or nil
end

local function is_roam_smart_allowed(smart_name, community)
    if not (smart_name and community) then return true end
    return has_enemy_stalker_near_smart(smart_name, community, 50, loaded_level_name()) == false
end

local function pick_random_valid_safe(arr, community, allowed_by_name, level_name, section_name)
    local n = arr and #arr or 0
    if n <= 0 then return nil end

    local board = get_board()
    if not (board and board.smarts_by_names) then
        for _ = 1, math.min(8, n) do
            local name = arr[math.random(n)]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                return name
            end
        end
        for i = 1, n do
            local name = arr[i]
            if name and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                return name
            end
        end
        return nil
    end

    local by_name = board.smarts_by_names
    local allowed_cache = allowed_by_name or {}
    local function is_allowed(name)
        if not name then return false end
        if allowed_cache[name] == nil then
            allowed_cache[name] = is_roam_smart_allowed(name, community) == true
        end
        return allowed_cache[name] == true
    end
    for _ = 1, math.min(8, n) do
        local name = arr[math.random(n)]
        local sm = name and by_name[name] or nil
        if sm and (not smart_is_blacklisted_by_obj(sm, name, community, section_name)) and is_allowed(name) then
            return name
        end
    end

    for i = 1, n do
        local name = arr[i]
        local sm = name and by_name[name] or nil
        if sm and (not smart_is_blacklisted_by_obj(sm, name, community, section_name)) and is_allowed(name) then
            return name
        end
    end

    return nil
end

local function shuffle_in_place(arr)
    if type(arr) ~= "table" then return end
    for i = #arr, 2, -1 do
        local j = math.random(i)
        arr[i], arr[j] = arr[j], arr[i]
    end
end

local function smart_has_campfires(smart_name)
    if not (smart_name and db and db.campfire_table_by_smart_names) then
        return false
    end
    local t = db.campfire_table_by_smart_names[smart_name]
    if type(t) ~= "table" then return false end
    for _ in pairs(t) do
        return true
    end
    return false
end

local function smart_has_kamp_slot_ltx(smart_name)
    local ini = get_beh_ini()
    if not (ini and ini.section_exist and smart_name) then
        return false
    end
    local ok, res = pcall(function()
        local base = tostring(smart_name)
        return ini:section_exist(base .. "_beh_kamp_1")
            or ini:section_exist(base .. "_beh_kamp_2")
            or ini:section_exist(base .. "_beh_kamp_3")
            or ini:section_exist(base .. "_beh_kamp_4")
    end)
    return ok and res == true
end

local function smart_has_kamp_slot_runtime(sm)
    if not (sm and sm.stalker_jobs) then
        return false
    end
    local jobs = sm.stalker_jobs
    if type(jobs) ~= "table" then return false end
    for i = 1, #jobs do
        local job = jobs[i]
        local sec = job and job.section or nil
        if type(sec) == "string" then
            if string.find(sec, "_beh_kamp_job_", 1, true) ~= nil then
                return true
            end
            if string.find(sec, "_beh_kamp_", 1, true) ~= nil then
                return true
            end
        end
    end
    return false
end

local function smart_has_kamp_slot(smart_name, sm)
    if smart_name and smart_has_kamp_slot_ltx(smart_name) then
        return true
    end
    if sm and smart_name then
        local cache = RUNTIME.smart_kamp_slot_cache
        if cache then
            local c = cache[smart_name]
            local now = tg()
            if c and c.tg and c.ttl_ms and (now < (c.tg + c.ttl_ms)) and c.has ~= nil then
                return c.has == true
            end
            local has = smart_has_kamp_slot_runtime(sm) == true
            cache[smart_name] = { tg = now, ttl_ms = (has and 60000 or 5000), has = has == true }
            return has == true
        end
    end
    if smart_name and smart_has_campfires(smart_name) then
        return true
    end
    return false
end

local function smart_is_safe_for_faction(smart_name, community, cur_level)
    if not (smart_name and community) then
        return true
    end
    if not (game_relations and game_relations.is_factions_enemies and IsStalker) then
        return true
    end
    local ok, hostile = pcall(has_enemy_stalker_near_smart, smart_name, community, 50, cur_level)
    if ok then
        return hostile ~= true
    end
    return true
end

local function rebuild_capability_index()
    local by_level = RUNTIME.smarts_by_level or {}
    local board = get_board()
    local by_name = board and board.smarts_by_names or nil
    local out = {}

    for lvl, smarts in pairs(by_level) do
        local idx = {
            trade_slot = {},
            trader = {},
            tech_slot = {},
            anomaly = {},
            kamp = {},
            base = {},
            safe = {},
        }
        local anomaly_set = {}
        local base_set = {}
        if siski.config and siski.config.get_anomaly_smarts then
            local a = siski.config.get_anomaly_smarts(lvl) or {}
            for i = 1, #a do anomaly_set[a[i]] = true end
        end
        if siski.config and siski.config.get_level_bases then
            local b = siski.config.get_level_bases(lvl) or {}
            for i = 1, #b do base_set[b[i]] = true end
        end

        for i = 1, (smarts and #smarts or 0) do
            local name = smarts[i]
            local sm = by_name and name and by_name[name] or nil
            if name and sm then
                idx.safe[#idx.safe + 1] = name
                if smart_has_trader_slot(name, sm) then
                    idx.trade_slot[#idx.trade_slot + 1] = name
                end
                if smart_has_real_trader(sm) then
                    idx.trader[#idx.trader + 1] = name
                end
                if smart_has_tech_slot(name, sm) then
                    idx.tech_slot[#idx.tech_slot + 1] = name
                end
                if smart_has_kamp_slot(name, sm) then
                    idx.kamp[#idx.kamp + 1] = name
                end
                if anomaly_set[name] == true then
                    idx.anomaly[#idx.anomaly + 1] = name
                end
                if base_set[name] == true then
                    idx.base[#idx.base + 1] = name
                end
            end
        end
        out[lvl] = idx
    end

    RUNTIME.cap_index_by_level = out
    RUNTIME.cap_index_rebuild_tg = tg()
end

local function get_cap_bucket(level_name, bucket, community)
    if type(level_name) ~= "string" or level_name == "" then
        return nil
    end
    if type(RUNTIME.cap_index_by_level) ~= "table" or next(RUNTIME.cap_index_by_level) == nil then
        rebuild_capability_index()
    end
    local idx = RUNTIME.cap_index_by_level[level_name]
    if type(idx) ~= "table" then
        return nil
    end
    local arr = idx[bucket]
    if type(arr) ~= "table" then
        return nil
    end
    if bucket ~= "safe" or not community then
        return arr
    end
    local filtered = {}
    for i = 1, #arr do
        local name = arr[i]
        if smart_is_safe_for_faction(name, community, level_name) then
            filtered[#filtered + 1] = name
        end
    end
    return filtered
end

local function pick_base_camping_target_smart(level_name, community, section_name)
    if not level_name then return nil end
    local smarts = get_smarts_for_level(level_name, community, section_name)
    local n = smarts and #smarts or 0
    if n <= 0 then return nil end

    local cap_base = get_cap_bucket(level_name, "base", community)
    if cap_base and #cap_base > 0 then
        local picked = pick_random_valid_safe(cap_base, community, nil, level_name, section_name)
        if picked then
            return picked
        end
    end

    local cap_kamp = get_cap_bucket(level_name, "kamp", community)
    if cap_kamp and #cap_kamp > 0 then
        local picked = pick_random_valid_safe(cap_kamp, community, nil, level_name, section_name)
        if picked then
            return picked
        end
    end

    local board = get_board()
    local by_name = board and board.smarts_by_names or nil

    local cfg = siski.config and siski.config.get_level_bases and siski.config.get_level_bases(level_name) or {}
    local cfg_n = cfg and #cfg or 0
    if cfg_n > 0 then
        local bases = {}
        local bn = 0
        for i = 1, cfg_n do
            local name = cfg[i]
            local sm = by_name and name and by_name[name] or nil
            if name and sm and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
                local safe = smart_is_safe_for_faction(name, community, level_name)
                if safe then
                    bn = bn + 1
                    bases[bn] = name
                end
            end
        end
        local picked = pick_random_valid(bases, community, level_name, section_name)
        if picked then
            return picked
        end
    end

    local kamp = {}
    local kamp_n = 0
    local safe_any = {}
    local safe_n = 0

    for i = 1, n do
        local name = smarts[i]
        local sm = by_name and name and by_name[name] or nil
        if name and sm and (not smart_is_blacklisted_for_level(level_name, name, community, section_name)) then
            local safe = smart_is_safe_for_faction(name, community, level_name)
            if safe then
                safe_n = safe_n + 1
                safe_any[safe_n] = name

                if smart_has_kamp_slot(name, sm) then
                    kamp_n = kamp_n + 1
                    kamp[kamp_n] = name
                end
            end
        end
    end

    return pick_random_valid(kamp, community, level_name, section_name)
        or pick_random_valid(safe_any, community, level_name, section_name)
        or pick_random_valid(smarts, community, level_name, section_name)
end

local function ensure_patrol_order(task, level_name, community, section_name)
    if not (task and task.params and level_name) then return nil end
    local p = task.params
    local order = p.order
    if type(order) == "table" and #order > 0 then
        return order
    end

    local src = get_smarts_for_level(level_name, community, section_name)
    local list = {}
    local board = get_board()
    local by_name = board and board.smarts_by_names or nil
    for i = 1, (src and #src or 0) do
        local name = src[i]
        if name and ((not by_name) or by_name[name]) then
            local allowed = true
            if community then
                allowed = is_roam_smart_allowed(name, community) == true
            end
            if allowed then
                list[#list + 1] = name
            end
        end
    end
    if #list > 0 then
        shuffle_in_place(list)
        p.order = list
        p.visited = {}
        p.visited_count = 0
        p.idx = 1
        return list
    end
    p.order = {}
    p.visited = {}
    p.visited_count = 0
    p.idx = 1
    return {}
end

local function pick_next_patrol_target(task, level_name, community, section_name)
    if not (task and task.params and level_name) then return nil end
    local p = task.params
    local order = ensure_patrol_order(task, level_name, community, section_name)
    local n = order and #order or 0
    if n <= 0 then return nil end

    p.visited = p.visited or {}
    p.visited_count = tonumber(p.visited_count) or 0
    p.idx = tonumber(p.idx) or 1

    if p.visited_count >= n then
        p.order = nil
        return pick_next_patrol_target(task, level_name, community, section_name)
    end

    local visited = p.visited
    local start = p.idx
    if start < 1 or start > n then start = 1 end

    for step = 0, n - 1 do
        local i = start + step
        if i > n then i = i - n end
        local name = order[i]
        if name and not visited[name] then
            p.idx = i + 1
            if p.idx > n then p.idx = 1 end
            return name
        end
    end

    p.order = nil
    return pick_next_patrol_target(task, level_name, community, section_name)
end

local function get_arrive_dist_cap_m()
    if not (siski.config and siski.config.get) then return 5 end
    local v = siski.config.get("task_arrive_dist_cap_m", 5)
    v = tonumber(v)
    if not v then return 5 end
    if v < 0 then v = 0 end
    return v
end

local function vanilla_am_i_reached(se_squad, sm)
    if not (se_squad and sm) then return false end

    local ok_sgvid, sgvid = pcall(function() return se_squad.m_game_vertex_id end)
    local ok_tgvid, tgvid = pcall(function() return sm.m_game_vertex_id end)
    sgvid = ok_sgvid and sgvid or nil
    tgvid = ok_tgvid and tgvid or nil
    if sgvid and tgvid and sgvid == tgvid then
        return true
    end

    if sgvid and tgvid and game_graph then
        local ok_lvl, same_level = pcall(function()
            return game_graph():vertex(sgvid):level_id() == game_graph():vertex(tgvid):level_id()
        end)
        if ok_lvl and same_level == false then
            return false
        end
    end

    local cap_m = get_arrive_dist_cap_m()
    if cap_m <= 0 then
        return false
    end

    local pos_s = siski.safe and siski.safe.safe_position and siski.safe.safe_position(se_squad) or nil
    local pos_t = sm.position
    if not (pos_s and pos_t and pos_s.distance_to_sqr) then
        return false
    end

    local ok_arr, arrive_dist = pcall(function() return sm.arrive_dist end)
    arrive_dist = ok_arr and tonumber(arrive_dist) or nil
    if not arrive_dist then
        arrive_dist = cap_m
    else
        arrive_dist = math.min(arrive_dist, cap_m)
    end

    local ok_alw, alw = pcall(function() return se_squad.always_arrived end)
    if ok_alw and alw == true then
        return true
    end

    local ok_d2, d2 = pcall(function() return pos_s:distance_to_sqr(pos_t) end)
    d2 = ok_d2 and tonumber(d2) or nil
    if not d2 then return false end
    return d2 <= (arrive_dist * arrive_dist)
end

local function is_squad_arrived_to_smart(se_squad, smart_name)
    local sm = get_smart_by_name(smart_name)
    if not (se_squad and sm) then return false end

    local ok_ca, ca = pcall(function() return se_squad.current_action end)
    local ok_at, at = pcall(function() return se_squad.assigned_target_id end)
    local ok_ct, ct = pcall(function() return se_squad.current_target_id end)
    local ok_ss, ss = pcall(function() return se_squad.smart_id end)
    local ok_id, sid = pcall(function() return sm.id end)
    ca = ok_ca and tonumber(ca) or nil
    at = ok_at and tonumber(at) or nil
    ct = ok_ct and tonumber(ct) or nil
    ss = ok_ss and tonumber(ss) or nil
    sid = ok_id and tonumber(sid) or nil

    local function log_state(arrived, source)
        if not (siski.log and siski.log.debug) then return end
        local sqid = tonumber(se_squad.id)
        if not sqid then return end
        local now = tg()
        local c = RUNTIME.target_arrived_state_cache[sqid]
        if c and c.arrived == arrived and now < (tonumber(c.next_tg) or 0) then
            return
        end
        RUNTIME.target_arrived_state_cache[sqid] = { arrived = arrived, next_tg = now + 5000 }
        siski.log.debug("TASKS", "target_arrived_state sid=%s target=%s arrived=%s source=%s ca=%s at=%s ct=%s smart_id=%s",
            tostring(sqid),
            tostring(smart_name or "-"),
            tostring(arrived == true),
            tostring(source or "-"),
            tostring(ca or "-"),
            tostring(at or "-"),
            tostring(ct or "-"),
            tostring(ss or "-")
        )
    end

    if ca == 1 and sid and ((ct and ct == sid) or (ss and ss == sid)) then
        log_state(true, "fast_current")
        return true
    end

    if sm.am_i_reached then
        local ok, res = pcall(function() return sm:am_i_reached(se_squad) end)
        if ok and res then
            log_state(true, "smart_am_i_reached")
            return true
        end
    end

    local arrived = vanilla_am_i_reached(se_squad, sm)
    log_state(arrived, "vanilla_fallback")
    return arrived
end

local TARGET_TASK_TYPES = {
    EXPLORE = true,
    ARTEFACT = true,
    BASE_CAMPING = true,
    PATROL = true,
    POPULATE = true,
    TRADE = true,
    NIGHT_REST = true,
    FACTION_TASK = true,
}

local ROAM_LIKE_TYPES = {
    REST_1H = true,
    EXPLORE = true,
    ARTEFACT = true,
    BASE_CAMPING = true,
    PATROL = true,
    POPULATE = true,
    NIGHT_REST = true,
}

local function is_target_task(task)
    if not (task and TARGET_TASK_TYPES[task.type]) then return false end
    return type(task.target) == "string" and task.target ~= ""
end

local function get_target_sync_enabled()
    if not (siski.config and siski.config.get) then return true end
    return siski.config.get("target_sync_enabled", true) ~= false
end

local function get_target_unstuck_enabled()
    if not (siski.config and siski.config.get) then return true end
    return siski.config.get("target_unstuck_enabled", true) ~= false
end

local function get_online_intent_enforce_enabled()
    if not (siski.config and siski.config.get) then return true end
    return siski.config.get("online_intent_enforce_enabled", true) ~= false
end

local function get_target_num_cfg(key, default, min_v)
    return cfg_num(key, default, min_v)
end

local function resolve_target_smart_id(smart_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return nil, nil
    end
    local board = get_board()
    local sm = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    local sid = sm and tonumber(sm.id) or nil
    return sid, sm
end

local function set_scripted_target(se_squad, smart_name, params, opts)
    if not se_squad then return false end
    se_squad.scripted_target = smart_name

    if not get_target_sync_enabled() then
        return true
    end
    if type(smart_name) ~= "string" or smart_name == "" then
        return true
    end

    params = type(params) == "table" and params or nil
    local now = tg()
    local sid = nil
    sid = resolve_target_smart_id(smart_name)
    local force_sync = opts and opts.force_sync == true

    local changed = false
    if params then
        changed = params.target_sync_name ~= smart_name
        params.target_sync_name = smart_name
        if sid then
            params.target_sync_smart_id = sid
        else
            params.target_sync_smart_id = nil
        end
        if changed then
            params.target_sync_started_tg = now
            params.target_last_progress_tg = now
            params.target_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
            params.target_last_assigned_id = tonumber(se_squad.assigned_target_id) or nil
            params.target_last_current_id = tonumber(se_squad.current_target_id) or nil
            params.target_last_action = tonumber(se_squad.current_action) or nil
        end
    end

    if changed or force_sync then
        se_squad.current_action = 0
        se_squad.current_target_id = nil
        if sid then
            se_squad.assigned_target_id = sid
        end
        se_squad.stay_time = nil
        se_squad.arrive_time = nil

        if params then
            params.target_last_progress_tg = now
            params.target_last_gvid = tonumber(se_squad.m_game_vertex_id) or nil
            params.target_last_assigned_id = tonumber(se_squad.assigned_target_id) or nil
            params.target_last_current_id = tonumber(se_squad.current_target_id) or nil
            params.target_last_action = tonumber(se_squad.current_action) or nil
        end

        if siski.log and siski.log.info then
            siski.log.info("TASKS", "target_sync sid=%s target=%s smart_id=%s reason=%s changed=%s",
                tostring(se_squad.id or "-"),
                tostring(smart_name),
                tostring(sid or "-"),
                tostring(opts and opts.reason or "set"),
                tostring(changed)
            )
        end
    end

    return true
end

local function is_online_squad(se_squad)
    if not se_squad then return false end
    local ok, online = pcall(function() return se_squad.online end)
    return ok and online == true
end

local function sync_rest_always_arrived(se_squad, task_or_flag)
    if not se_squad then return end

    local should_hold = false
    if type(task_or_flag) == "table" then
        should_hold = task_or_flag.type == "REST_1H"
    else
        should_hold = task_or_flag == true
    end
    if should_hold == true and is_squad_monster and is_squad_monster[se_squad.player_id] == true then
        should_hold = false
    end

    local ok_cur, current = pcall(function() return se_squad.always_arrived end)
    if ok_cur and current == should_hold then
        return
    end

    pcall(function()
        se_squad.always_arrived = should_hold
    end)
end

local function smart_distance_to_target_m(se_squad, smart_name)
    if not (se_squad and type(smart_name) == "string" and smart_name ~= "") then return nil end
    local sm = get_smart_by_name(smart_name)
    if not sm then return nil end
    local p1 = siski.safe and siski.safe.safe_position and siski.safe.safe_position(se_squad) or nil
    local p2 = sm.position
    if not (p1 and p2 and p1.distance_to) then return nil end
    local ok, d = pcall(function() return p1:distance_to(p2) end)
    d = ok and tonumber(d) or nil
    return d
end

local function pick_alt_target_for_task(task, cur_level, community, section_name, prefer_current_level)
    if not (task and type(cur_level) == "string" and cur_level ~= "") then return nil end
    local current = task.target
    local target_level = task.params and task.params.target_level or cur_level

    local function pick_from_list(list, list_level)
        if not list or #list <= 0 then return nil end

        for _ = 1, math.min(12, #list) do
            local c = community and pick_random_valid_safe(list, community, nil, list_level, section_name) or pick_random_valid(list, community, list_level, section_name)
            if c and c ~= current then
                local sm = get_smart_by_name(c)
                if sm and (not smart_is_blacklisted_by_obj(sm, c, community, section_name)) and ((not community) or is_roam_smart_allowed(c, community)) then
                    return c
                end
            end
        end

        for i = 1, #list do
            local c = list[i]
            if c and c ~= current then
                local sm = get_smart_by_name(c)
                if sm and (not smart_is_blacklisted_by_obj(sm, c, community, section_name)) and ((not community) or is_roam_smart_allowed(c, community)) then
                    return c
                end
            end
        end
        return nil
    end

    if prefer_current_level == true then
        local c1 = pick_from_list(get_smarts_for_level(cur_level, community, section_name), cur_level)
        if c1 then return c1 end
        local c2 = pick_from_list(get_smarts_for_level(target_level, community, section_name), target_level)
        if c2 then return c2 end
    else
        local c1 = pick_from_list(get_smarts_for_level(target_level, community, section_name), target_level)
        if c1 then return c1 end
        local c2 = pick_from_list(get_smarts_for_level(cur_level, community, section_name), cur_level)
        if c2 then return c2 end
    end

    return nil
end

local function enforce_online_task_intent(se_squad, entry, task)
    if not get_online_intent_enforce_enabled() then return end
    if not (se_squad and entry and is_target_task(task)) then return end
    if not is_online_squad(se_squad) then return end

    local sid = resolve_target_smart_id(task.target)
    local stgt = se_squad.scripted_target
    local at = tonumber(se_squad.assigned_target_id) or nil
    local ca = tonumber(se_squad.current_action) or nil
    local mismatch = false

    if stgt ~= task.target then mismatch = true end
    if sid and at and at ~= sid then mismatch = true end
    if ca == nil then mismatch = true end

    if mismatch then
        set_scripted_target(se_squad, task.target, task.params, { force_sync = true, reason = "online_intent_enforce" })
        if siski.log and siski.log.warn then
            siski.log.warn("TASKS", "ONLINE_WANDER_DETECTED sid=%s task=%s target=%s cur_level=%s gvid=%s",
                tostring(entry and entry.squad_id or "-"),
                tostring(task and task.type or "-"),
                tostring(task and task.target or "-"),
                tostring(entry and entry.level or "-"),
                tostring(se_squad and se_squad.m_game_vertex_id or "-")
            )
        end
    end
end

local function run_target_watchdog(se_squad, entry, task)
    if not (se_squad and is_target_task(task)) then return end
    if not get_target_unstuck_enabled() then return end
    if not get_online_intent_enforce_enabled() then return end
    if not is_online_squad(se_squad) then return end

    local p = task.params or {}
    task.params = p
    if entry and p.online_force_rebuild == true then
        return { force_rebuild = true }
    end

    local now = tg()
    local grace_ms = get_target_num_cfg("target_retarget_grace_ms", 5000, 0)
    local soft_ms = get_target_num_cfg("online_move_soft_timeout_ms", 45000, 1000)
    local hard_ms = get_target_num_cfg("online_move_hard_timeout_ms", 120000, soft_ms)
    if hard_ms < soft_ms then hard_ms = soft_ms end
    local cooldown_ms = get_target_num_cfg("online_move_cooldown_ms", 10000, 0)
    local rush_window_ms = get_target_num_cfg("online_rush_window_ms", 15000, 0)
    local dist_eps = get_target_num_cfg("online_dist_progress_eps_m", 5, 0)
    local max_retargets = get_target_num_cfg("online_retarget_max_per_task", 2, 0)
    local medium_ms = soft_ms + math.max(5000, math.floor((hard_ms - soft_ms) * 0.5))
    if medium_ms >= hard_ms then medium_ms = hard_ms - 1 end

    local sync_started = tonumber(p.target_sync_started_tg) or now
    if now < (sync_started + grace_ms) then
        return
    end

    if p.online_rush_until_tg and now >= tonumber(p.online_rush_until_tg) then
        se_squad.rush_to_target = nil
        p.online_rush_until_tg = nil
    end

    local gvid = tonumber(se_squad.m_game_vertex_id) or nil
    local at = tonumber(se_squad.assigned_target_id) or nil
    local ct = tonumber(se_squad.current_target_id) or nil
    local ca = tonumber(se_squad.current_action) or nil
    local dist = smart_distance_to_target_m(se_squad, task.target)

    local last_gvid = tonumber(p.online_last_gvid) or tonumber(p.target_last_gvid) or nil
    local last_at = tonumber(p.target_last_assigned_id) or nil
    local last_ct = tonumber(p.target_last_current_id) or nil
    local last_ca = tonumber(p.target_last_action) or nil
    local last_dist = tonumber(p.online_last_dist_to_target_m) or nil

    if p.online_last_progress_tg == nil then
        p.online_last_progress_tg = now
        p.online_last_gvid = gvid
        p.online_last_dist_to_target_m = dist
        p.target_last_assigned_id = at
        p.target_last_current_id = ct
        p.target_last_action = ca
        p.online_stall_started_tg = nil
        return
    end

    local dist_progress = false
    if dist and last_dist then
        dist_progress = (last_dist - dist) >= dist_eps
    end
    local progressed = (gvid ~= last_gvid) or dist_progress or (at ~= last_at) or (ct ~= last_ct) or (ca ~= last_ca)
    if progressed then
        p.online_last_progress_tg = now
        p.online_last_gvid = gvid
        p.online_last_dist_to_target_m = dist
        p.target_last_assigned_id = at
        p.target_last_current_id = ct
        p.target_last_action = ca
        p.online_nudge_stage = 0
        p.online_stall_started_tg = nil
        p.online_force_rebuild = nil
        if siski.log and siski.log.info then
            siski.log.info("TASKS", "target_progress sid=%s target=%s gvid=%s dist=%s at=%s ct=%s ca=%s",
                tostring(entry and entry.squad_id or "-"),
                tostring(task.target or "-"),
                tostring(gvid or "-"),
                tostring(dist or "-"),
                tostring(at or "-"),
                tostring(ct or "-"),
                tostring(ca or "-")
            )
        end
        return
    end

    if p.online_stall_started_tg == nil then
        p.online_stall_started_tg = now
    end
    local elapsed = now - (tonumber(p.online_stall_started_tg) or now)
    local next_allowed = tonumber(p.online_nudge_next_tg) or tonumber(p.target_unstuck_next_tg) or 0
    if now < next_allowed then
        return
    end

    local cur_level = entry and entry.level or now_level_name_by_gvid(se_squad.m_game_vertex_id)
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)
    local task_name = tostring(task and task.type or "-")
    local target_name = tostring(task and task.target or "-")

    local route_deadlock = (dist == nil and gvid == last_gvid)
    if route_deadlock and elapsed >= soft_ms and ((tonumber(p.online_route_deadlock_last_tg) or 0) + 15000 <= now) then
        p.online_route_deadlock_last_tg = now
        if siski.log and siski.log.warn then
            siski.log.warn("TASKS", "ONLINE_ROUTE_DEADLOCK sid=%s task=%s target=%s cur_level=%s target_level=%s gvid=%s dist=%s stage=%s elapsed_ms=%s",
                tostring(entry and entry.squad_id or "-"),
                task_name,
                target_name,
                tostring(cur_level or "-"),
                tostring(task.params and task.params.target_level or cur_level or "-"),
                tostring(gvid or "-"),
                tostring(dist or "-"),
                tostring(p.online_nudge_stage or 0),
                tostring(elapsed)
            )
        end
    end

    if elapsed >= soft_ms and (tonumber(p.online_wander_last_tg) or 0) + 15000 <= now then
        p.online_wander_last_tg = now
        if siski.log and siski.log.warn then
            siski.log.warn("TASKS", "ONLINE_WANDER_DETECTED sid=%s task=%s target=%s cur_level=%s target_level=%s gvid=%s dist=%s stage=%s elapsed_ms=%s",
                tostring(entry and entry.squad_id or "-"),
                task_name,
                target_name,
                tostring(cur_level or "-"),
                tostring(task.params and task.params.target_level or cur_level or "-"),
                tostring(gvid or "-"),
                tostring(dist or "-"),
                tostring(p.online_nudge_stage or 0),
                tostring(elapsed)
            )
        end
    end

    if elapsed >= hard_ms then
        -- Hard steering reset for long online deadlock.
        se_squad.scripted_target = nil
        se_squad.assigned_target_id = nil
        se_squad.current_target_id = nil
        se_squad.current_action = 0
        se_squad.stay_time = nil
        se_squad.arrive_time = nil
        if SIMBOARD and SIMBOARD.assign_squad_to_smart then
            pcall(function() SIMBOARD:assign_squad_to_smart(se_squad, nil) end)
        end

        local ret = tonumber(p.online_retarget_count) or 0
        if ret < max_retargets then
            local new_target = pick_alt_target_for_task(task, cur_level, community, section_name, true)
            if not new_target then
                new_target = pick_alt_target_for_task(task, cur_level, community, section_name, false)
            end
            if new_target and new_target ~= task.target then
                task.target = new_target
                reset_task_hotpath_timers(task)
                p.online_retarget_count = ret + 1
                p.online_nudge_stage = 3
                p.online_nudge_next_tg = now + cooldown_ms
                p.online_stall_started_tg = nil
                p.online_last_progress_tg = now
                p.online_last_gvid = gvid
                p.online_last_dist_to_target_m = nil
                p._applied = nil
                set_scripted_target(se_squad, task.target, p, { force_sync = true, reason = "online_hard_reroll" })
                if siski.log and siski.log.warn then
                    siski.log.warn("TASKS", "ONLINE_STALL_HARD_RETARGET sid=%s task=%s target=%s cur_level=%s target_level=%s gvid=%s dist=%s stage=%s elapsed_ms=%s retarget_count=%s",
                        tostring(entry and entry.squad_id or "-"),
                        task_name,
                        tostring(task.target or "-"),
                        tostring(cur_level or "-"),
                        tostring(task.params and task.params.target_level or cur_level or "-"),
                        tostring(gvid or "-"),
                        tostring(dist or "-"),
                        tostring(p.online_nudge_stage or "-"),
                        tostring(elapsed),
                        tostring(p.online_retarget_count or 0)
                    )
                end
                return
            end
        end

        p.online_nudge_stage = 4
        p.online_nudge_next_tg = now + cooldown_ms
        p.online_stall_started_tg = nil
        p.online_force_rebuild = true
        p._applied = nil
        if siski.log and siski.log.warn then
            siski.log.warn("TASKS", "ONLINE_STALL_FALLBACK sid=%s task=%s target=%s cur_level=%s target_level=%s gvid=%s dist=%s stage=%s elapsed_ms=%s",
                tostring(entry and entry.squad_id or "-"),
                task_name,
                target_name,
                tostring(cur_level or "-"),
                tostring(task.params and task.params.target_level or cur_level or "-"),
                tostring(gvid or "-"),
                tostring(dist or "-"),
                tostring(p.online_nudge_stage or "-"),
                tostring(elapsed)
            )
        end
        return { force_rebuild = true }
    end

    if elapsed >= medium_ms and (tonumber(p.online_nudge_stage) or 0) < 2 then
        p.online_nudge_stage = 2
        p.online_nudge_next_tg = now + cooldown_ms
        se_squad.rush_to_target = true
        p.online_rush_until_tg = now + rush_window_ms
        set_scripted_target(se_squad, task.target, p, { force_sync = true, reason = "online_medium_rush" })
        if siski.log and siski.log.warn then
            siski.log.warn("TASKS", "ONLINE_STALL_MEDIUM_RUSH sid=%s task=%s target=%s cur_level=%s target_level=%s gvid=%s dist=%s stage=%s elapsed_ms=%s",
                tostring(entry and entry.squad_id or "-"),
                task_name,
                target_name,
                tostring(cur_level or "-"),
                tostring(task.params and task.params.target_level or cur_level or "-"),
                tostring(gvid or "-"),
                tostring(dist or "-"),
                tostring(p.online_nudge_stage or "-"),
                tostring(elapsed)
            )
        end
        return
    end

    if elapsed >= soft_ms and (tonumber(p.online_nudge_stage) or 0) < 1 then
        p.online_nudge_stage = 1
        p.online_nudge_next_tg = now + cooldown_ms
        set_scripted_target(se_squad, task.target, p, { force_sync = true, reason = "online_soft" })
        if siski.log and siski.log.warn then
            siski.log.warn("TASKS", "ONLINE_STALL_SOFT sid=%s task=%s target=%s cur_level=%s target_level=%s gvid=%s dist=%s stage=%s elapsed_ms=%s",
                tostring(entry and entry.squad_id or "-"),
                task_name,
                target_name,
                tostring(cur_level or "-"),
                tostring(task.params and task.params.target_level or cur_level or "-"),
                tostring(gvid or "-"),
                tostring(dist or "-"),
                tostring(p.online_nudge_stage or "-"),
                tostring(elapsed)
            )
        end
        return
    end
end

local function should_run_watchdog(task, now, entry)
    if not task then return false end
    task.params = task.params or {}
    local dirty = false
    if entry then
        dirty = consume_entry_dirty(entry, "task") or consume_entry_dirty(entry, "smart") or consume_entry_dirty(entry, "identity")
    end
    local next_tg = tonumber(task.params.watchdog_next_scan_tg) or 0
    if (not dirty) and now < next_tg then
        return false
    end
    if not adaptive_should_run("tasks.watchdog", now, WATCHDOG_SCAN_INTERVAL_MS, ADAPTIVE_FORCE_WATCHDOG_MS) then
        adaptive_note_defer("tasks.watchdog", now, "lane_pressure")
        return false
    end
    local interval = WATCHDOG_SCAN_INTERVAL_MS
    if dirty then
        interval = math.min(interval, DIRTY_REVALIDATE_TTL_MS)
    end
    task.params.watchdog_next_scan_tg = now + interval
    return true
end

local function should_revalidate_target(task, now, force, entry)
    if not task then return false end
    task.params = task.params or {}
    local dirty = false
    if entry then
        dirty = consume_entry_dirty(entry, "task") or consume_entry_dirty(entry, "level") or consume_entry_dirty(entry, "community") or consume_entry_dirty(entry, "identity")
    end
    if force == true then
        task.params.target_revalidate_next_tg = now + math.min(TARGET_REVALIDATE_INTERVAL_MS, DIRTY_REVALIDATE_TTL_MS)
        return true
    end
    if dirty then
        task.params.target_revalidate_next_tg = now + DIRTY_REVALIDATE_TTL_MS
        return true
    end
    local next_tg = tonumber(task.params.target_revalidate_next_tg) or 0
    if now < next_tg then
        return false
    end
    if not adaptive_should_run("tasks.revalidate", now, TARGET_REVALIDATE_INTERVAL_MS, ADAPTIVE_FORCE_REVALIDATE_MS) then
        adaptive_note_defer("tasks.revalidate", now, "lane_pressure")
        return false
    end
    task.params.target_revalidate_next_tg = now + TARGET_REVALIDATE_INTERVAL_MS
    return true
end

local function is_task_target_valid(task, community, section_name)
    if not (task and task.target and type(task.target) == "string") then
        return true
    end
    local sm = get_smart_by_name(task.target)
    if sm and smart_is_blacklisted_by_obj(sm, task.target, community, section_name) then
        return false
    end
    local target_level = task.params and task.params.target_level or nil
    if (not sm) and smart_is_blacklisted_for_level(target_level, task.target, community, section_name) then
        return false
    end
    return sm ~= nil
end

local function build_rest_task(se_squad)
    local tonumber = tonumber
    local rest_hours = 1
    if siski.config and siski.config.get then
        local v = siski.config.get("rest_duration_game_hours", rest_hours)
        if tonumber(v) then rest_hours = tonumber(v) end
    end
    if rest_hours <= 0 then rest_hours = 1 end
    local duration_game_sec = math.floor(rest_hours * 3600)
    if duration_game_sec < 1 then duration_game_sec = 1 end
    do
        local min_s = 0
        local max_s = 0
        if siski.config and siski.config.get then
            local vmin = siski.config.get("rest_fallback_stay_min_sec", 900)
            local vmax = siski.config.get("rest_fallback_stay_max_sec", 1800)
            min_s = tonumber(vmin) or 0
            max_s = tonumber(vmax) or 0
        end
        if min_s < 0 then min_s = 0 end
        if max_s < 0 then max_s = 0 end
        if max_s > 0 and min_s > 0 and max_s < min_s then
            max_s = min_s
        end
        if min_s > 0 and duration_game_sec < min_s then
            duration_game_sec = max_s > 0 and math.random(min_s, max_s) or min_s
        elseif max_s > 0 and duration_game_sec > max_s then
            duration_game_sec = max_s
        end
        if duration_game_sec < 1 then duration_game_sec = 1 end
    end

    local started_gt = nil
    local now_gt = game_time_now()
    if now_gt then
        started_gt = ctime_to_table(now_gt)
    end

    local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
    if tf <= 0 then tf = 10 end
    local duration_ms = math.floor((duration_game_sec * 1000) / tf)
    if duration_ms < 1000 then duration_ms = 1000 end

    return make_task("REST_1H", nil, {
        started_at_gt = started_gt,
        duration_game_sec = duration_game_sec,
        started_at_tg = tg(),
        duration_ms = duration_ms
    }, 0)
end

local function build_explore_task(se_squad, cur_level, community, section_name)
    local neighbors = {}
    if siski.config and siski.config.get_neighbors then
        neighbors = siski.config.get_neighbors(cur_level)
    end
    local levels = {}
    local seen = {}
    local function add_level(name)
        if type(name) ~= "string" or name == "" then return end
        if seen[name] then return end
        if is_level_blacklisted_for_faction(name, community, section_name) then return end
        seen[name] = true
        levels[#levels + 1] = name
    end
    for i = 1, (neighbors and #neighbors or 0) do
        add_level(neighbors[i])
    end

    local target_level = pick_random(levels)
    if not target_level then return nil end

    local smarts = get_smarts_for_level(target_level, community, section_name)
    local smart_name = nil
    if community then
        smart_name = pick_random_valid_safe(smarts, community, nil, target_level, section_name)
    else
        smart_name = pick_random_valid(smarts, community, target_level, section_name)
    end
    if not smart_name then return nil end
    return make_task("EXPLORE", smart_name, { started_at_tg = tg(), target_level = target_level }, 0)
end

local function build_force_exit_task(se_squad, entry, cur_level, community, section_name)
    if not (cur_level and community) then return nil end

    local neighbors = {}
    if siski.config and siski.config.get_neighbors then
        neighbors = siski.config.get_neighbors(cur_level)
    end

    local candidate_levels = {}
    local seen = {}
    for i = 1, (neighbors and #neighbors or 0) do
        local lvl = neighbors[i]
        if type(lvl) == "string" and lvl ~= "" and lvl ~= cur_level and (not seen[lvl]) then
            seen[lvl] = true
            if not is_level_blacklisted_for_faction(lvl, community, section_name) then
                candidate_levels[#candidate_levels + 1] = lvl
            end
        end
    end

    local sid = (entry and entry.squad_id) or (se_squad and se_squad.id) or "-"

    if #candidate_levels <= 0 then
        if siski.log and siski.log.info then
            siski.log.info("TASKS", "FORCE_EXIT_NO_ROUTE sid=%s community=%s from_level=%s reason=no_allowed_neighbor_levels",
                tostring(sid), tostring(community), tostring(cur_level))
        end
        return nil
    end

    shuffle_in_place(candidate_levels)
    for i = 1, #candidate_levels do
        local target_level = candidate_levels[i]
        local smarts = get_smarts_for_level(target_level, community, section_name)
        local target = pick_random_valid_safe(smarts, community, nil, target_level, section_name)
        if target then
            if siski.log and siski.log.info then
                siski.log.info("TASKS", "FORCE_EXIT_ASSIGNED sid=%s community=%s from_level=%s to_level=%s target=%s",
                    tostring(sid), tostring(community), tostring(cur_level), tostring(target_level), tostring(target))
            end
            return make_task("EXPLORE", target, {
                started_at_tg = tg(),
                target_level = target_level,
                from_level = cur_level,
                force_exit = true,
            }, 0)
        end
    end

    if siski.log and siski.log.info then
        siski.log.info("TASKS", "FORCE_EXIT_NO_ROUTE sid=%s community=%s from_level=%s reason=no_allowed_smarts",
            tostring(sid), tostring(community), tostring(cur_level))
    end
    return nil
end

local function pick_populate_target_smart(se_squad, cur_level, community, section_name)
    if not (se_squad and cur_level and community) then
        return nil
    end
    if not (siski.memory and (siski.memory.iter_squads_for_logic or siski.memory.get_state)) then
        return nil
    end

    local board = get_board()
    local by_name = board and board.smarts_by_names or nil

    local function resolve_anchor_smart(entry)
        if type(entry) ~= "table" then
            return nil, nil, nil, nil
        end

        local function resolve_by_name(smart_name)
            if type(smart_name) ~= "string" or smart_name == "" then
                return nil, nil, nil, nil
            end
            local sm = (by_name and by_name[smart_name]) or get_smart_by_name(smart_name)
            if not sm then
                return nil, nil, nil, nil
            end
            local tgvid = tonumber(sm.m_game_vertex_id) or nil
            local lvl = tgvid and now_level_name_by_gvid(tgvid) or nil
            return smart_name, lvl, tgvid, sm
        end

        local smart_name, lvl, tgvid, sm = resolve_by_name(entry.scripted_target)
        if smart_name then
            return smart_name, lvl, tgvid, sm
        end

        local smart_id = tonumber(entry.smart_id) or nil
        if smart_id and by_name then
            for name, sm in pairs(by_name) do
                if sm and tonumber(sm.id) == smart_id then
                    local gvid = tonumber(sm.m_game_vertex_id) or nil
                    local level_name = gvid and now_level_name_by_gvid(gvid) or nil
                    return name, level_name, gvid, sm
                end
            end
        end

        local cur = entry.tasks and entry.tasks.current or nil
        return resolve_by_name(cur and cur.target or nil)
    end

    local function build_populate_search_levels()
        local pass1 = {}
        local pass2 = {}
        local pass1_set = {}
        local pass2_set = {}

        local seen = {}
        local function add_level(into, into_set, level_name)
            if type(level_name) ~= "string" or level_name == "" then return end
            if level_name == cur_level then return end
            if seen[level_name] then return end
            if is_level_blacklisted_for_faction(level_name, community, section_name) then return end
            seen[level_name] = true
            into[#into + 1] = level_name
            into_set[level_name] = true
        end

        if siski.config and siski.config.get_neighbors then
            local neighbors = siski.config.get_neighbors(cur_level) or {}
            for i = 1, #neighbors do
                add_level(pass1, pass1_set, neighbors[i])
            end

            for i = 1, #pass1 do
                local lvl = pass1[i]
                local lvl_neighbors = siski.config.get_neighbors(lvl) or {}
                for j = 1, #lvl_neighbors do
                    add_level(pass2, pass2_set, lvl_neighbors[j])
                end
            end
        end

        return pass1, pass1_set, pass2, pass2_set
    end

    local function scan_candidates(level_set)
        if type(level_set) ~= "table" or next(level_set) == nil then
            return nil
        end

        local ok_sgvid, sgvid = pcall(function() return se_squad.m_game_vertex_id end)
        sgvid = ok_sgvid and sgvid or nil

        local best_name = nil
        local best_dist = nil
        local fallback = {}
        local fallback_n = 0
        local fallback_seen = {}

        for _, e in iter_logic_squads(LOGIC_MAX_AGE_MS) do
            local other_comm = e and e.community or nil
            if other_comm and other_comm == community then
                local smart_name, target_level, tgvid, sm = resolve_anchor_smart(e)
                if smart_name and target_level and level_set[target_level] == true then
                    if sm
                        and (not smart_is_blacklisted_by_obj(sm, smart_name, community, section_name))
                        and is_roam_smart_allowed(smart_name, community)
                    then
                        local d = (not sgvid or not tgvid) and nil or try_game_graph_distance(sgvid, tgvid)
                        if d ~= nil then
                            if (not best_dist) or d < best_dist then
                                best_dist = d
                                best_name = smart_name
                            end
                        elseif not fallback_seen[smart_name] then
                            fallback_seen[smart_name] = true
                            fallback_n = fallback_n + 1
                            fallback[fallback_n] = smart_name
                        end
                    end
                end
            end
        end

        if best_name then
            return best_name
        end
        if fallback_n > 0 then
            return pick_random_valid_safe(fallback, community, nil, nil, section_name)
        end
        return nil
    end

    local pass1, pass1_set, pass2, pass2_set = build_populate_search_levels()
    if #pass1 > 0 then
        local target = scan_candidates(pass1_set)
        if target then
            return target
        end
    end
    if #pass2 > 0 then
        return scan_candidates(pass2_set)
    end
    return nil
end

local function build_populate_task(se_squad, entry, cur_level, community, section_name)
    if not (cur_level and community) then return nil end
    local smart_name = pick_populate_target_smart(se_squad, cur_level, community, section_name)
    if not smart_name then return nil end
    return make_task("POPULATE", smart_name, { started_at_tg = tg(), from_level = cur_level }, 0)
end

local function ensure_task_params(task)
    if not task then return nil end
    task.params = task.params or {}
    return task.params
end

local function get_alife_sim()
    if not alife then return nil end
    local ok, sim = pcall(function() return alife() end)
    return ok and sim or nil
end

local function safe_se_obj_by_id(id)
    id = tonumber(id)
    if not id then return nil end
    local sim = get_alife_sim()
    if not sim then return nil end
    local ok, se_obj = pcall(function() return sim:object(id) end)
    return ok and se_obj or nil
end

local function is_loose_world_object_by_id(id)
    id = tonumber(id)
    if not id then return false end

    local se_obj = safe_se_obj_by_id(id)
    if se_obj then
        local parent_id = tonumber(se_obj.parent_id)
        if parent_id and parent_id ~= 65535 then
            return false
        end
        return true
    end

    return safe_obj_by_id(id) ~= nil
end

local function request_release_object_by_id(id)
    id = tonumber(id)
    if not id then
        return false, "still_exists_unknown"
    end

    local accepted = false
    local rel = _G.alife_release_id
    if type(rel) == "function" then
        local ok, res = pcall(function() return rel(id) end)
        if ok and res ~= false then
            accepted = true
        end
    end

    if not accepted then
        local sim = get_alife_sim()
        local se_obj = safe_se_obj_by_id(id)
        if sim and se_obj and sim.release then
            local ok, res = pcall(function() return sim:release(se_obj, true) end)
            if ok and res ~= false then
                accepted = true
            end
        end
    end

    if not safe_se_obj_by_id(id) and not safe_obj_by_id(id) then
        return accepted, "gone"
    end
    if is_loose_world_object_by_id(id) then
        return accepted, "still_loose"
    end
    return accepted, "still_exists_unknown"
end

local function create_alife_item(section, pos, lvid, gvid, parent_id)
    if not (section and pos) then return nil end
    lvid = tonumber(lvid)
    gvid = tonumber(gvid)
    parent_id = tonumber(parent_id)
    if not (lvid and gvid) then return nil end

    local sim = get_alife_sim()
    if sim and sim.create then
        if parent_id then
            local ok, created = pcall(function() return sim:create(section, pos, lvid, gvid, parent_id) end)
            if ok and created then
                return created
            end
        else
            local ok, created = pcall(function() return sim:create(section, pos, lvid, gvid) end)
            if ok and created then
                return created
            end
        end
    end

    if not parent_id then
        local alife_create = _G.alife_create
        if type(alife_create) == "function" then
            local ok, created = pcall(function() return alife_create(section, pos, lvid, gvid) end)
            if ok and created then
                return created
            end
        end
    end

    return nil
end

local function mark_artefact_pickup_done(task)
    local params = ensure_task_params(task)
    if not params then return true end
    params.pickup_stage = "done"
    params.pickup_release_requested_tg = nil
    params.pickup_release_deadline_tg = nil
    params.pickup_copy_id = nil
    params.pickup_wait_until_tg = nil
    return true
end

local function get_squad_commander_id(se_squad, entry)
    local cid = nil
    if se_squad and se_squad.commander_id then
        local ok, res = pcall(function() return se_squad:commander_id() end)
        cid = ok and tonumber(res) or nil
    end
    if not cid then
        cid = tonumber(se_squad and se_squad.commander_id) or nil
    end
    if not cid then
        cid = tonumber(entry and entry.commander_id) or nil
    end
    return cid
end

local function get_online_commander_obj(se_squad, entry)
    local cid = get_squad_commander_id(se_squad, entry)
    if not cid then return nil end
    return safe_obj_by_id(cid)
end

local function resolve_artefact_scan_anchor(se_squad, entry, target_smart_name)
    local sm = target_smart_name and get_smart_by_name(target_smart_name) or nil
    if sm and sm.position then
        return sm.position
    end

    local leader_obj = get_online_commander_obj(se_squad, entry)
    if leader_obj and siski.safe and siski.safe.safe_position then
        local pos = siski.safe.safe_position(leader_obj)
        if pos then
            return pos
        end
    end

    if siski.safe and siski.safe.safe_position then
        local pos = siski.safe.safe_position(se_squad)
        if pos then
            return pos
        end
    end

    return nil
end

local function resolve_artefact_parent_anchor(se_squad, entry, target_smart_name)
    local sm = target_smart_name and get_smart_by_name(target_smart_name) or nil
    local sm_lvid = tonumber(sm and sm.m_level_vertex_id) or nil
    local sm_gvid = tonumber(sm and sm.m_game_vertex_id) or nil
    if sm and sm.position and sm_lvid and sm_gvid then
        return {
            pos = sm.position,
            lvid = sm_lvid,
            gvid = sm_gvid,
        }
    end

    do
        local leader_obj = get_online_commander_obj(se_squad, entry)
        if leader_obj then
            local safe = siski.safe
            local pos = safe and safe.safe_position and safe.safe_position(leader_obj) or nil
            local lvid = safe and safe.safe_level_vertex_id and tonumber(safe.safe_level_vertex_id(leader_obj)) or nil
            local gvid = safe and safe.safe_game_vertex_id and tonumber(safe.safe_game_vertex_id(leader_obj)) or nil
            if pos and lvid and gvid then
                return {
                    pos = pos,
                    lvid = lvid,
                    gvid = gvid,
                }
            end
        end
    end

    local safe = siski.safe
    local pos = safe and safe.safe_position and safe.safe_position(se_squad) or nil
    local lvid = tonumber(se_squad and se_squad.m_level_vertex_id) or nil
    local gvid = tonumber(se_squad and se_squad.m_game_vertex_id) or nil
    if pos and lvid and gvid then
        return {
            pos = pos,
            lvid = lvid,
            gvid = gvid,
        }
    end

    return nil
end

local function extract_member_candidate_id_local(k, v)
    if type(v) == "table" then
        local idv = tonumber(v.id) or tonumber(v.object_id) or tonumber(v.squad_id)
        if idv and idv > 0 then
            return idv
        end
    end

    local id = tonumber(v)
    if id and id > 0 then
        return id
    end

    id = tonumber(k)
    if id and id > 0 then
        return id
    end

    return nil
end

local function iter_online_squad_member_ids(se_squad)
    local out = {}
    if not se_squad then
        return out
    end

    local seen = {}
    local function push(id)
        id = tonumber(id)
        if not id or id <= 0 or seen[id] then
            return
        end
        if not safe_obj_by_id(id) then
            return
        end
        seen[id] = true
        out[#out + 1] = id
    end

    local ok_members, a, b, c = pcall(function() return se_squad:squad_members() end)
    if ok_members and a ~= nil then
        local ok_iter = pcall(function()
            for member in a, b, c do
                push(extract_member_candidate_id_local(nil, member))
            end
        end)
        if (not ok_iter) and type(a) == "table" then
            for k, v in pairs(a) do
                push(extract_member_candidate_id_local(k, v))
            end
        end
    end

    if #out <= 0 then
        push(get_squad_commander_id(se_squad, nil))
    end

    return out
end

local function is_squad_online_for_tasks(se_squad, entry)
    return get_online_commander_obj(se_squad, entry) ~= nil
end

local function smart_supports_stalker_jobs(smart)
    local jobs = smart and smart.stalker_jobs or nil
    if type(jobs) ~= "table" or #jobs <= 0 then
        return false
    end
    if type(smart.npc_info) ~= "table" then
        return false
    end
    if type(smart.select_npc_job) ~= "function" then
        return false
    end
    return true
end

local function is_smart_on_actor_level_for_tasks(smart)
    if not smart then
        return false
    end

    local ok_actor, actor_level = pcall(function() return smart.is_on_actor_level end)
    if ok_actor and actor_level ~= nil then
        return actor_level == true
    end

    local active_level = loaded_level_name()
    local gvid = tonumber(smart.m_game_vertex_id) or nil
    local smart_level = gvid and now_level_name_by_gvid(gvid) or nil
    return smart_level ~= nil and smart_level == active_level
end

local function try_soft_register_squad_to_smart(se_squad, smart_name, smart, board)
    if not (se_squad and smart and board and board.assign_squad_to_smart) then
        return false
    end
    local smart_id = tonumber(smart.id) or nil
    if not smart_id then
        return false
    end
    if tonumber(se_squad.smart_id) == smart_id then
        return true
    end
    local ok = pcall(function() board:assign_squad_to_smart(se_squad, smart_id) end)
    return ok == true
end

local function try_soft_assign_free_stalker_jobs_once(se_squad, smart, smart_name)
    if not smart_supports_stalker_jobs(smart) then
        return false
    end

    local member_ids = iter_online_squad_member_ids(se_squad)
    for i = 1, #member_ids do
        local npc_id = member_ids[i]
        local npc_info = smart.npc_info[npc_id] or smart.npc_info[tostring(npc_id)]
        if npc_info and npc_info.job == nil then
            pcall(function() smart:select_npc_job(npc_info, true) end)
        end
    end

    return true
end

local function resolve_post_arrival_assist(se_squad, entry, task, target_smart_name)
    local params = ensure_task_params(task)
    if not params then
        return true
    end

    local task_type = task and task.type or nil
    if task_type ~= "EXPLORE" and task_type ~= "POPULATE" and task_type ~= "ARTEFACT" then
        return true
    end

    if params.arrival_assist_done == true then
        return true
    end

    local board = get_board()
    local smart = nil
    if type(target_smart_name) == "string" and target_smart_name ~= "" and board and board.smarts_by_names then
        smart = board.smarts_by_names[target_smart_name]
    end
    if not smart then
        params.arrival_assist_done = true
        return true
    end

    if params.arrival_register_attempted ~= true then
        try_soft_register_squad_to_smart(se_squad, target_smart_name, smart, board)
        params.arrival_register_attempted = true
    end

    local jobs_supported = smart_supports_stalker_jobs(smart)
    params.arrival_jobs_supported = jobs_supported == true
    if jobs_supported ~= true then
        params.arrival_assist_done = true
        return true
    end

    if not is_squad_online_for_tasks(se_squad, entry) then
        params.arrival_assist_done = true
        return true
    end

    if not is_smart_on_actor_level_for_tasks(smart) then
        params.arrival_assist_done = true
        return true
    end

    if params.arrival_jobs_attempted ~= true then
        try_soft_assign_free_stalker_jobs_once(se_squad, smart, target_smart_name)
        params.arrival_jobs_attempted = true
    end

    local now = tg()
    if not tonumber(params.arrival_settle_started_tg) then
        params.arrival_settle_started_tg = now
        params.arrival_settle_until_tg = now + ARRIVAL_ASSIST_SETTLE_MS
    end

    if now < (tonumber(params.arrival_settle_until_tg) or 0) then
        return false
    end

    params.arrival_assist_done = true
    return true
end

local function find_nearby_artifact_hit(anchor_pos, radius_m)
    if not (level and level.iterate_nearest and anchor_pos and radius_m) then return nil end
    local found = nil
    level.iterate_nearest(anchor_pos, radius_m, function(obj)
        if not obj then return false end
        local sec = siski.safe and siski.safe.safe_section and siski.safe.safe_section(obj) or nil
        if sec and string.sub(sec, 1, 3) == "af_" then
            local oid = siski.safe and siski.safe.safe_id and siski.safe.safe_id(obj) or nil
            found = {
                section = sec,
                object_id = tonumber(oid) or nil,
                object = obj,
            }
            return true
        end
        return false
    end)
    return found
end

local function get_offline_artefact_pool()
    if RUNTIME.artefact_pool ~= false then
        return RUNTIME.artefact_pool
    end

    local out = {}
    if type(_G.ini_file) == "function" then
        local ok_ini, ini = pcall(function() return _G.ini_file("items\\trade\\gulag_job_trade_buy_sell.ltx") end)
        if ok_ini and ini and ini.section_exist and ini.line_count and ini.r_line then
            local ok_sec, has_sec = pcall(function() return ini:section_exist("buy_sell") end)
            if ok_sec and has_sec then
                local ok_cnt, cnt = pcall(function() return ini:line_count("buy_sell") end)
                cnt = ok_cnt and tonumber(cnt) or 0
                if cnt > 0 then
                    for idx = 0, cnt - 1 do
                        local ok_line, key = pcall(function() return ini:r_line("buy_sell", idx) end)
                        if ok_line and type(key) == "string" and key ~= "" and string.sub(key, 1, 1) ~= ";" and string.sub(key, 1, 3) == "af_" then
                            out[#out + 1] = key
                        end
                    end
                end
            end
        end
    end

    RUNTIME.artefact_pool = out
    return out
end

local function resolve_artefact_completion_after_pickup(se_squad, entry, task)
    local params = ensure_task_params(task)
    local done = true
    if type(params.pickup_section) == "string" then
        done = resolve_post_arrival_assist(se_squad, entry, task, task and task.target or nil)
    end
    if done then
        params.fast_trade_block = nil
    end
    return done
end

local function complete_online_artefact_inventory_delivery(se_squad, entry, task)
    local leader_obj = get_online_commander_obj(se_squad, entry)
    local params = ensure_task_params(task)
    local sid = tostring(entry and entry.squad_id or "-")
    local target = tostring(task and task.target or "-")
    local section = type(params.pickup_section) == "string" and params.pickup_section or nil
    local source_id = tonumber(params.pickup_source_id) or nil

    local created = nil
    local alife_create_item = _G.alife_create_item
    if leader_obj and type(alife_create_item) == "function" and section then
        local ok, res = pcall(function() return alife_create_item(section, leader_obj) end)
        if ok and res then
            created = res
        end
    end

    if not created then
        task_warn_once("ARTEFACT_INV_CREATE_FAIL", "ARTEFACT_INV_CREATE_FAIL sid=%s target=%s src_id=%s sec=%s",
            sid, target, tostring(source_id or "-"), tostring(section or "-"))
        return mark_artefact_pickup_done(task)
    end

    local commander_id = get_squad_commander_id(se_squad, entry)
    if commander_id and siski.fast_trading and siski.fast_trading.enqueue_check_for_npc then
        pcall(function()
            siski.fast_trading.enqueue_check_for_npc(commander_id, section, "artefact_task_direct_inventory")
        end)
    end

    return mark_artefact_pickup_done(task)
end

local function resolve_artefact_release_pending(se_squad, entry, task)
    local params = ensure_task_params(task)
    local source_id = tonumber(params.pickup_source_id) or nil
    if not source_id then
        return mark_artefact_pickup_done(task)
    end

    if not is_loose_world_object_by_id(source_id) then
        return complete_online_artefact_inventory_delivery(se_squad, entry, task)
    end

    local now = tg()
    local deadline = tonumber(params.pickup_release_deadline_tg) or 0
    if now < deadline then
        return false
    end

    task_warn_once("ARTEFACT_SOURCE_RELEASE_TIMEOUT", "ARTEFACT_SOURCE_RELEASE_TIMEOUT sid=%s target=%s src_id=%s sec=%s",
        tostring(entry and entry.squad_id or "-"),
        tostring(task and task.target or "-"),
        tostring(source_id),
        tostring(params.pickup_section or "-"))
    return mark_artefact_pickup_done(task)
end

local function begin_online_artefact_pickup(se_squad, entry, task, hit)
    local params = ensure_task_params(task)
    local sid = tostring(entry and entry.squad_id or "-")
    local target = tostring(task and task.target or "-")
    local section = hit and hit.section or nil
    local source_id = tonumber(hit and hit.object_id) or nil

    if not (section and source_id) then
        task_warn_once("ARTEFACT_SOURCE_RELEASE_FAIL", "ARTEFACT_SOURCE_RELEASE_FAIL sid=%s target=%s src_id=%s sec=%s",
            sid, target, tostring(source_id or "-"), tostring(section or "-"))
        return mark_artefact_pickup_done(task)
    end

    params.pickup_section = section
    params.pickup_source_id = source_id

    local accepted, source_state = request_release_object_by_id(source_id)
    if accepted ~= true then
        task_warn_once("ARTEFACT_SOURCE_RELEASE_FAIL", "ARTEFACT_SOURCE_RELEASE_FAIL sid=%s target=%s src_id=%s sec=%s",
            sid, target, tostring(source_id), tostring(section))
        return mark_artefact_pickup_done(task)
    end

    if source_state == "still_loose" then
        params.pickup_stage = "release_pending"
        params.pickup_release_requested_tg = tg()
        params.pickup_release_deadline_tg = tg() + ARTEFACT_RELEASE_CONFIRM_MS
        return false
    end

    return complete_online_artefact_inventory_delivery(se_squad, entry, task)
end

local function grant_offline_artefact_to_squad(se_squad, entry, task, target_smart_name)
    local params = ensure_task_params(task)
    if params.offline_roll_done == true then
        if params.pickup_stage == "done" then
            return true
        end
        return true
    end

    params.offline_roll_done = true
    params.offline_roll_success = false

    if math.random(100) > ARTEFACT_OFFLINE_ROLL_PERCENT then
        return true
    end

    local pool = get_offline_artefact_pool()
    if not pool or #pool == 0 then
        task_warn_once("ARTEFACT_OFFLINE_POOL_EMPTY", "ARTEFACT_OFFLINE_POOL_EMPTY sid=%s target=%s",
            tostring(entry and entry.squad_id or "-"), tostring(task and task.target or "-"))
        return true
    end

    local section = pick_random(pool)
    local commander_id = get_squad_commander_id(se_squad, entry)
    local anchor = resolve_artefact_parent_anchor(se_squad, entry, target_smart_name)
    if not (section and commander_id and anchor) then
        task_warn_once("ARTEFACT_OFFLINE_CREATE_FAIL", "ARTEFACT_OFFLINE_CREATE_FAIL sid=%s target=%s sec=%s commander=%s",
            tostring(entry and entry.squad_id or "-"), tostring(task and task.target or "-"),
            tostring(section or "-"), tostring(commander_id or "-"))
        return true
    end

    local created = create_alife_item(section, anchor.pos, anchor.lvid, anchor.gvid, commander_id)
    if not created then
        task_warn_once("ARTEFACT_OFFLINE_CREATE_FAIL", "ARTEFACT_OFFLINE_CREATE_FAIL sid=%s target=%s sec=%s commander=%s",
            tostring(entry and entry.squad_id or "-"), tostring(task and task.target or "-"),
            tostring(section or "-"), tostring(commander_id or "-"))
        return true
    end

    params.offline_roll_success = true
    params.pickup_section = section
    return mark_artefact_pickup_done(task)
end

local function resolve_artefact_task_completion(se_squad, entry, task)
    local params = ensure_task_params(task)
    if params.pickup_stage == "done" then
        return resolve_artefact_completion_after_pickup(se_squad, entry, task)
    end

    local target = task and task.target or nil
    if not target then
        return false
    end
    if not is_squad_arrived_to_smart(se_squad, target) then
        return false
    end

    params.fast_trade_block = true

    local now = tg()
    local cd = tonumber(params.check_cd_tg) or 0
    if now < cd then
        return false
    end
    params.check_cd_tg = now + ARTEFACT_CHECK_INTERVAL_MS

    if params.pickup_stage == "ground_pending" then
        params.pickup_copy_id = nil
        params.pickup_wait_until_tg = nil
        params.pickup_stage = "done"
        return resolve_artefact_completion_after_pickup(se_squad, entry, task)
    end

    if params.pickup_stage == "release_pending" then
        local resolved_pending = resolve_artefact_release_pending(se_squad, entry, task)
        if params.pickup_stage == "done" then
            return resolve_artefact_completion_after_pickup(se_squad, entry, task)
        end
        return resolved_pending
    end

    local leader_obj = get_online_commander_obj(se_squad, entry)
    if leader_obj then
        if params.pickup_scan_done == true then
            params.pickup_stage = "done"
            return resolve_artefact_completion_after_pickup(se_squad, entry, task)
        end

        params.pickup_scan_done = true
        local anchor_pos = resolve_artefact_scan_anchor(se_squad, entry, target)
        local hit = anchor_pos and find_nearby_artifact_hit(anchor_pos, ARTEFACT_SCAN_RADIUS) or nil
        if not hit then
            params.pickup_stage = "done"
            return resolve_artefact_completion_after_pickup(se_squad, entry, task)
        end
        local resolved_online = begin_online_artefact_pickup(se_squad, entry, task, hit)
        if params.pickup_stage == "done" then
            return resolve_artefact_completion_after_pickup(se_squad, entry, task)
        end
        return resolved_online
    end

    local resolved_offline = grant_offline_artefact_to_squad(se_squad, entry, task, target)
    if params.pickup_stage == "done" then
        return resolve_artefact_completion_after_pickup(se_squad, entry, task)
    end
    return resolved_offline
end

local function build_artefact_task(se_squad, cur_level, community, section_name)
    local list = get_cap_bucket(cur_level, "anomaly", community)
    if not list or #list == 0 then
        list = siski.config and siski.config.get_anomaly_smarts and siski.config.get_anomaly_smarts(cur_level) or {}
    end
    local smart_name = community and pick_random_valid_safe(list, community, nil, cur_level, section_name) or pick_random_valid(list, community, cur_level, section_name)
    if not smart_name then return nil end
    return make_task("ARTEFACT", smart_name, { started_at_tg = tg(), check_cd_tg = 0, hops = 0 }, 0)
end

local build_base_camping_task
local build_patrol_task
local build_night_rest_task
local build_trade_task

local function build_roam_task(se_squad, entry, cur_level, community, section_name, trade_enabled, artefact_enabled, explore_enabled, populate_enabled, base_camping_enabled, patrol_enabled)
    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        local forced = build_force_exit_task(se_squad, entry, cur_level, community, section_name)
        if forced then
            return forced
        end
    end

    local candidates = {}
    local n = 0

    if artefact_enabled then
        local t = build_artefact_task(se_squad, cur_level, community, section_name)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    if trade_enabled and siski.trade and siski.trade.can_trade_now then
        local ok_can, can_trade = pcall(siski.trade.can_trade_now, se_squad)
        if ok_can and can_trade == true and build_trade_task then
            local t = build_trade_task(se_squad, entry, cur_level, community, section_name)
            if t then
                n = n + 1
                candidates[n] = t
            end
        end
    end

    if populate_enabled and community then
        local t = build_populate_task(se_squad, entry, cur_level, community, section_name)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    if explore_enabled then
        local t = build_explore_task(se_squad, cur_level, community, section_name)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end
    
    if base_camping_enabled then
        local t = build_base_camping_task(se_squad, entry, cur_level, community, section_name)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    if patrol_enabled then
        local t = build_patrol_task(se_squad, entry, cur_level, community, section_name)
        if t then
            n = n + 1
            candidates[n] = t
        end
    end

    return pick_random(candidates)
end

build_base_camping_task = function(se_squad, entry, cur_level, community, section_name)
    if not cur_level then return nil end
    local smart_name = pick_base_camping_target_smart(cur_level, community, section_name)
    if not smart_name then return nil end

    local camp_hours = 2
    if siski.config and siski.config.get then
        local v = siski.config.get("base_camping_duration_game_hours", camp_hours)
        if tonumber(v) then camp_hours = tonumber(v) end
    end
    if camp_hours <= 0 then camp_hours = 1 end

    local duration_game_sec = math.floor(camp_hours * 3600)
    if duration_game_sec < 1 then duration_game_sec = 1 end

    local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
    if tf <= 0 then tf = 10 end
    local duration_ms = math.floor((camp_hours * 3600 * 1000) / tf)
    if duration_ms < 1000 then duration_ms = 1000 end

    return make_task("BASE_CAMPING", smart_name, {
        duration_game_sec = duration_game_sec,
        duration_ms = duration_ms,
        arrived_at_gt = nil,
        arrived_at_tg = nil,
    }, 0)
end

build_patrol_task = function(se_squad, entry, cur_level, community, section_name)
    if not cur_level then return nil end
    local task = make_task("PATROL", nil, {}, 0)
    task.params.started_at_tg = tg()
    do
        local now_gt = game_time_now()
        if now_gt then
            task.params.started_at_gt = ctime_to_table(now_gt)
        end
    end
    task.params.duration_game_sec = 7200
    do
        local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
        if tf <= 0 then tf = 10 end
        task.params.duration_ms = math.floor((task.params.duration_game_sec * 1000) / tf)
        if task.params.duration_ms < 1000 then task.params.duration_ms = 1000 end
    end
    local target = pick_next_patrol_target(task, cur_level, community, section_name)
    if not target then return nil end
    task.target = target
    reset_task_hotpath_timers(task)
    return task
end

build_night_rest_task = function(se_squad, entry, cur_level, community, section_name)
    if not cur_level then return nil end
    local smart_name = pick_base_camping_target_smart(cur_level, community, section_name)
    if not smart_name then return nil end
    local p = { started_at_tg = tg(), arrived_at_gt = nil, arrived_at_tg = nil }
    local now_gt = game_time_now()
    if now_gt then
        p.started_at_gt = ctime_to_table(now_gt)
    end
    return make_task("NIGHT_REST", smart_name, p, 0)
end

local function quota_key(level_name, community)
    local lvl = type(level_name) == "string" and level_name ~= "" and level_name or "-"
    local comm = normalize_community_key(community) or tostring(community or "-")
    return tostring(lvl) .. "|" .. tostring(comm)
end

local function intel_bucket(level_name, community)
    local key = quota_key(level_name, community)
    local intel = RUNTIME.intel.by_level_faction
    local b = intel[key]
    if type(b) ~= "table" then
        b = {}
        intel[key] = b
    end
    return b
end

function record_intel(level_name, community, smart_name, score, source)
    if type(level_name) ~= "string" or level_name == "" then return end
    if type(community) ~= "string" or community == "" then return end
    if type(smart_name) ~= "string" or smart_name == "" then return end

    local now = tg()
    local b = intel_bucket(level_name, community)
    local cur = b[smart_name]
    if type(cur) ~= "table" then
        cur = { score = 0, tg = now, source = source }
        b[smart_name] = cur
    end
    cur.score = (tonumber(cur.score) or 0) + (tonumber(score) or 0)
    if cur.score > 5 then cur.score = 5 end
    if cur.score < -5 then cur.score = -5 end
    cur.tg = now
    cur.source = source
end

local function cleanup_intel(now)
    if now < (tonumber(RUNTIME.intel.next_cleanup_tg) or 0) then
        return
    end
    RUNTIME.intel.next_cleanup_tg = now + 30000
    for _, b in pairs(RUNTIME.intel.by_level_faction) do
        if type(b) == "table" then
            for smart_name, e in pairs(b) do
                if type(e) ~= "table" or now - (tonumber(e.tg) or 0) > INTEL_TTL_MS then
                    b[smart_name] = nil
                end
            end
        end
    end
end

local function refresh_faction_quota(now)
    now = tonumber(now) or tg()
    local q = RUNTIME.faction_quota
    if now < (tonumber(q.next_tg) or 0) then
        return q.by_level_faction
    end

    if (not get_faction_task_enabled()) or get_faction_task_squads_per_level() <= 0 then
        q.next_tg = now + FACTION_QUOTA_UPDATE_MS
        q.by_level_faction = {}
        return q.by_level_faction
    end

    q.next_tg = now + FACTION_QUOTA_UPDATE_MS
    q.by_level_faction = {}

    local function resolve_quota_identity(e, sid)
        local level_name = e and e.level or nil
        local community = e and e.community or nil
        local squad_id = tonumber((e and e.squad_id) or sid) or nil
        if squad_id and alife then
            local sim = alife()
            if sim and sim.object then
                local ok_obj, se_squad = pcall(function() return sim:object(squad_id) end)
                if ok_obj and se_squad then
                    local gvid = tonumber(se_squad.m_game_vertex_id) or nil
                    if gvid then
                        local live_level = now_level_name_by_gvid(gvid)
                        if live_level then
                            level_name = live_level
                            if e then
                                e.level = live_level
                                e.level_gvid = gvid
                            end
                        end
                    end
                    community = get_squad_community(e, se_squad) or community
                end
            end
        end
        community = normalize_community_key(community) or nil
        return level_name, community
    end

    local desired_count = get_faction_task_squads_per_level()
    for sid, e in iter_logic_squads(LOGIC_MAX_AGE_MS) do
        local level_name, community = resolve_quota_identity(e, sid)
        if type(level_name) == "string" and level_name ~= "" and type(community) == "string" and community ~= "" then
            local key = quota_key(level_name, community)
            local row = q.by_level_faction[key]
            if not row then
                row = { level = level_name, community = community, total = 0, assigned = 0, desired = 0 }
                q.by_level_faction[key] = row
            end
            row.total = row.total + 1
            local cur = e.tasks and e.tasks.current or nil
            if cur and cur.type == "FACTION_TASK" then
                row.assigned = row.assigned + 1
            end
        end
    end

    for _, row in pairs(q.by_level_faction) do
        local desired = desired_count
        if desired < 0 then desired = 0 end
        if desired > row.total then desired = row.total end
        row.desired = desired
    end
    return q.by_level_faction
end

local function get_quota_row(level_name, community, now)
    local map = refresh_faction_quota(now)
    local row = map and map[quota_key(level_name, community)] or nil
    if row then return row end
    return { level = level_name, community = community, total = 0, assigned = 0, desired = 0 }
end

local function is_runner_target_allowed(smart_name, level_name, community, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false
    end
    local sm = get_smart_by_name(smart_name)
    local lvl = level_name
    if sm and sm.m_game_vertex_id then
        lvl = now_level_name_by_gvid(sm.m_game_vertex_id) or lvl
        if smart_is_blacklisted_by_obj(sm, smart_name, community, section_name) then
            return false
        end
    elseif smart_is_blacklisted_for_level(lvl, smart_name, community, section_name) then
        return false
    end
    if community and smart_is_safe_for_faction(smart_name, community, lvl) ~= true then
        return false
    end
    return true
end

local function collect_ally_runner_candidates(se_squad, entry, cur_level, community, section_name)
    local out = {
        own_current = {},
        neutral_current = {},
        own_neighbor = {},
        neutral_neighbor = {},
        level_by_smart = {},
        seen = {
            own_current = {},
            neutral_current = {},
            own_neighbor = {},
            neutral_neighbor = {},
        },
    }
    if type(cur_level) ~= "string" or cur_level == "" then
        return out
    end

    local neighbors = {}
    if siski.config and siski.config.get_neighbors then
        local arr = siski.config.get_neighbors(cur_level) or {}
        for i = 1, #arr do
            local lvl = arr[i]
            if type(lvl) == "string" and lvl ~= "" then
                neighbors[lvl] = true
            end
        end
    end

    local sid = tonumber((entry and entry.squad_id) or (se_squad and se_squad.id) or 0) or 0
    local function push(bucket_name, smart_name, level_name)
        local seen = out.seen[bucket_name]
        if seen[smart_name] then
            return
        end
        seen[smart_name] = true
        local bucket = out[bucket_name]
        bucket[#bucket + 1] = smart_name
        if out.level_by_smart[smart_name] == nil then
            out.level_by_smart[smart_name] = level_name
        end
    end

    for osid, e in iter_logic_squads(LOGIC_MAX_AGE_MS) do
        local oid = tonumber(osid) or 0
        if oid ~= sid then
            local other_comm = e and e.community or nil
            local relation = nil
            if type(other_comm) == "string" and other_comm ~= "" then
                if other_comm == community then
                    relation = "own"
                elseif other_comm ~= community and is_ally_faction(community, other_comm) then
                    relation = "neutral"
                end
            end

            if relation then
                local smart_name, lvl = RUNTIME.resolve_entry_anchor_smart(e)
                lvl = lvl or (e and e.level) or nil
                if smart_name and type(lvl) == "string" and lvl ~= "" and is_runner_target_allowed(smart_name, lvl, community, section_name) then
                    if lvl == cur_level then
                        if relation == "own" then
                            push("own_current", smart_name, lvl)
                        else
                            push("neutral_current", smart_name, lvl)
                        end
                    elseif neighbors[lvl] then
                        if relation == "own" then
                            push("own_neighbor", smart_name, lvl)
                        else
                            push("neutral_neighbor", smart_name, lvl)
                        end
                    end
                end
            end
        end
    end

    return out
end

local function pick_runner_candidate_from_list(list, level_by_smart, community, section_name, avoid_target)
    if type(list) ~= "table" or #list <= 0 then
        return nil, nil
    end

    local function pick(source)
        local n = source and #source or 0
        if n <= 0 then
            return nil, nil
        end
        for _ = 1, math.min(8, n) do
            local smart_name = source[math.random(n)]
            local lvl = level_by_smart and level_by_smart[smart_name] or nil
            if is_runner_target_allowed(smart_name, lvl, community, section_name) then
                return smart_name, lvl
            end
        end
        for i = 1, n do
            local smart_name = source[i]
            local lvl = level_by_smart and level_by_smart[smart_name] or nil
            if is_runner_target_allowed(smart_name, lvl, community, section_name) then
                return smart_name, lvl
            end
        end
        return nil, nil
    end

    if type(avoid_target) == "string" and avoid_target ~= "" then
        local alt = {}
        for i = 1, #list do
            local smart_name = list[i]
            if smart_name ~= avoid_target then
                alt[#alt + 1] = smart_name
            end
        end
        local picked, lvl = pick(alt)
        if picked then
            return picked, lvl
        end
    end

    return pick(list)
end

local function pick_runner_safe_current_target(cur_level, community, section_name, avoid_target)
    if type(cur_level) ~= "string" or cur_level == "" then
        return nil
    end
    local list = get_cap_bucket(cur_level, "safe", community)
    if not list or #list == 0 then
        list = get_smarts_for_level(cur_level, community, section_name)
    end
    if not list or #list == 0 then
        return nil
    end
    local level_by_smart = {}
    for i = 1, #list do
        local smart_name = list[i]
        if smart_name then
            level_by_smart[smart_name] = cur_level
        end
    end
    return pick_runner_candidate_from_list(list, level_by_smart, community, section_name, avoid_target)
end

local function pick_runner_ally_target(se_squad, entry, cur_level, community, section_name, avoid_current_target)
    if type(cur_level) ~= "string" or cur_level == "" then
        return nil, nil, false
    end
    local candidates = collect_ally_runner_candidates(se_squad, entry, cur_level, community, section_name)
    local level_by_smart = candidates.level_by_smart or {}

    local picked, lvl = pick_runner_candidate_from_list(candidates.own_current, level_by_smart, community, section_name, avoid_current_target)
    if picked then return picked, lvl, true end

    picked, lvl = pick_runner_candidate_from_list(candidates.neutral_current, level_by_smart, community, section_name, avoid_current_target)
    if picked then return picked, lvl, true end

    picked, lvl = pick_runner_candidate_from_list(candidates.own_neighbor, level_by_smart, community, section_name, nil)
    if picked then return picked, lvl, true end

    picked, lvl = pick_runner_candidate_from_list(candidates.neutral_neighbor, level_by_smart, community, section_name, nil)
    if picked then return picked, lvl, true end

    picked = pick_runner_safe_current_target(cur_level, community, section_name, avoid_current_target)
    if picked then
        return picked, cur_level, false
    end
    return nil, nil, false
end

local function pick_nearest_safe_candidate(arr, se_squad, community, level_name, section_name)
    if type(arr) ~= "table" or #arr <= 0 then
        return nil
    end
    local sgvid = se_squad and tonumber(se_squad.m_game_vertex_id) or nil
    local best_name = nil
    local best_dist = nil
    local fallback = {}
    local seen = {}

    for i = 1, #arr do
        local smart_name = arr[i]
        if type(smart_name) == "string" and smart_name ~= "" and not seen[smart_name] then
            seen[smart_name] = true
            local sm = get_smart_by_name(smart_name)
            local lvl = level_name
            local tgvid = nil
            if sm and sm.m_game_vertex_id then
                tgvid = tonumber(sm.m_game_vertex_id) or nil
                lvl = now_level_name_by_gvid(tgvid) or lvl
            end
            if is_runner_target_allowed(smart_name, lvl, community, section_name) then
                local d = (not sgvid or not tgvid) and nil or try_game_graph_distance(sgvid, tgvid)
                if d ~= nil then
                    if (best_dist == nil) or (d < best_dist) or (d == best_dist and tostring(smart_name) < tostring(best_name)) then
                        best_dist = d
                        best_name = smart_name
                    end
                else
                    fallback[#fallback + 1] = smart_name
                end
            end
        end
    end

    if best_name then
        return best_name
    end
    if #fallback > 0 then
        table.sort(fallback)
        return fallback[1]
    end
    return nil
end

local function pick_runner_base_target(se_squad, cur_level, ally_level, community, section_name)
    local target_level = type(ally_level) == "string" and ally_level or cur_level
    if type(target_level) == "string" and target_level ~= "" then
        local target = pick_nearest_safe_candidate(get_cap_bucket(target_level, "base", community), se_squad, community, target_level, section_name)
        if target then return target, target_level end

        target = pick_nearest_safe_candidate(get_cap_bucket(target_level, "kamp", community), se_squad, community, target_level, section_name)
        if target then return target, target_level end

        local safe = get_cap_bucket(target_level, "safe", community)
        if not safe or #safe == 0 then
            safe = get_smarts_for_level(target_level, community, section_name)
        end
        target = pick_nearest_safe_candidate(safe, se_squad, community, target_level, section_name)
        if target then return target, target_level end
    end

    if type(cur_level) == "string" and cur_level ~= "" then
        local safe_cur = get_cap_bucket(cur_level, "safe", community)
        if not safe_cur or #safe_cur == 0 then
            safe_cur = get_smarts_for_level(cur_level, community, section_name)
        end
        local target = pick_nearest_safe_candidate(safe_cur, se_squad, community, cur_level, section_name)
        if target then return target, cur_level end
    end
    return nil, nil
end

local function build_faction_task(se_squad, entry, cur_level, community, section_name, prev_params)
    if not get_faction_task_enabled() then return nil end
    if not (cur_level and community) then return nil end

    local now = tg()
    local prev = type(prev_params) == "table" and prev_params or {}
    local params = {
        mode = "ALLY_RUNNER",
        phase = (prev.phase == "TO_BASE") and "TO_BASE" or "TO_ALLY",
        cycle = tonumber(prev.cycle) or 0,
        last_ally_target = (type(prev.last_ally_target) == "string" and prev.last_ally_target ~= "") and prev.last_ally_target or nil,
        ally_level = (type(prev.ally_level) == "string" and prev.ally_level ~= "") and prev.ally_level or nil,
        reacquire_next_tg = tonumber(prev.reacquire_next_tg) or 0,
        ally_registered = prev.ally_registered == true,
    }

    local target = nil
    local target_level = nil

    if params.phase == "TO_BASE" then
        target, target_level = pick_runner_base_target(se_squad, cur_level, params.ally_level, community, section_name)
        if target then
            params.ally_registered = true
        else
            params.phase = "TO_ALLY"
            params.ally_registered = false
        end
    end

    if not target then
        local avoid_target = ((tonumber(params.cycle) or 0) > 0) and params.last_ally_target or nil
        local registered = false
        target, target_level, registered = pick_runner_ally_target(se_squad, entry, cur_level, community, section_name, avoid_target)
        if not target then
            return nil
        end
        params.phase = "TO_ALLY"
        params.ally_registered = registered == true
        if params.ally_registered then
            params.last_ally_target = target
            params.ally_level = target_level
            params.reacquire_next_tg = 0
        else
            params.ally_level = nil
            params.reacquire_next_tg = now + FACTION_RUNNER_REACQUIRE_MS
        end
    end

    params.target_level = target_level or cur_level
    return make_task("FACTION_TASK", target, params, 10)
end

local function should_assign_faction_task(entry, cur_level, community, now, reserve_slot)
    if not get_faction_task_enabled() then return false end
    local row = get_quota_row(cur_level, community, now)
    if row.assigned < row.desired then
        if reserve_slot ~= false then
            row.assigned = row.assigned + 1
            RUNTIME.stats.forced_faction_assignments = (tonumber(RUNTIME.stats.forced_faction_assignments) or 0) + 1
        end
        return true
    end
    return false
end

local function should_release_faction_task(entry, task, cur_level, community, now)
    if not (task and task.type == "FACTION_TASK") then return false end
    if not get_faction_task_enabled() then return true end
    local row = get_quota_row(cur_level, community, now)
    if row.assigned > row.desired then
        row.assigned = row.assigned - 1
        RUNTIME.stats.forced_faction_releases = (tonumber(RUNTIME.stats.forced_faction_releases) or 0) + 1
        return true
    end
    return false
end

local function trade_target_cache_key(se_squad, cur_level, community, section_name)
    local sid = nil
    if se_squad and se_squad.id then
        sid = tonumber(se_squad.id)
    end
    return tostring(sid or "-") .. "|" .. tostring(cur_level or "-") .. "|" .. tostring(community or "-") .. "|" .. tostring(section_name or "-")
end

local function get_cached_trade_target(se_squad, cur_level, community, section_name, max_age_ms)
    local key = trade_target_cache_key(se_squad, cur_level, community, section_name)
    local c = RUNTIME.adaptive_trade_target_cache[key]
    if type(c) ~= "table" then
        return nil
    end

    local now = tg()
    local age = now - (tonumber(c.tg) or 0)
    local ttl = tonumber(max_age_ms) or 30000
    if age > ttl then
        return nil
    end

    local target = c.target
    if not (target and type(target) == "string") then
        return nil
    end

    local sm = get_smart_by_name(target)
    if sm and smart_is_blacklisted_by_obj(sm, target, community, section_name) then
        return nil
    end
    if (not sm) and smart_is_blacklisted_for_level(cur_level, target, community, section_name) then
        return nil
    end
    if community and is_roam_smart_allowed(target, community) ~= true then
        return nil
    end
    return target
end

local function set_cached_trade_target(se_squad, cur_level, community, section_name, target)
    if not (target and type(target) == "string") then return end
    local key = trade_target_cache_key(se_squad, cur_level, community, section_name)
    RUNTIME.adaptive_trade_target_cache[key] = {
        tg = tg(),
        target = target,
    }
end

RUNTIME.collect_trade_candidate_smarts = function(level_name, community, section_name)
    if not level_name then
        return {}
    end

    if siski.config and siski.config.get_trade_smarts then
        local static_list = siski.config.get_trade_smarts(level_name) or {}
        if #static_list > 0 then
            local seen = {}
            local smarts = {}
            for i = 1, #static_list do
                local name = static_list[i]
                if name and not seen[name] then
                    seen[name] = true
                    smarts[#smarts + 1] = name
                end
            end
            return smarts
        end
    end

    local smarts = nil
    do
        local cap_slots = get_cap_bucket(level_name, "trade_slot", community) or {}
        if #cap_slots > 0 then
            local seen = {}
            smarts = {}
            for i = 1, #cap_slots do
                local name = cap_slots[i]
                if name and not seen[name] then
                    seen[name] = true
                    smarts[#smarts + 1] = name
                end
            end
        end
    end
    if not smarts or #smarts == 0 then
        local list = get_smarts_for_level(level_name, community, section_name)
        local board = get_board()
        local by_name = board and board.smarts_by_names or nil
        local seen = {}
        smarts = {}
        for i = 1, (list and #list or 0) do
            local name = list[i]
            local sm = name and by_name and by_name[name] or nil
            local has_trade_slot = name and smart_has_trader_slot(name, sm) or false
            if name and not seen[name] and has_trade_slot then
                seen[name] = true
                smarts[#smarts + 1] = name
            end
        end
    end
    return smarts or {}
end

RUNTIME.build_trade_search_levels = function(cur_level, community, section_name)
    local levels = {}
    local seen = {}

    local function add_level(level_name)
        if type(level_name) ~= "string" or level_name == "" then return end
        if seen[level_name] then return end
        if is_level_blacklisted_for_faction(level_name, community, section_name) then return end
        seen[level_name] = true
        levels[#levels + 1] = level_name
    end

    add_level(cur_level)

    if siski.config and siski.config.get_neighbors then
        local neighbors = siski.config.get_neighbors(cur_level) or {}
        for i = 1, #neighbors do
            add_level(neighbors[i])
        end
    end

    return levels
end

RUNTIME.pick_trade_target_on_level = function(se_squad, level_name, community, section_name)
    local smarts = RUNTIME.collect_trade_candidate_smarts(level_name, community, section_name)
    local n = smarts and #smarts or 0
    local active_level = loaded_level_name()
    local require_live_provider = type(active_level) == "string" and active_level ~= "" and active_level == level_name
    if n <= 0 then
        return nil, nil, {
            level = level_name,
            slot_n = 0,
            slot_any = 0,
            trader_only_n = 0,
            trader_any = 0,
            excluded_unsafe = 0,
            excluded_cap = 0,
            best_name = nil,
            best_dist = nil,
        }
    end

    local board = get_board()
    local by_name = board and board.smarts_by_names or nil

    local ok_sgvid, sgvid = pcall(function() return se_squad.m_game_vertex_id end)
    sgvid = ok_sgvid and sgvid or nil

    local ok_sid, sid = pcall(function() return se_squad.id end)
    sid = ok_sid and tonumber(sid) or nil

    local max_per_smart = 1
    if siski.config and siski.config.get then
        local v = siski.config.get("trade_max_squads_per_smart", max_per_smart)
        if tonumber(v) then max_per_smart = tonumber(v) end
    end
    if max_per_smart < 0 then max_per_smart = 0 end

    local taken = nil
    if max_per_smart > 0 and siski.memory and (siski.memory.iter_squads_for_logic or siski.memory.get_state) then
        taken = {}
        for osid, e in iter_logic_squads(LOGIC_MAX_AGE_MS) do
            local oid = tonumber(osid)
            if not (sid and oid and oid == sid) then
                local cur = e and e.tasks and e.tasks.current or nil
                local tgt = cur and cur.type == "TRADE" and cur.target or nil
                if tgt then
                    local tgt_level = RUNTIME.resolve_smart_level_name(tgt, e and e.level or nil)
                    if tgt_level == level_name then
                        taken[tgt] = (tonumber(taken[tgt]) or 0) + 1
                    end
                end
            end
        end
    end

    local best_slot = nil
    local best_slot_dist = nil
    local fallback_slot = {}
    local fb_slot_n = 0
    local slot_n = 0
    local trader_only_n = 0
    local excluded_cap = 0
    local excluded_unsafe = 0
    local slot_any = 0
    local trader_any = 0
    local allowed_by_name = {}
    local function is_allowed(name)
        if not name then return false end
        if allowed_by_name[name] == nil then
            allowed_by_name[name] = is_roam_smart_allowed(name, community) == true
        end
        return allowed_by_name[name] == true
    end

    for i = 1, n do
        local name = smarts[i]
        local used = taken and name and (tonumber(taken[name]) or 0) or 0
        if max_per_smart > 0 and used >= max_per_smart then
            excluded_cap = excluded_cap + 1
        else
            local sm = by_name and name and by_name[name] or nil
            local has_slot = name and smart_has_trader_slot(name, sm) or false
            local has_trader = (sm and smart_has_real_trader(sm)) or false
            local trade_ready = has_slot and ((require_live_provider and has_trader) or (not require_live_provider))
            local ok_allowed = name and is_allowed(name)
            if has_slot then slot_any = slot_any + 1 end
            if has_trader then trader_any = trader_any + 1 end
            if ok_allowed ~= true then
                excluded_unsafe = excluded_unsafe + 1
            end
            if ok_allowed and trade_ready then
                slot_n = slot_n + 1
                local ok_gvid, tgvid = pcall(function() return sm and sm.m_game_vertex_id end)
                tgvid = ok_gvid and tgvid or nil
                local d = try_game_graph_distance(sgvid, tgvid)
                if d then
                    if not best_slot_dist or d < best_slot_dist then
                        best_slot_dist = d
                        best_slot = name
                    end
                else
                    fb_slot_n = fb_slot_n + 1
                    fallback_slot[fb_slot_n] = name
                end
            elseif ok_allowed and has_trader and not has_slot then
                trader_only_n = trader_only_n + 1
            end
        end
    end

    local picked = nil
    local reason = nil
    if slot_n > 0 then
        picked = best_slot or pick_random_valid_safe(fallback_slot, community, allowed_by_name, level_name, section_name)
        reason = "slot"
    end

    return picked, reason, {
        level = level_name,
        slot_n = slot_n,
        slot_any = slot_any,
        trader_only_n = trader_only_n,
        trader_any = trader_any,
        excluded_unsafe = excluded_unsafe,
        excluded_cap = excluded_cap,
        best_name = best_slot or nil,
        best_dist = best_slot_dist or nil,
    }
end

RUNTIME.summarize_trade_pick_failure = function(se_squad, cur_level, community, section_name)
    local levels = RUNTIME.build_trade_search_levels(cur_level, community, section_name)
    if not levels or #levels <= 0 then
        return "-"
    end

    local parts = {}
    for i = 1, #levels do
        local level_name = levels[i]
        local _, _, stats = RUNTIME.pick_trade_target_on_level(se_squad, level_name, community, section_name)
        parts[#parts + 1] = string.format(
            "%s slot=%s/%s trader_only=%s/%s unsafe=%s cap=%s",
            tostring(level_name or "-"),
            tostring(stats and stats.slot_n or 0),
            tostring(stats and stats.slot_any or 0),
            tostring(stats and stats.trader_only_n or 0),
            tostring(stats and stats.trader_any or 0),
            tostring(stats and stats.excluded_unsafe or 0),
            tostring(stats and stats.excluded_cap or 0)
        )
    end

    return table.concat(parts, "; ")
end

local function pick_trade_target_smart(se_squad, cur_level, community, section_name, lane_granted, entry)
    local tostring = tostring
    if not (se_squad and cur_level and community) then return nil end

    local search_levels = RUNTIME.build_trade_search_levels(cur_level, community, section_name)
    local current_smarts = RUNTIME.collect_trade_candidate_smarts(cur_level, community, section_name)
    if #search_levels <= 0 then
        return nil
    end

    local now = tg()
    local dirty = false
    if entry then
        dirty = consume_entry_dirty(entry, "task") or consume_entry_dirty(entry, "community") or consume_entry_dirty(entry, "identity")
    end
    if lane_granted ~= true and (not dirty) and (not adaptive_should_run("trade.pick_target", now, 500, ADAPTIVE_FORCE_TRADE_PICK_MS)) then
        adaptive_note_defer("trade.pick_target", now, "lane_pressure")
        local cached_target = get_cached_trade_target(se_squad, cur_level, community, section_name, DIRTY_TRADE_PICK_TTL_MS)
        if cached_target then
            return cached_target
        end

        local board_quick = get_board()
        local by_name_quick = board_quick and board_quick.smarts_by_names or nil
        for li = 1, #search_levels do
            local level_name = search_levels[li]
            local smarts = (li == 1) and current_smarts or RUNTIME.collect_trade_candidate_smarts(level_name, community, section_name)
            local limit = math.min(6, smarts and #smarts or 0)
            for i = 1, limit do
                local candidate = smarts[i]
                local sm = by_name_quick and candidate and by_name_quick[candidate] or nil
                local blacklisted = false
                if sm then
                    blacklisted = smart_is_blacklisted_by_obj(sm, candidate, community, section_name)
                else
                    blacklisted = smart_is_blacklisted_for_level(level_name, candidate, community, section_name)
                end
                local safe = (community == nil) or (is_roam_smart_allowed(candidate, community) == true)
                if candidate and not blacklisted and safe then
                    set_cached_trade_target(se_squad, cur_level, community, section_name, candidate)
                    record_intel(level_name, community, candidate, 0.5, li == 1 and "trade_pick_quick" or "trade_pick_neighbor_quick")
                    return candidate
                end
            end
        end
        return nil
    end

    local picked = nil
    local reason = nil
    local picked_level = nil
    local stats = nil
    for li = 1, #search_levels do
        local level_name = search_levels[li]
        local candidate, pick_reason, pick_stats = RUNTIME.pick_trade_target_on_level(se_squad, level_name, community, section_name)
        if candidate then
            picked = candidate
            reason = (li == 1) and pick_reason or ("neighbor_" .. tostring(pick_reason or "pick"))
            picked_level = level_name
            stats = pick_stats
            break
        end
        if li == 1 then
            stats = pick_stats
        end
    end
    if siski.log and siski.log.debug then
        siski.log.debug("TRADE", "pick_trade_target level=%s picked_level=%s community=%s slot_smarts=%s/%s trader_only_smarts=%s/%s excluded_unsafe=%s excluded_cap=%s best=%s best_dist=%s picked=%s reason=%s",
            tostring(cur_level or "-"),
            tostring(picked_level or "-"),
            tostring(community or "-"),
            tostring(stats and stats.slot_n or 0),
            tostring(stats and stats.slot_any or 0),
            tostring(stats and stats.trader_only_n or 0),
            tostring(stats and stats.trader_any or 0),
            tostring(stats and stats.excluded_unsafe or 0),
            tostring(stats and stats.excluded_cap or 0),
            tostring(stats and stats.best_name or "-"),
            tostring(stats and stats.best_dist or "-"),
            tostring(picked or "-"),
            tostring(reason or "-")
        )
    end
    if picked then
        set_cached_trade_target(se_squad, cur_level, community, section_name, picked)
        record_intel(picked_level or cur_level, community, picked, 0.5, "trade_pick")
    end
    return picked
end

build_trade_task = function(se_squad, entry, cur_level, community, section_name)
    local tostring = tostring
    if not (cur_level and community) then return nil end
    local smart_name = pick_trade_target_smart(se_squad, cur_level, community, section_name, false, entry)
    if not smart_name then return nil end
    local task = make_task("TRADE", smart_name, { started_at_tg = tg(), trade_offline_duration_game_sec = 7200 }, 0)
    if siski.log and siski.log.info then
        siski.log.info("TRADE", "build_trade_task sid=%s level=%s community=%s target=%s",
            tostring(entry and entry.squad_id or "-"),
            tostring(cur_level or "-"),
            tostring(community or "-"),
            tostring(smart_name or "-")
        )
    end
    return task
end

local function rebuild_task(se_squad, entry, task)
    if not (se_squad and entry and task and task.type) then return nil end
    
    -- Fast trading trigger: force TRADE task
    if task.params and task.params.fast_trade_trigger == true then
        local retry_ms = 2000
        local now_fast = tg()
        local retry_next_tg = tonumber(task.params.fast_trade_retry_next_tg) or 0
        if retry_next_tg > now_fast then
            return nil
        end
        local cur_level_fast = now_level_name_by_gvid(se_squad.m_game_vertex_id) or entry.level
        local community_fast = get_squad_community(entry, se_squad)
        local section_fast = get_squad_section(entry, se_squad)
        if siski.log and siski.log.info then
            siski.log.info("FAST_TRADE", "rebuild_to_trade sid=%s prev_type=%s",
                tostring(entry.squad_id or "-"),
                tostring(task.type or "-")
            )
        end
        local trade_task = build_trade_task(se_squad, entry, cur_level_fast, community_fast, section_fast)
        if trade_task and trade_task.params then
            task.params.fast_trade_trigger = nil
            task.params.fast_trade_retry_next_tg = nil
            task.params.fast_trade_retry_count = nil
            trade_task.params.fast_trade_triggered = true
            trade_task.params.online_force_rebuild = true
            trade_task.params.fast_trade_prev_type = task.type
            return trade_task
        end

        task.params.online_force_rebuild = nil
        task.params.fast_trade_retry_count = (tonumber(task.params.fast_trade_retry_count) or 0) + 1
        task.params.fast_trade_retry_next_tg = now_fast + retry_ms

        if siski.log and siski.log.warn then
            local retry_count = tonumber(task.params.fast_trade_retry_count) or 0
            if retry_count == 1 or (retry_count % 5) == 0 then
                siski.log.warn(
                    "FAST_TRADE",
                    "build_failed sid=%s prev_type=%s level=%s community=%s retry=%s next_retry_ms=%s levels=%s",
                    tostring(entry.squad_id or "-"),
                    tostring(task.type or "-"),
                    tostring(cur_level_fast or "-"),
                    tostring(community_fast or "-"),
                    tostring(retry_count),
                    tostring(retry_ms),
                    tostring(RUNTIME.summarize_trade_pick_failure(se_squad, cur_level_fast, community_fast, section_fast))
                )
            end
        end
        return nil
    end

    local now = tg()
    if not adaptive_should_run("tasks.rebuild_ensure", now, 1000, ADAPTIVE_FORCE_REBUILD_ENSURE_MS) then
        adaptive_note_defer("tasks.rebuild_ensure", now, "rebuild")
        return task
    end
    local cur_level = now_level_name_by_gvid(se_squad.m_game_vertex_id) or entry.level
    entry.level = cur_level
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)
    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        local forced = build_force_exit_task(se_squad, entry, cur_level, community, section_name)
        if forced then
            return forced
        end
    end
    local night_rest_enabled = siski.config and siski.config.get and siski.config.get("night_rest_enabled", false) ~= false
    if night_rest_enabled and is_night_now() then
        return build_night_rest_task(se_squad, entry, cur_level, community, section_name)
    end
    if task.type == "EXPLORE" then
        return build_explore_task(se_squad, cur_level, community, section_name)
    end
    if task.type == "ARTEFACT" then
        return build_artefact_task(se_squad, cur_level, community, section_name)
    end
    if task.type == "REST_1H" then
        return build_rest_task(se_squad)
    end
    if task.type == "BASE_CAMPING" then
        return build_base_camping_task(se_squad, entry, cur_level, community, section_name)
    end
    if task.type == "PATROL" then
        return build_patrol_task(se_squad, entry, cur_level, community, section_name)
    end
    if task.type == "NIGHT_REST" then
        return build_night_rest_task(se_squad, entry, cur_level, community, section_name)
    end
    if task.type == "FACTION_TASK" then
        return build_faction_task(se_squad, entry, cur_level, community, section_name, task.params)
    end
    if task.type == "POPULATE" then
        return build_populate_task(se_squad, entry, cur_level, community, section_name)
    end
    if task.type == "TRADE" then
        return build_trade_task(se_squad, entry, cur_level, community, section_name)
    end
    return nil
end

local function ensure_current_task(se_squad, entry)
    if entry.tasks and entry.tasks.current then return entry.tasks.current end
    local now = tg()
    local allow_expensive = adaptive_should_run("tasks.rebuild_ensure", now, 1000, ADAPTIVE_FORCE_REBUILD_ENSURE_MS)
    if not allow_expensive then
        adaptive_note_defer("tasks.rebuild_ensure", now, "ensure")
    end

    local cur_level = now_level_name_by_gvid(se_squad.m_game_vertex_id) or entry.level
    entry.level = cur_level
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)

    local task = nil
    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        task = build_force_exit_task(se_squad, entry, cur_level, community, section_name)
        if task then
            return task
        end
    end

    local night_rest_enabled = siski.config and siski.config.get and siski.config.get("night_rest_enabled", false) ~= false
    if night_rest_enabled and is_night_now() then
        task = build_night_rest_task(se_squad, entry, cur_level, community, section_name)
    end
    refresh_faction_quota(now)
    cleanup_intel(now)
    local trade_enabled = siski.config and siski.config.get and siski.config.get("trade_enabled", false) ~= false
    local artefact_enabled = siski.config and siski.config.get and siski.config.get("artefact_enabled", true) ~= false
    local explore_enabled = siski.config and siski.config.get and siski.config.get("explore_enabled", true) ~= false
    local populate_enabled = siski.config and siski.config.get and siski.config.get("populate_enabled", true) ~= false
    local base_camping_enabled = siski.config and siski.config.get and siski.config.get("base_camping_enabled", true) ~= false
    local patrol_enabled = siski.config and siski.config.get and siski.config.get("patrol_enabled", true) ~= false

    if not task and allow_expensive and should_assign_faction_task(entry, cur_level, community, now, false) then
        local faction_task = build_faction_task(se_squad, entry, cur_level, community, section_name, nil)
        if faction_task and should_assign_faction_task(entry, cur_level, community, now, true) then
            task = faction_task
        end
    end
    if not task and allow_expensive then
        task = build_roam_task(se_squad, entry, cur_level, community, section_name, trade_enabled, artefact_enabled, explore_enabled, populate_enabled, base_camping_enabled, patrol_enabled)
    end
    if not task and (entry.tasks and entry.tasks.prev) then
        task = entry.tasks.prev
    end
    if not task then
        task = build_rest_task(se_squad)
    end
    return task
end

function tasks._build_initial_task_bootstrap(se_squad, entry)
    if not (se_squad and entry) then
        return nil
    end

    local now = tg()
    local cur_level = now_level_name_by_gvid(se_squad.m_game_vertex_id) or entry.level
    entry.level = cur_level
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)

    local task = nil
    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        task = build_force_exit_task(se_squad, entry, cur_level, community, section_name)
        if task then
            return task
        end
    end

    local night_rest_enabled = siski.config and siski.config.get and siski.config.get("night_rest_enabled", false) ~= false
    if night_rest_enabled and is_night_now() then
        task = build_night_rest_task(se_squad, entry, cur_level, community, section_name)
        if task then
            return task
        end
    end

    refresh_faction_quota(now)
    cleanup_intel(now)

    local trade_enabled = siski.config and siski.config.get and siski.config.get("trade_enabled", false) ~= false
    local artefact_enabled = siski.config and siski.config.get and siski.config.get("artefact_enabled", true) ~= false
    local explore_enabled = siski.config and siski.config.get and siski.config.get("explore_enabled", true) ~= false
    local populate_enabled = siski.config and siski.config.get and siski.config.get("populate_enabled", true) ~= false
    local base_camping_enabled = siski.config and siski.config.get and siski.config.get("base_camping_enabled", true) ~= false
    local patrol_enabled = siski.config and siski.config.get and siski.config.get("patrol_enabled", true) ~= false

    if should_assign_faction_task(entry, cur_level, community, now, false) then
        local faction_task = build_faction_task(se_squad, entry, cur_level, community, section_name, nil)
        if faction_task and should_assign_faction_task(entry, cur_level, community, now, true) then
            return faction_task
        end
    end

    task = build_roam_task(
        se_squad,
        entry,
        cur_level,
        community,
        section_name,
        trade_enabled,
        artefact_enabled,
        explore_enabled,
        populate_enabled,
        base_camping_enabled,
        patrol_enabled
    )
    if task then
        return task
    end

    if entry.tasks and entry.tasks.prev then
        return entry.tasks.prev
    end

    return nil
end

local function rotate_task_on_complete(se_squad, entry, surge_active)
    local tostring = tostring
    local prev = entry.tasks and entry.tasks.current or nil
    local cur_level = now_level_name_by_gvid(se_squad.m_game_vertex_id) or entry.level
    entry.level = cur_level
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)
    local now = tg()
    refresh_faction_quota(now)
    cleanup_intel(now)

    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        local forced = build_force_exit_task(se_squad, entry, cur_level, community, section_name)
        if forced then
            siski.memory.set_task_current(entry.squad_id, forced)
            return
        end
    end

    local night_rest_enabled = siski.config and siski.config.get and siski.config.get("night_rest_enabled", false) ~= false
    if night_rest_enabled and is_night_now() then
        local next_task = build_night_rest_task(se_squad, entry, cur_level, community, section_name) or build_rest_task(se_squad)
        siski.memory.set_task_current(entry.squad_id, next_task)
        return
    end

    if surge_active == nil then
        surge_active = is_surge_active()
    end
    if surge_active then
        local next_task = build_rest_task(se_squad)
        siski.memory.set_task_current(entry.squad_id, next_task)
        return
    end

    local base_camping_enabled = siski.config and siski.config.get and siski.config.get("base_camping_enabled", true) ~= false
    local patrol_enabled = siski.config and siski.config.get and siski.config.get("patrol_enabled", true) ~= false
    local trade_enabled = siski.config and siski.config.get and siski.config.get("trade_enabled", false) ~= false

    local next_task = nil
    if should_assign_faction_task(entry, cur_level, community, now, false) then
        local faction_task = build_faction_task(se_squad, entry, cur_level, community, section_name, nil)
        if faction_task and should_assign_faction_task(entry, cur_level, community, now, true) then
            next_task = faction_task
        end
    end
    if (not next_task) and prev and prev.type == "REST_1H" then
        local artefact_enabled = siski.config and siski.config.get and siski.config.get("artefact_enabled", true) ~= false
        local explore_enabled = siski.config and siski.config.get and siski.config.get("explore_enabled", true) ~= false
        local populate_enabled = siski.config and siski.config.get and siski.config.get("populate_enabled", true) ~= false
        next_task = build_roam_task(se_squad, entry, cur_level, community, section_name, trade_enabled, artefact_enabled, explore_enabled, populate_enabled, base_camping_enabled, patrol_enabled)
    end

    if not next_task and prev and prev.type == "TRADE" then
        if not next_task then
            local artefact_enabled = siski.config and siski.config.get and siski.config.get("artefact_enabled", true) ~= false
            local explore_enabled = siski.config and siski.config.get and siski.config.get("explore_enabled", true) ~= false
            local populate_enabled = siski.config and siski.config.get and siski.config.get("populate_enabled", true) ~= false
            next_task = build_roam_task(se_squad, entry, cur_level, community, section_name, trade_enabled, artefact_enabled, explore_enabled, populate_enabled, base_camping_enabled, patrol_enabled)
        end
        if not next_task then
            next_task = build_explore_task(se_squad, cur_level, community, section_name)
        end
    end

    if prev and prev.type == "TRADE" then
        next_task = next_task or build_explore_task(se_squad, cur_level, community, section_name)
    else
        next_task = next_task or build_rest_task(se_squad)
    end
    siski.memory.set_task_current(entry.squad_id, next_task)
end

local function is_rest_timer_zero(task, now)
    if not (task and task.type == "REST_1H") then
        return false
    end
    local p = task.params or {}
    now = tonumber(now) or tg()

    local started_gt = ctime_from_table(p.started_at_gt)
    local dur_gs = tonumber(p.duration_game_sec)
    if started_gt and dur_gs then
        if dur_gs <= 0 then
            return true
        end
        local elapsed = game_time_diff_sec(started_gt)
        if elapsed and elapsed >= dur_gs then
            return true
        end
    end

    local started = tonumber(p.started_at_tg) or 0
    local dur = tonumber(p.duration_ms) or 0
    if dur <= 0 then
        return true
    end
    return now >= (started + dur)
end

local function try_rest_zero_recovery(se_squad, entry, current, surge_active, community, now)
    if not is_rest_timer_zero(current, now) then
        return false
    end

    local p = current.params or {}
    current.params = p
    local next_recover_tg = tonumber(p.rest_zero_recovery_next_tg) or 0
    if now < next_recover_tg then
        return false
    end
    p.rest_zero_recovery_next_tg = now + 3000

    if siski.memory and siski.memory.update_squad_snapshot then
        pcall(siski.memory.update_squad_snapshot, se_squad)
    end

    local cur_level = resolve_entry_level(entry, se_squad) or entry.level
    if cur_level then
        entry.level = cur_level
    end
    community = get_squad_community(entry, se_squad) or community
    local section_name = get_squad_section(entry, se_squad)
    entry.smart_id = se_squad.smart_id
    entry.scripted_target = se_squad.scripted_target

    local ok_rot, err_rot = pcall(rotate_task_on_complete, se_squad, entry, surge_active)
    if not ok_rot then
        log_task_error("rest_zero_recover_rotate", entry, current, err_rot)
        siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        return true
    end

    if not (entry.tasks and entry.tasks.current) then
        local ok_new, new_or_err = pcall(ensure_current_task, se_squad, entry)
        if ok_new and new_or_err then
            siski.memory.set_task_current(entry.squad_id, new_or_err)
        else
            log_task_error("rest_zero_recover_ensure", entry, current, new_or_err)
            siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        end
    end

    local next_task = entry.tasks and entry.tasks.current or nil
    reset_task_hotpath_timers(next_task)
    local ok_apply, err_apply = pcall(apply_task, se_squad, next_task, surge_active, community, section_name)
    if not ok_apply then
        log_task_error("rest_zero_recover_apply", entry, next_task, err_apply)
        siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
    elseif siski.log and siski.log.warn then
        siski.log.warn(
            "TASKS",
            "REST_ZERO_RECOVERY sid=%s level=%s smart=%s",
            tostring(entry and entry.squad_id or "-"),
            tostring(entry and entry.level or "-"),
            tostring(entry and entry.smart_id or "-")
        )
    end
    return true
end

local function is_task_completed(se_squad, entry, task)
    local tonumber = tonumber
    local tostring = tostring
    if not task or not task.type then return true end

    if task.type == "REST_1H" then
        local p = task.params or {}
        local started_gt = ctime_from_table(p.started_at_gt)
        local dur_gs = tonumber(p.duration_game_sec)
        if started_gt and dur_gs and dur_gs > 0 then
            local elapsed = game_time_diff_sec(started_gt) or 0
            local done = elapsed >= dur_gs
            if done and not p.rest_dbg_done and siski.log and siski.log.info then
                p.rest_dbg_done = true
                siski.log.info("TASKS", "rest_done sid=%s", tostring(entry and entry.squad_id or "-"))
            end
            return done
        end
        local started = tonumber(p.started_at_tg) or 0
        local dur = tonumber(p.duration_ms) or 0
        local done = tg() >= (started + dur)
        if done and not p.rest_dbg_done and siski.log and siski.log.info then
            p.rest_dbg_done = true
            siski.log.info("TASKS", "rest_done sid=%s", tostring(entry and entry.squad_id or "-"))
        end
        return done
    end

    if task.type == "NIGHT_REST" then
        return is_night_now() == false
    end

    if task.type == "FACTION_TASK" then
        local p = task.params or {}
        task.params = p
        p.mode = "ALLY_RUNNER"
        local now = tg()
        local cur_level = resolve_entry_level(entry, se_squad) or entry.level
        local community = get_squad_community(entry, se_squad)
        local section_name = get_squad_section(entry, se_squad)

        if should_release_faction_task(entry, task, cur_level, community, now) then
            p.release_due_quota = true
            return true
        end

        local function apply_runner_target(target, target_level, phase, ally_registered)
            if type(target) ~= "string" or target == "" then
                return false
            end
            if task.target ~= target then
                task.target = target
                reset_task_hotpath_timers(task)
                p._applied = nil
            end
            p.mode = "ALLY_RUNNER"
            p.phase = phase or p.phase
            p.target_level = target_level or cur_level
            p.ally_registered = ally_registered == true
            return true
        end

        local function try_retarget_ally(prefer_other_target)
            local avoid = prefer_other_target and p.last_ally_target or nil
            local target, target_level, ally_registered = pick_runner_ally_target(se_squad, entry, cur_level, community, section_name, avoid)
            if not target then
                p.reacquire_next_tg = now + FACTION_RUNNER_REACQUIRE_MS
                RUNTIME.stats.faction_runner_reacquire = (tonumber(RUNTIME.stats.faction_runner_reacquire) or 0) + 1
                return false
            end
            apply_runner_target(target, target_level or cur_level, "TO_ALLY", ally_registered)
            if ally_registered then
                p.last_ally_target = target
                p.ally_level = target_level or cur_level
                p.reacquire_next_tg = 0
            else
                p.ally_level = nil
                p.reacquire_next_tg = now + FACTION_RUNNER_REACQUIRE_MS
                RUNTIME.stats.faction_runner_reacquire = (tonumber(RUNTIME.stats.faction_runner_reacquire) or 0) + 1
            end
            return true
        end

        local function try_retarget_base()
            local target, target_level = pick_runner_base_target(se_squad, cur_level, p.ally_level, community, section_name)
            if not target then
                return false
            end
            apply_runner_target(target, target_level or cur_level, "TO_BASE", true)
            return true
        end

        p.phase = (p.phase == "TO_BASE") and "TO_BASE" or "TO_ALLY"
        p.reacquire_next_tg = tonumber(p.reacquire_next_tg) or 0

        if p.phase == "TO_ALLY" then
            if type(task.target) ~= "string" or task.target == "" then
                if now >= p.reacquire_next_tg then
                    try_retarget_ally((tonumber(p.cycle) or 0) > 0)
                end
                return false
            end

            local arrived_ally = is_squad_arrived_to_smart(se_squad, task.target)
            if p.ally_registered ~= true then
                if now >= p.reacquire_next_tg then
                    try_retarget_ally((tonumber(p.cycle) or 0) > 0)
                end
                return false
            end

            if not arrived_ally then
                return false
            end

            if try_retarget_base() then
                return false
            end

            p.ally_registered = false
            p.ally_level = nil
            p.reacquire_next_tg = now
            return false
        end

        if type(task.target) ~= "string" or task.target == "" then
            if try_retarget_base() then
                return false
            end
            p.phase = "TO_ALLY"
            if now >= p.reacquire_next_tg then
                try_retarget_ally((tonumber(p.cycle) or 0) > 0)
            end
            return false
        end

        if not is_squad_arrived_to_smart(se_squad, task.target) then
            return false
        end

        p.cycle = (tonumber(p.cycle) or 0) + 1
        RUNTIME.stats.faction_runner_cycles = (tonumber(RUNTIME.stats.faction_runner_cycles) or 0) + 1
        p.phase = "TO_ALLY"
        p.ally_level = nil
        p.ally_registered = false
        p.reacquire_next_tg = 0
        try_retarget_ally(true)
        return false
    end

    if task.type == "TRADE" then
        local target = task.target
        if not target then return true end
        if not is_squad_arrived_to_smart(se_squad, target) then
            local p = task.params or {}
            task.params = p
            local now = tg()
            local cd = tonumber(p.trade_dbg_cd_ms) or 8000
            if siski.log and siski.log.debug and now >= (tonumber(p.trade_dbg_next_tg) or 0) then
                p.trade_dbg_next_tg = now + cd
                siski.log.debug("TRADE", "tick sid=%s level=%s state=TRAVEL target=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(entry and entry.level or "-"),
                    tostring(target or "-")
                )
            end
            local travel_ms = 600000
            if siski.config and siski.config.get then
                local v = siski.config.get("trade_travel_timeout_ms", travel_ms)
                if tonumber(v) then travel_ms = tonumber(v) end
            end
            if travel_ms < 30000 then travel_ms = 30000 end
            local started = tonumber(p.started_at_tg) or now
            if started > now then started = now end
            if now >= (started + travel_ms) then
                local rerolls = tonumber(p.trade_travel_reroll_count) or 0
                if rerolls < 2 then
                    local cur_level = resolve_entry_level(entry, se_squad)
                    local community = get_squad_community(entry, se_squad)
                    local section_name = get_squad_section(entry, se_squad)
                    local can_pick = adaptive_should_run("trade.pick_target", now, 500, ADAPTIVE_FORCE_TRADE_PICK_MS)
                    local next_target = nil
                    if can_pick then
                        next_target = pick_trade_target_smart(se_squad, cur_level, community, section_name, true, entry)
                    else
                        adaptive_note_defer("trade.pick_target", now, "travel_timeout")
                        next_target = get_cached_trade_target(se_squad, cur_level, community, section_name, 60000)
                    end
                    if next_target and next_target ~= target then
                        p.trade_travel_reroll_count = rerolls + 1
                        task.target = next_target
                        reset_task_hotpath_timers(task)
                        p.started_at_tg = now
                        p.trade_last_target = nil
                        p.trade_entered_job_logged = nil
                        p.trade_started_tg = nil
                        p.trade_started_idle = nil
                        p.trade_surge_was_active = nil
                        p.trade_no_trader_hard = nil
                        p.trade_no_trader_reason = nil
                        p.trade_job_evicted = nil
                        p.trade_done_state = nil
                        p.trade_offline_started_gt = nil
                        p.trade_offline_started_tg = nil
                        p.trade_offline_duration_ms = nil
                        p.trade_dbg_last_state = nil
                        if siski.log and siski.log.warn then
                            siski.log.warn("TRADE", "travel_timeout_reroll sid=%s old_target=%s new_target=%s",
                                tostring(entry and entry.squad_id or "-"),
                                tostring(target or "-"),
                                tostring(next_target or "-")
                            )
                        end
                        return false
                    end
                    if not can_pick then
                        return false
                    end
                end
                if siski.log and siski.log.warn then
                    siski.log.warn("TRADE", "travel_timeout_giveup sid=%s target=%s",
                        tostring(entry and entry.squad_id or "-"),
                        tostring(target or "-")
                    )
                end
                return true
            end
            return false
        end

        local p = task.params or {}
        task.params = p
        local dur_gs = tonumber(p.trade_offline_duration_game_sec) or 7200
        if dur_gs < 1 then dur_gs = 7200 end

        local st = nil
        local trade_tick_deferred = false
        local now_tick = tg()
        if adaptive_should_run("trade.tick", now_tick, 250, ADAPTIVE_FORCE_TRADE_TICK_MS) then
            local ad = siski.adaptive
            if ad and ad.stage_begin then
                ad.stage_begin("tasks.trade_tick", now_tick)
            end
            if siski.trade and siski.trade.tick then
                local ok_tick, res = pcall(siski.trade.tick, se_squad, entry, task)
                if ok_tick then
                    st = res
                else
                    if siski.log and siski.log.error then
                        siski.log.error("TRADE", "tick sid=%s state=ERROR err=%s",
                            tostring(entry and entry.squad_id or "-"),
                            tostring(res or "-")
                        )
                    end
                end
            end
            if ad and ad.stage_end then
                ad.stage_end("tasks.trade_tick", tg())
            end
        else
            trade_tick_deferred = true
            adaptive_note_defer("trade.tick", now_tick, "lane_pressure")
            st = p.trade_dbg_last_state
        end

        do
            local now = tg()
            local cd = tonumber(p.trade_dbg_cd_ms) or 8000
            local last = p.trade_dbg_last_state
            local changed = st and st ~= last
            if (changed or (now >= (tonumber(p.trade_dbg_next_tg) or 0))) and siski.log and siski.log.debug then
                p.trade_dbg_next_tg = now + cd
                if st ~= nil then
                    p.trade_dbg_last_state = st
                end
                siski.log.debug("TRADE", "tick sid=%s level=%s state=%s target=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(entry and entry.level or "-"),
                    tostring(st or "nil"),
                    tostring(target or "-")
                )
            end
        end

        if trade_tick_deferred and st == nil then
            return false
        end

        if st and st ~= "OFFLINE" then
            p.trade_offline_started_gt = nil
            p.trade_offline_started_tg = nil
            p.trade_offline_duration_ms = nil
        end

        if st == "DONE" or st == "DONE_EMPTY" then
            record_intel(entry and entry.level or nil, entry and entry.community or nil, target, 1, "trade_done")
            if st == "DONE_EMPTY" then
                p.force_rest_after_complete = true
                p.trade_done_state = "DONE_EMPTY"
            end
            if siski.log and siski.log.info then
                siski.log.info("TRADE", "done sid=%s target=%s state=%s sell_items=%s sell_ru=%s buy_items=%s buy_ru=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(st),
                    tostring(p.trade_sell_items or 0),
                    tostring(p.trade_sell_total_value or 0),
                    tostring(p.trade_buy_items or 0),
                    tostring(p.trade_buy_total_value or 0)
                )
            end
            return true
        end
        if st == "MEETING" or st == "TRADING" then
            return false
        end
        if st == "NO_TRADER" then
            if p.trade_no_trader_hard == true then
                record_intel(entry and entry.level or nil, entry and entry.community or nil, target, -1, "trade_no_trader_hard")
                p.trade_done_state = "NO_TRADER_HARD"
                if siski.fast_trading and siski.fast_trading.on_trade_completed and entry and entry.squad_id then
                    siski.fast_trading.on_trade_completed(entry.squad_id, "NO_TRADER")
                end
                task_warn_once(
                    "TRADE_HARD_NO_TRADER_COMPLETE:" .. tostring(entry and entry.squad_id or "-") .. ":" .. tostring(target or "-"),
                    "TRADE_HARD_NO_TRADER_COMPLETE sid=%s target=%s reason=%s evicted=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(p.trade_no_trader_reason or "-"),
                    tostring(p.trade_job_evicted == true)
                )
                return true
            end
            record_intel(entry and entry.level or nil, entry and entry.community or nil, target, -1, "trade_no_trader")
            if siski.log and siski.log.warn then
                siski.log.warn("TRADE", "no_trader sid=%s target=%s reroll=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(p.trade_reroll_count or 0)
                )
            end
            local rerolls = tonumber(p.trade_reroll_count) or 0
            if rerolls < 3 then
                local next_reroll = rerolls + 1
                p.trade_reroll_count = next_reroll
                local cur_level = resolve_entry_level(entry, se_squad)
                local community = get_squad_community(entry, se_squad)
                local section_name = get_squad_section(entry, se_squad)
                local now = tg()
                local can_pick = adaptive_should_run("trade.pick_target", now, 500, ADAPTIVE_FORCE_TRADE_PICK_MS)
                local next_target = nil
                if can_pick then
                    next_target = pick_trade_target_smart(se_squad, cur_level, community, section_name, true, entry)
                else
                    adaptive_note_defer("trade.pick_target", now, "no_trader")
                    next_target = get_cached_trade_target(se_squad, cur_level, community, section_name, 60000)
                end
                if next_target and next_target ~= target then
                    task.target = next_target
                    reset_task_hotpath_timers(task)
                    p.trade_last_target = nil
                    p.trade_entered_job_logged = nil
                    p.trade_started_tg = nil
                    p.trade_started_idle = nil
                    p.trade_surge_was_active = nil
                    p.trade_no_trader_hard = nil
                    p.trade_no_trader_reason = nil
                    p.trade_job_evicted = nil
                    p.trade_done_state = nil
                    p.trade_offline_started_gt = nil
                    p.trade_offline_started_tg = nil
                    p.trade_offline_duration_ms = nil
                    p.trade_dbg_last_state = nil
                    p.trade_travel_reroll_count = nil
                    if siski.log and siski.log.info then
                        siski.log.info("TRADE", "reroll sid=%s old_target=%s new_target=%s",
                            tostring(entry and entry.squad_id or "-"),
                            tostring(target or "-"),
                            tostring(next_target or "-")
                        )
                    end
                elseif siski.log and siski.log.warn then
                    siski.log.warn("TRADE", "reroll_spent sid=%s target=%s attempt=%s next_target=%s can_pick=%s",
                        tostring(entry and entry.squad_id or "-"),
                        tostring(target or "-"),
                        tostring(next_reroll),
                        tostring(next_target or "-"),
                        tostring(can_pick == true)
                    )
                end
                if not can_pick and not next_target then
                    return false
                end
                return false
            end
            return true
        end
        if st == "FAILED" then
            p.trade_failed = true
            if siski.log and siski.log.warn then
                siski.log.warn("TRADE", "failed sid=%s target=%s", tostring(entry and entry.squad_id or "-"), tostring(target or "-"))
            end
            return true
        end

        if not p.trade_offline_started_gt and not p.trade_offline_started_tg then
            local now_gt = game_time_now()
            if now_gt then
                p.trade_offline_started_gt = ctime_to_table(now_gt)
            end
            p.trade_offline_started_tg = tg()
            local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
            if tf <= 0 then tf = 10 end
            local ms = math.floor((dur_gs * 1000) / tf)
            if ms < 1000 then ms = 1000 end
            p.trade_offline_duration_ms = ms
            if siski.log and siski.log.info then
                siski.log.info("TRADE", "offline_start sid=%s target=%s dur_game_sec=%s",
                    tostring(entry and entry.squad_id or "-"),
                    tostring(target or "-"),
                    tostring(dur_gs)
                )
            end
        end

        local started_gt = ctime_from_table(p.trade_offline_started_gt)
        if started_gt and dur_gs and dur_gs > 0 then
            local elapsed = game_time_diff_sec(started_gt) or 0
            if siski.log and siski.log.debug then
                local now = tg()
                local cd = tonumber(p.trade_dbg_cd_ms) or 8000
                if now >= (tonumber(p.trade_dbg_next_tg) or 0) then
                    p.trade_dbg_next_tg = now + cd
                    siski.log.debug("TRADE", "offline_wait sid=%s target=%s elapsed=%s/%s",
                        tostring(entry and entry.squad_id or "-"),
                        tostring(target or "-"),
                        tostring(elapsed),
                        tostring(dur_gs)
                    )
                end
            end
            return elapsed >= dur_gs
        end

        local started = tonumber(p.trade_offline_started_tg) or 0
        local dur = tonumber(p.trade_offline_duration_ms) or 0
        return tg() >= (started + dur)
    end

    if task.type == "BASE_CAMPING" then
        local target = task.target
        if not target then
            return true
        end
        if not is_squad_arrived_to_smart(se_squad, target) then
            return false
        end

        local p = task.params or {}
        if not p.arrived_at_tg then
            p.arrived_at_tg = tg()
            local now_gt = game_time_now()
            if now_gt then
                p.arrived_at_gt = ctime_to_table(now_gt)
            end
            return false
        end

        local started_gt = ctime_from_table(p.arrived_at_gt)
        local dur_gs = tonumber(p.duration_game_sec)
        if started_gt and dur_gs and dur_gs > 0 then
            local elapsed = game_time_diff_sec(started_gt) or 0
            return elapsed >= dur_gs
        end

        local started = tonumber(p.arrived_at_tg) or 0
        local dur = tonumber(p.duration_ms) or 0
        return tg() >= (started + dur)
    end

    if task.type == "PATROL" then
        local p = task.params or {}
        task.params = p

        if not p.started_at_tg then
            p.started_at_tg = tg()
            local now_gt = game_time_now()
            if now_gt then
                p.started_at_gt = ctime_to_table(now_gt)
            end
        end
        if not tonumber(p.duration_game_sec) then
            p.duration_game_sec = 7200
        end
        if not tonumber(p.duration_ms) then
            local tf = (level and level.get_time_factor and level.get_time_factor()) or 10
            if tf <= 0 then tf = 10 end
            p.duration_ms = math.floor((tonumber(p.duration_game_sec) * 1000) / tf)
            if p.duration_ms < 1000 then p.duration_ms = 1000 end
        end

        do
            local started_gt = ctime_from_table(p.started_at_gt)
            local dur_gs = tonumber(p.duration_game_sec)
            if started_gt and dur_gs and dur_gs > 0 then
                local elapsed = game_time_diff_sec(started_gt) or 0
                if elapsed >= dur_gs then
                    return true
                end
            else
                local started = tonumber(p.started_at_tg) or 0
                local dur = tonumber(p.duration_ms) or 0
                if tg() >= (started + dur) then
                    return true
                end
            end
        end

        local target = task.target
        local cur_level = entry and entry.level or nil
        local community = get_squad_community(entry, se_squad)
        local section_name = get_squad_section(entry, se_squad)
        if not cur_level then
            cur_level = resolve_entry_level(entry, se_squad) or loaded_level_name()
            if entry and cur_level then entry.level = cur_level end
        end

        if not target then
            local next_target = cur_level and pick_next_patrol_target(task, cur_level, community, section_name) or nil
            if not next_target then
                return true
            end
            task.target = next_target
            reset_task_hotpath_timers(task)
            p._applied = nil
            return false
        end

        if is_squad_arrived_to_smart(se_squad, target) then
            p.visited = p.visited or {}
            if not p.visited[target] then
                p.visited[target] = true
                p.visited_count = (tonumber(p.visited_count) or 0) + 1
            end

            local next_target = cur_level and pick_next_patrol_target(task, cur_level, community, section_name) or nil
            if next_target and next_target ~= target then
                task.target = next_target
                reset_task_hotpath_timers(task)
                p._applied = nil
            end
            return false
        end

        return false
    end

    if task.type == "POPULATE" then
        local target = task.target
        if not target then return true end
        if is_squad_arrived_to_smart(se_squad, target) ~= true then
            return false
        end
        return resolve_post_arrival_assist(se_squad, entry, task, target)
    end

    if task.type == "EXPLORE" then
        local target = task.target
        if target and is_squad_arrived_to_smart(se_squad, target) then
            return resolve_post_arrival_assist(se_squad, entry, task, target)
        end
        return false
    end

    if task.type == "ARTEFACT" then
        return resolve_artefact_task_completion(se_squad, entry, task)
    end

    return false
end

function apply_task(se_squad, task, surge_active, community, section_name)
    if not task then
        sync_rest_always_arrived(se_squad, false)
        return
    end
    sync_rest_always_arrived(se_squad, task)
    task.params = task.params or {}

    if task.type == "REST_1H" then
        set_scripted_target(se_squad, nil)
        return
    end

    if task.params._applied then
        return
    end

    if surge_active == nil then
        surge_active = is_surge_active()
    end
    if surge_active then
        return
    end

    if task.target and type(task.target) == "string" then
        local board = get_board()
        local sm = board and board.smarts_by_names and board.smarts_by_names[task.target] or nil
        if smart_is_blacklisted_by_obj(sm, task.target, community, section_name) then
            set_scripted_target(se_squad, nil)
            return
        end
        if set_scripted_target(se_squad, task.target, task.params, { force_sync = true, reason = "apply" }) then
            task.params._applied = true
            local now = tg()
            if should_run_watchdog(task, now, nil) then
                pcall(run_target_watchdog, se_squad, nil, task)
            end
        end
    end
end

function tasks.update_squad_tasks(se_squad, ctx)
    if not (siski.memory and (siski.memory.touch_squad_validated or siski.memory.touch_squad)) then return end
    if siski.memory.is_protected_squad and siski.memory.is_protected_squad(se_squad) then
        if siski.memory.mark_squad_missed and se_squad and se_squad.id then
            siski.memory.mark_squad_missed(se_squad.id, "tasks", "protected")
        end
        return
    end

    local entry = nil
    if ctx and ctx.prevalidated == true and se_squad and se_squad.id and siski.memory.touch_squad then
        entry = siski.memory.touch_squad(se_squad.id, false, "tasks_fast")
    elseif siski.memory.touch_squad_validated then
        entry = siski.memory.touch_squad_validated(se_squad, false, "tasks")
    else
        entry = siski.memory.touch_squad(se_squad.id, false, "tasks")
    end
    if not entry then return end
    local now = tg()

    local surge_active = is_surge_active()
    local surge_locked = siski.memory.get_surge_lock(se_squad.id)
    if surge_active then
        if not surge_locked then
            local rest = build_rest_task(se_squad)
            siski.memory.set_task_current(entry.squad_id, rest)
            if siski.memory.set_task_next then
                siski.memory.set_task_next(entry.squad_id, nil)
            end
            sync_rest_always_arrived(se_squad, rest)
            set_scripted_target(se_squad, nil)
            siski.memory.set_surge_lock(se_squad.id, true)
        else
            sync_rest_always_arrived(se_squad, true)
            set_scripted_target(se_squad, nil)
        end
        return
    end

    if surge_locked then
        siski.memory.set_surge_lock(se_squad.id, false)
    end

    local cur_level = resolve_entry_level(entry, se_squad) or entry.level
    local community = get_squad_community(entry, se_squad)
    local section_name = get_squad_section(entry, se_squad)
    entry.smart_id = se_squad.smart_id
    entry.scripted_target = se_squad.scripted_target

    entry.tasks = entry.tasks or { prev = nil, current = nil, next = nil }
    local current = entry.tasks.current
    sync_rest_always_arrived(se_squad, current)

    if is_level_blacklisted_for_faction(cur_level, community, section_name) then
        local force_exit_active = current
            and current.type == "EXPLORE"
            and current.params
            and current.params.force_exit == true
        if not force_exit_active then
            local forced = build_force_exit_task(se_squad, entry, cur_level, community, section_name)
            if forced then
                siski.memory.set_task_current(entry.squad_id, forced)
                current = entry.tasks and entry.tasks.current or forced
            else
                siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                current = entry.tasks and entry.tasks.current or nil
            end
        end
    end

    -- Fast trading: check trigger and force rebuild
    if current and current.params and current.params.fast_trade_trigger == true then
        local ok_rebuild, rebuilt_or_err = pcall(rebuild_task, se_squad, entry, current)
        if ok_rebuild and rebuilt_or_err then
            siski.memory.set_task_current(entry.squad_id, rebuilt_or_err)
            current = entry.tasks and entry.tasks.current or rebuilt_or_err
            reset_task_hotpath_timers(current)
        end
    end

    if not current then
        local ok_new, new_task = pcall(ensure_current_task, se_squad, entry)
        if not ok_new then
            log_task_error("ensure", entry, nil, new_task)
            new_task = build_rest_task(se_squad)
        end
        if not new_task then
            log_task_error("ensure_nil", entry, nil, "ensure_current_task returned nil")
            new_task = build_rest_task(se_squad)
        end
        siski.memory.set_task_current(entry.squad_id, new_task)
        current = entry.tasks.current
        if not current then
            siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            current = entry.tasks.current
        end
        reset_task_hotpath_timers(current)
        local valid_or_err = true
        local ok_valid = true
        local err_or_valid = true
        if should_revalidate_target(current, now, true, entry) then
            ok_valid, err_or_valid = pcall(is_task_target_valid, current, community, section_name)
            if not ok_valid then
                log_task_error("target_valid", entry, current, err_or_valid)
                siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                return
            end
            valid_or_err = err_or_valid
        end
        if valid_or_err == false then
            local ok_rebuild, rebuilt_or_err = pcall(rebuild_task, se_squad, entry, current)
            if not ok_rebuild then
                log_task_error("rebuild", entry, current, rebuilt_or_err)
                siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                return
            end
            local rebuilt = rebuilt_or_err
            if rebuilt then
                siski.memory.set_task_current(entry.squad_id, rebuilt)
                current = entry.tasks.current
            end
            if not current then
                siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                current = entry.tasks.current
            end
            reset_task_hotpath_timers(current)
        end
        local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
        if not ok_apply then
            log_task_error("apply", entry, current, err_apply)
            siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        end
        return
    end

    if current.type ~= "REST_1H" then
            local ok_enf, err_enf = pcall(enforce_online_task_intent, se_squad, entry, current)
            if not ok_enf then
                log_task_error("intent_enforce", entry, current, err_enf)
            end

            local stgt = nil
            local ok_stgt, res_stgt = pcall(function() return se_squad.scripted_target end)
            if ok_stgt then stgt = res_stgt end

            if current.target and type(current.target) == "string" then
                if stgt ~= current.target then
                    current.params = current.params or {}
                    current.params._applied = nil
                    local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
                    if not ok_apply then
                        log_task_error("apply_reassert", entry, current, err_apply)
                        siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                        return
                end
            end
        end

        -- Tick throttle for watchdog - only check every Nth tick
        local wd_res = nil
        RUNTIME.watchdog_tick = (RUNTIME.watchdog_tick or 0) + 1
        if (RUNTIME.watchdog_tick % WATCHDOG_CHECK_INTERVAL) == 0 and should_run_watchdog(current, now, entry) then
            local ok_wd, err_or_res_wd = pcall(run_target_watchdog, se_squad, entry, current)
            if not ok_wd then
                log_task_error("watchdog", entry, current, err_or_res_wd)
            else
                wd_res = err_or_res_wd
            end
        end

        if type(wd_res) == "table" and wd_res.force_rebuild == true then
            RUNTIME.stats.watchdog_rebuild_count = (tonumber(RUNTIME.stats.watchdog_rebuild_count) or 0) + 1
            if current and current.params then
                current.params.online_force_rebuild = nil
            end

            local ok_rebuild, rebuilt_or_err = pcall(rebuild_task, se_squad, entry, current)
            if not ok_rebuild then
                log_task_error("watchdog_rebuild", entry, current, rebuilt_or_err)
            else
                local rebuilt = rebuilt_or_err
                if rebuilt then
                    siski.memory.set_task_current(entry.squad_id, rebuilt)
                    current = entry.tasks and entry.tasks.current or rebuilt
                    reset_task_hotpath_timers(current)
                    local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
                    if not ok_apply then
                        log_task_error("watchdog_apply_rebuild", entry, current, err_apply)
                        siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                    end
                    return
                end
            end

            local cur_level = resolve_entry_level(entry, se_squad) or entry.level
            entry.level = cur_level
            local fallback = build_base_camping_task(se_squad, entry, cur_level, community, section_name) or build_rest_task(se_squad)
            siski.memory.set_task_current(entry.squad_id, fallback)
            current = entry.tasks and entry.tasks.current or fallback
            reset_task_hotpath_timers(current)
            local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
            if not ok_apply then
                log_task_error("watchdog_apply_fallback", entry, current, err_apply)
                siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            end
            return
        end
    end

    local valid_or_err = true
    if should_revalidate_target(current, now, false, entry) then
        local ok_valid, err_or_valid = pcall(is_task_target_valid, current, community, section_name)
        if not ok_valid then
            log_task_error("target_valid", entry, current, err_or_valid)
            siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            return
        end
        valid_or_err = err_or_valid
    end

    if valid_or_err == false then
        local ok_rebuild, rebuilt_or_err = pcall(rebuild_task, se_squad, entry, current)
        if not ok_rebuild then
            log_task_error("rebuild", entry, current, rebuilt_or_err)
            siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            return
        end
        local rebuilt = rebuilt_or_err
        if rebuilt then
            siski.memory.set_task_current(entry.squad_id, rebuilt)
            if not entry.tasks.current then
                siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            end
            reset_task_hotpath_timers(entry.tasks.current)
            local ok_apply, err_apply = pcall(apply_task, se_squad, entry.tasks.current, surge_active, community, section_name)
            if not ok_apply then
                log_task_error("apply_rebuild", entry, entry.tasks.current, err_apply)
                siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            end
            return
        end
    end

    if current.type == "REST_1H" then
        local ok_recover, recovered_or_err = pcall(try_rest_zero_recovery, se_squad, entry, current, surge_active, community, now)
        if not ok_recover then
            log_task_error("rest_zero_recover", entry, current, recovered_or_err)
        elseif recovered_or_err == true then
            return
        end
    end

    if current and current.type ~= "FACTION_TASK" and ROAM_LIKE_TYPES[current.type] then
        -- C: Tick throttle - check only every Nth tick
        RUNTIME.faction_preempt_tick = (RUNTIME.faction_preempt_tick or 0) + 1
        if (RUNTIME.faction_preempt_tick % FACTION_PREEMPT_CHECK_INTERVAL) ~= 0 then
            goto skip_faction_preempt
        end
        
        -- A: Dedicated lane for faction preemption with gentler intervals
        if not adaptive_should_run("tasks.faction_preempt", now, 2000, ADAPTIVE_FORCE_FACTION_PREEMPT_MS) then
            adaptive_note_defer("tasks.faction_preempt", now, "preempt")
            goto skip_faction_preempt
        end
        
        if should_assign_faction_task(entry, cur_level, community, now, false) then
            local faction_task = build_faction_task(se_squad, entry, cur_level, community, section_name, nil)
            if faction_task and should_assign_faction_task(entry, cur_level, community, now, true) then
                siski.memory.set_task_current(entry.squad_id, faction_task)
                current = entry.tasks and entry.tasks.current or faction_task
                reset_task_hotpath_timers(current)
                local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
                if not ok_apply then
                    log_task_error("faction_preempt_apply", entry, current, err_apply)
                    siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
                end
                return
            end
        end
    end
    
    ::skip_faction_preempt::

    local ok_done, done_or_err = pcall(is_task_completed, se_squad, entry, current)
    if not ok_done then
        log_task_error("completed", entry, current, done_or_err)
        siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        return
    end

    if done_or_err == true then
        local ok_rot, err_rot = pcall(rotate_task_on_complete, se_squad, entry, surge_active)
        if not ok_rot then
            log_task_error("rotate", entry, current, err_rot)
            siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        end
        if not (entry.tasks and entry.tasks.current) then
            if current and current.type == "TRADE" then
                local cur_level = resolve_entry_level(entry, se_squad) or entry.level
                entry.level = cur_level
                local community = get_squad_community(entry, se_squad)
                local section_local = get_squad_section(entry, se_squad)
                siski.memory.set_task_current(entry.squad_id, build_explore_task(se_squad, cur_level, community, section_local) or build_rest_task(se_squad))
            else
                siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
            end
        end
        reset_task_hotpath_timers(entry.tasks and entry.tasks.current or nil)
        local ok_apply, err_apply = pcall(apply_task, se_squad, entry.tasks.current, surge_active, community, section_name)
        if not ok_apply then
            log_task_error("apply_next", entry, entry.tasks.current, err_apply)
            siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        end
        return
    end

    if current.type ~= "REST_1H" then
        local ok_apply, err_apply = pcall(apply_task, se_squad, current, surge_active, community, section_name)
        if not ok_apply then
            log_task_error("apply", entry, current, err_apply)
            siski.memory.set_task_current(entry.squad_id, build_rest_task(se_squad))
        end
    end
end

function tasks.force_resync(reason)
    tasks._cold_start_reset_runtime()
    RUNTIME.smarts_rebuild_tg = 0
    RUNTIME.smarts_by_level = {}
    RUNTIME.cap_index_by_level = {}
    RUNTIME.cap_index_rebuild_tg = 0
    RUNTIME.smart_enemy_cache = {}
    RUNTIME.smart_trade_slot_cache = {}
    RUNTIME.smart_tech_slot_cache = {}
    RUNTIME.smart_kamp_slot_cache = {}
    RUNTIME.target_arrived_state_cache = {}
    RUNTIME.smart_enemy_fallback_cache = {}
    RUNTIME.adaptive_trade_target_cache = {}
    RUNTIME.faction_quota = { next_tg = 0, by_level_faction = {} }
    RUNTIME.intel = { by_level_faction = {}, next_cleanup_tg = 0 }
    RUNTIME.stats.force_resync_count = (tonumber(RUNTIME.stats.force_resync_count) or 0) + 1
    if siski.log and siski.log.warn then
        siski.log.warn("TASKS", "force_resync reason=%s", tostring(reason or "-"))
    end
end

function tasks.on_first_update()
    tasks._cold_start_reset_runtime()
    local cs = RUNTIME.cold_start
    local sim_stats = siski.sim and siski.sim.get_runtime_stats and siski.sim.get_runtime_stats() or nil
    cs.active = true
    cs.phase = "warmup"
    cs.started_tg = tg()
    cs.start_sim_cycles = tonumber(sim_stats and sim_stats.completed_cycles) or 0
end

function tasks.capture_bootstrap_candidate(se_squad, entry)
    local cs = RUNTIME.cold_start
    if cs.active ~= true then
        return false
    end
    if not (se_squad and type(entry) == "table") then
        return false
    end
    if entry.npc_kind == "mutant" then
        return false
    end
    if entry.tasks and entry.tasks.current then
        return false
    end
    local sid = tonumber(entry.squad_id) or tonumber(se_squad.id)
    if not sid then
        return false
    end
    tasks._cold_start_enqueue(sid)
    return true
end

function tasks._cold_start_complete_if_ready()
    local cs = RUNTIME.cold_start
    if cs.active ~= true or cs.phase ~= "assign" then
        return false
    end
    if tasks._cold_start_queue_len() > 0 then
        return false
    end

    local sim_stats = siski.sim and siski.sim.get_runtime_stats and siski.sim.get_runtime_stats() or nil
    local cycles = tonumber(sim_stats and sim_stats.completed_cycles) or 0
    if cycles < ((tonumber(cs.start_sim_cycles) or 0) + 1) then
        return false
    end

    tasks._cold_start_log(
        tg(),
        "COLD_START done assigned=%s skipped=%s dropped=%s",
        tostring(tonumber(cs.assigned_count) or 0),
        tostring(tonumber(cs.skipped_count) or 0),
        tostring(tonumber(cs.dropped_count) or 0)
    )
    tasks._cold_start_reset_runtime()
    return true
end

function tasks._cold_start_run_warmup(now)
    local cs = RUNTIME.cold_start
    local profile = tasks._cold_start_profile()
    local deadline = now + (tonumber(profile and profile.warmup_ms) or 2)

    if not RUNTIME.smarts_build.active then
        local smarts_ready = type(RUNTIME.smarts_by_level) == "table"
            and next(RUNTIME.smarts_by_level) ~= nil
            and tonumber(RUNTIME.smarts_rebuild_tg) ~= 0
        if not smarts_ready then
            start_smarts_build()
        end
    end

    while RUNTIME.smarts_build.active and tg() < deadline do
        step_smarts_build(tonumber(RUNTIME.cold_start_cfg.warmup_step_budget) or 16)
    end

    if RUNTIME.smarts_build.active then
        tasks._cold_start_log(now, "COLD_START phase=warmup build=running pending=%s", tostring(tasks._cold_start_queue_len()))
        return true
    end

    if type(RUNTIME.cap_index_by_level) ~= "table" or next(RUNTIME.cap_index_by_level) == nil or tonumber(RUNTIME.cap_index_rebuild_tg) == 0 then
        rebuild_capability_index()
    end

    cs.phase = "assign"
    tasks._cold_start_log(now, "COLD_START phase=warmup ready=true pending=%s", tostring(tasks._cold_start_queue_len()))
    return true
end

function tasks._cold_start_run_assign(now)
    local cs = RUNTIME.cold_start
    local profile = tasks._cold_start_profile()
    local deadline = now + (tonumber(profile and profile.assign_ms) or 2)
    local max_assign = tonumber(profile and profile.assign_budget) or 8
    local sim_obj = alife and alife() or nil
    if not sim_obj then
        return true
    end

    local processed = 0
    while processed < max_assign and tg() < deadline and tasks._cold_start_queue_len() > 0 do
        local sid = tasks._cold_start_dequeue()
        if not sid then
            break
        end
        processed = processed + 1

        local retry_next = tonumber(cs.retry_next_tg_by_sid[sid]) or 0
        if retry_next > now then
            cs.skipped_count = (tonumber(cs.skipped_count) or 0) + 1
            tasks._cold_start_enqueue(sid)
            break
        end

        local se_squad = sim_obj:object(sid)
        if not se_squad then
            cs.dropped_count = (tonumber(cs.dropped_count) or 0) + 1
        else
            local ok_live = false
            local valid_sid = sid
            local reason = nil
            local severity = nil
            if siski.memory and siski.memory.validate_live_squad then
                ok_live, valid_sid, reason, severity = siski.memory.validate_live_squad(se_squad, "tasks.cold_start")
            else
                ok_live = true
            end
            sid = tonumber(valid_sid) or sid

            if not ok_live then
                cs.dropped_count = (tonumber(cs.dropped_count) or 0) + 1
                if severity == "hard" and siski.memory and siski.memory.purge_squad_entry then
                    siski.memory.purge_squad_entry(sid, reason or "invalid_live", "tasks.cold_start")
                elseif siski.memory and siski.memory.mark_squad_missed then
                    siski.memory.mark_squad_missed(sid, "tasks.cold_start", reason or "invalid_live")
                end
            else
                local entry = siski.memory and siski.memory.get_squad_entry and siski.memory.get_squad_entry(sid) or nil
                if not entry and siski.memory and siski.memory.touch_squad_validated then
                    entry = siski.memory.touch_squad_validated(se_squad, false, "tasks.cold_start")
                end

                if type(entry) ~= "table" then
                    cs.dropped_count = (tonumber(cs.dropped_count) or 0) + 1
                elseif (siski.memory and siski.memory.is_protected_squad and siski.memory.is_protected_squad(se_squad))
                    or (siski.memory and siski.memory.should_manage_squad and siski.memory.should_manage_squad(se_squad) ~= true)
                then
                    cs.dropped_count = (tonumber(cs.dropped_count) or 0) + 1
                elseif entry.tasks and entry.tasks.current then
                    cs.dropped_count = (tonumber(cs.dropped_count) or 0) + 1
                    cs.retry_next_tg_by_sid[sid] = nil
                else
                    local task = tasks._build_initial_task_bootstrap(se_squad, entry)
                    if task then
                        cs.retry_next_tg_by_sid[sid] = nil
                        siski.memory.set_task_current(sid, task)
                        reset_task_hotpath_timers(task)
                        cs.assigned_count = (tonumber(cs.assigned_count) or 0) + 1
                    else
                        cs.retry_next_tg_by_sid[sid] = now + (tonumber(RUNTIME.cold_start_cfg.retry_ms) or 1000)
                        cs.skipped_count = (tonumber(cs.skipped_count) or 0) + 1
                        tasks._cold_start_enqueue(sid)
                    end
                end
            end
        end
    end

    tasks._cold_start_log(
        now,
        "COLD_START phase=assign pending=%s assigned=%s skipped=%s dropped=%s",
        tostring(tasks._cold_start_queue_len()),
        tostring(tonumber(cs.assigned_count) or 0),
        tostring(tonumber(cs.skipped_count) or 0),
        tostring(tonumber(cs.dropped_count) or 0)
    )
    tasks._cold_start_complete_if_ready()
    return true
end

function tasks.get_runtime_stats()
    local cs = RUNTIME.cold_start
    return {
        watchdog_rebuild_count = tonumber(RUNTIME.stats.watchdog_rebuild_count) or 0,
        forced_faction_assignments = tonumber(RUNTIME.stats.forced_faction_assignments) or 0,
        forced_faction_releases = tonumber(RUNTIME.stats.forced_faction_releases) or 0,
        faction_runner_cycles = tonumber(RUNTIME.stats.faction_runner_cycles) or 0,
        faction_runner_reacquire = tonumber(RUNTIME.stats.faction_runner_reacquire) or 0,
        force_resync_count = tonumber(RUNTIME.stats.force_resync_count) or 0,
        cold_start_active = cs.active == true,
        cold_start_phase = cs.phase,
        cold_start_pending_len = tasks._cold_start_queue_len(),
        cold_start_assigned_count = tonumber(cs.assigned_count) or 0,
        cold_start_skipped_count = tonumber(cs.skipped_count) or 0,
        cold_start_dropped_count = tonumber(cs.dropped_count) or 0,
    }
end

-- Public gate for external modules (e.g. base_filler) to reuse task safety policy.
-- Returns: allowed:boolean, reason:string
function tasks.is_smart_spawn_allowed(smart_name, community, level_name, section_name)
    if type(smart_name) ~= "string" or smart_name == "" then
        return false, "invalid_smart"
    end

    local board = get_board()
    local sm = board and board.smarts_by_names and board.smarts_by_names[smart_name] or nil
    local lvl = level_name
    if (type(lvl) ~= "string" or lvl == "") and sm and sm.m_game_vertex_id then
        lvl = now_level_name_by_gvid(sm.m_game_vertex_id)
    end

    if sm then
        if smart_is_blacklisted_by_obj(sm, smart_name, community, section_name) then
            return false, "blacklist"
        end
    elseif smart_is_blacklisted_for_level(lvl, smart_name, community, section_name) then
        return false, "blacklist"
    end

    if type(community) == "string" and community ~= "" then
        local ok_enemy, hostile = pcall(has_enemy_stalker_near_smart, smart_name, community, 50, lvl)
        if ok_enemy and hostile == true then
            return false, "enemy"
        end
        if smart_is_safe_for_faction(smart_name, community, lvl) ~= true then
            return false, "unsafe"
        end
    end

    return true, "ok"
end

function tasks.on_update()
    local now = tg()
    prune_runtime_caches(now)
    refresh_faction_quota(now)
    cleanup_intel(now)

    local cs = RUNTIME.cold_start
    if cs.active == true then
        if cs.phase == "warmup" then
            tasks._cold_start_run_warmup(now)
            return
        end
        if cs.phase == "assign" then
            tasks._cold_start_run_assign(now)
            return
        end
    end

    if not RUNTIME.smarts_build.active then
        if RUNTIME.smarts_rebuild_tg == 0 then
            start_smarts_build()
        else
            return
        end
    end
    local budget = 64
    if siski.config and siski.config.get then
        local v = siski.config.get("smarts_index_budget_per_tick", budget)
        if tonumber(v) then budget = tonumber(v) end
    end
    local adaptive = siski.adaptive
    if adaptive and adaptive.get_module_budget then
        budget = adaptive.get_module_budget("tasks_index", budget, 1, 512, 0)
    end
    if budget < 1 then budget = 1 end
    if not adaptive_should_run("tasks.smarts_index_step", now, 250, ADAPTIVE_FORCE_SMARTS_STEP_MS) then
        adaptive_note_defer("tasks.smarts_index_step", now, "lane_pressure")
        return
    end
    if adaptive and adaptive.stage_begin then
        adaptive.stage_begin("tasks.smarts_index_step", now)
    end
    step_smarts_build(budget)
    if adaptive and adaptive.stage_end then
        adaptive.stage_end("tasks.smarts_index_step", tg())
    end
    if not RUNTIME.smarts_build.active and (RUNTIME.cap_index_rebuild_tg == 0 or now > (RUNTIME.cap_index_rebuild_tg + 60000)) then
        rebuild_capability_index()
    end
end
